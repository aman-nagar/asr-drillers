---
import Layout from "../layouts/Layout.astro";
import { commonData } from "../data/locations-i18n.js";
import { getWhatsAppNumber, siteConfig } from "../config/site";

const { phone, whatsapp, yearsActive } = commonData;
const whatsappNumber = getWhatsAppNumber();

const pageTitle = "About ASR Drillers - Boring Machine Manufacturer";
const pageDescription =
  `Learn about ASR Drillers, Kanpur's leading boring machine manufacturer since ${siteConfig.foundingYear}. Quality, innovation, and customer satisfaction.`;
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Hero Section -->
  <section
    class="py-16 md:py-24 bg-gradient-to-r from-brand-teal to-brand-green text-white"
  >
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">About ASR Drillers</h1>
        <p class="text-lg md:text-xl text-teal-100 max-w-2xl mx-auto">
          Leading manufacturer of high-quality boring machines in India for over {
            yearsActive
          } years
        </p>
      </div>
    </div>
  </section>

  <!-- Company Story -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6">
            Our Story
          </h2>
          <p class="text-lg text-slate-600 mb-4">
            ASR Drillers was founded in {siteConfig.foundingYear} with a vision to revolutionize the
            boring machine industry in India. What started as a small
            manufacturing unit in Kanpur has grown into a trusted name across
            northern India.
          </p>
          <p class="text-lg text-slate-600 mb-4">
            We believe in combining traditional craftsmanship with modern
            technology to create machines that are reliable, efficient, and
            built to last. Every machine that leaves our factory undergoes
            rigorous quality checks.
          </p>
          <p class="text-lg text-slate-600">
            Our commitment to customer satisfaction and after-sales support has
            made us the preferred choice for contractors, farmers, and drilling
            companies across India.
          </p>
        </div>
        <div
          class="bg-slate-100 rounded-lg h-96 flex items-center justify-center"
        >
          <div class="text-center">
            <p class="text-6xl font-bold text-brand-teal mb-2">
              {yearsActive}+
            </p>
            <p class="text-xl text-slate-600">Years of Excellence</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Manufacturing Process -->
  <section class="py-16 md:py-24 bg-slate-50">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2
        class="text-3xl md:text-4xl font-bold text-slate-900 mb-12 text-center"
      >
        Manufacturing Process
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div
          class="bg-white p-8 rounded-lg shadow-md text-center border-t-4 border-brand-teal"
        >
          <div class="text-4xl font-bold text-brand-teal mb-4">01</div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">
            Design & Planning
          </h3>
          <p class="text-slate-600">
            Advanced CAD design and engineering for optimal performance and
            durability.
          </p>
        </div>
        <div
          class="bg-white p-8 rounded-lg shadow-md text-center border-t-4 border-brand-green"
        >
          <div class="text-4xl font-bold text-brand-green mb-4">02</div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">
            Component Selection
          </h3>
          <p class="text-slate-600">
            Premium quality parts sourced from certified suppliers and vendors.
          </p>
        </div>
        <div
          class="bg-white p-8 rounded-lg shadow-md text-center border-t-4 border-brand-teal"
        >
          <div class="text-4xl font-bold text-brand-teal mb-4">03</div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">
            Assembly & Testing
          </h3>
          <p class="text-slate-600">
            Precision assembly and rigorous testing at every stage of
            production.
          </p>
        </div>
        <div
          class="bg-white p-8 rounded-lg shadow-md text-center border-t-4 border-brand-green"
        >
          <div class="text-4xl font-bold text-brand-green mb-4">04</div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Quality Control</h3>
          <p class="text-slate-600">
            Final inspection and certification before delivery to customers.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications & Standards -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2
        class="text-3xl md:text-4xl font-bold text-slate-900 mb-12 text-center"
      >
        Quality & Certifications
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-8 bg-slate-50 rounded-lg">
          <div class="text-4xl mb-4">✓</div>
          <h3 class="text-xl font-bold text-brand-teal mb-3">
            ISO 9001 Certified
          </h3>
          <p class="text-slate-600">
            Quality management system certified for consistent excellence.
          </p>
        </div>
        <div class="text-center p-8 bg-slate-50 rounded-lg">
          <div class="text-4xl mb-4">✓</div>
          <h3 class="text-xl font-bold text-brand-green mb-3">
            ISI Mark Approved
          </h3>
          <p class="text-slate-600">
            Indian Standards Institute approval for product quality and safety.
          </p>
        </div>
        <div class="text-center p-8 bg-slate-50 rounded-lg">
          <div class="text-4xl mb-4">✓</div>
          <h3 class="text-xl font-bold text-brand-teal mb-3">
            Tested & Trusted
          </h3>
          <p class="text-slate-600">
            Proven track record with 500+ satisfied customers nationwide.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 md:py-24 bg-slate-50">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2
        class="text-3xl md:text-4xl font-bold text-slate-900 mb-12 text-center"
      >
        Why Choose ASR Drillers?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="flex gap-4">
          <div class="text-3xl text-brand-teal font-bold flex-shrink-0">✓</div>
          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">
              15+ Years Experience
            </h3>
            <p class="text-slate-600">
              Proven expertise in manufacturing and customer satisfaction.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="text-3xl text-brand-green font-bold flex-shrink-0">✓</div>
          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">24/7 Support</h3>
            <p class="text-slate-600">
              Round-the-clock WhatsApp and phone support for all customers.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="text-3xl text-brand-teal font-bold flex-shrink-0">✓</div>
          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">
              Competitive Pricing
            </h3>
            <p class="text-slate-600">
              Best quality at the most affordable prices in the market.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="text-3xl text-brand-green font-bold flex-shrink-0">✓</div>
          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">
              On-Site Installation
            </h3>
            <p class="text-slate-600">
              Free installation and training at your location with expert
              technicians.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="text-3xl text-brand-teal font-bold flex-shrink-0">✓</div>
          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">
              Warranty Support
            </h3>
            <p class="text-slate-600">
              Comprehensive warranty and after-sales service guarantee.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="text-3xl text-brand-green font-bold flex-shrink-0">✓</div>
          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">
              Custom Solutions
            </h3>
            <p class="text-slate-600">
              Tailored machines for specific drilling requirements and
              conditions.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section
    class="py-16 bg-gradient-to-r from-brand-teal to-brand-green text-white"
  >
    <div class="container mx-auto px-4 md:px-8 max-w-6xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Ready to Work with ASR Drillers?
      </h2>
      <p class="text-lg text-teal-100 mb-8 max-w-2xl mx-auto">
        Contact us today for a free quote and consultation with our boring
        machine experts.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="bg-white text-brand-teal px-8 py-3 rounded-lg font-bold hover:bg-slate-100 transition-colors"
        >
          Get Quote
        </a>
        <a
            href={`https://wa.me/${whatsappNumber}`}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-white text-brand-teal px-8 py-3 rounded-lg font-bold hover:bg-slate-100 transition-colors"
        >
          WhatsApp Us
        </a>
      </div>
    </div>
  </section>
</Layout>
