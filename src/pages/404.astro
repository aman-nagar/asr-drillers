---
import Layout from "../layouts/Layout.astro";
import { commonData } from "../data/locations-i18n.js";
import { getAbsoluteUrl } from "../config/site.js";
import { getLocaleFromPath, withLocalePrefix } from "../lib/i18n.js";

const { phone, whatsapp } = commonData;

const currentPath = Astro.url?.pathname || "/404";
const locale = getLocaleFromPath(currentPath);
const isHindi = locale === "hi";

const pageTitle = isHindi
  ? "404 - पेज नहीं मिला | ASR Drillers"
  : "404 - Page Not Found | ASR Drillers";

const pageDescription = isHindi
  ? "क्षमा करें, यह पेज नहीं मिला। ASR Drillers - भारत में बोरिंग मशीन निर्माता।"
  : "Sorry, this page doesn't exist. ASR Drillers - Boring Machine Manufacturer in India.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  noindex={true}
  alternateUrls={{
    en: getAbsoluteUrl("/404/"),
    xDefault: getAbsoluteUrl("/404/"),
  }}
>
  <!-- 404 Hero -->
  <section class="flex min-h-[70vh] items-center justify-center bg-gradient-to-br from-brand-teal to-brand-green py-14 md:py-16">
    <div class="container mx-auto px-4 text-center text-white">
      <div class="mb-6 md:mb-8">
        <span class="text-7xl font-bold opacity-20 md:text-9xl">404</span>
      </div>
      <h1 class="mb-5 text-4xl font-bold md:mb-6 md:text-5xl">
        {isHindi ? "पेज नहीं मिला" : "Page Not Found"}
      </h1>
      <p class="mx-auto mb-7 max-w-2xl text-xl opacity-90 md:mb-8 md:text-2xl">
        {isHindi
          ? "क्षमा करें, जिस पेज को आप खोज रहे हैं वह मौजूद नहीं है।"
          : "Sorry, the page you're looking for doesn't exist or has been moved."}
      </p>
      <div class="flex flex-col justify-center gap-3 sm:flex-row sm:gap-4">
        <a
          href={withLocalePrefix("/", locale)}
          class="rounded-2xl bg-white px-8 py-4 text-lg font-bold text-brand-teal transition hover:bg-gray-100"
        >
          {isHindi ? "🏠 होम पेज पर जाएं" : "🏠 Go to Homepage"}
        </a>
        <a
          href={`https://wa.me/${whatsapp.replace(/[^0-9]/g, "")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-2xl bg-brand-green px-8 py-4 text-lg font-bold text-white transition hover:bg-brand-green/90"
        >
          {isHindi ? "💬 WhatsApp पर संपर्क करें" : "💬 Contact on WhatsApp"}
        </a>
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="section-shell bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-4xl">
      <h2 class="mb-6 text-center text-2xl font-bold text-gray-900 md:mb-8 md:text-3xl">
        {isHindi ? "लोकप्रिय पेज" : "Popular Pages"}
      </h2>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <a
          href={withLocalePrefix("/", locale)}
          class="group rounded-2xl bg-gray-50 p-5 transition hover:bg-brand-teal/10 md:p-6"
        >
          <h3 class="font-bold text-lg text-brand-teal group-hover:text-brand-green">
            {isHindi ? "🏠 होमपेज" : "🏠 Homepage"}
          </h3>
          <p class="text-sm text-gray-600 mt-1">
            {isHindi ? "हमारी सभी मशीनें देखें" : "View all our machines"}
          </p>
        </a>
        <a
          href={withLocalePrefix("/kanpur", locale)}
          class="group rounded-2xl bg-gray-50 p-5 transition hover:bg-brand-teal/10 md:p-6"
        >
          <h3 class="font-bold text-lg text-brand-teal group-hover:text-brand-green">
            📍 Kanpur
          </h3>
          <p class="text-sm text-gray-600 mt-1">
            {isHindi ? "कानपुर में बोरिंग मशीन" : "Boring machines in Kanpur"}
          </p>
        </a>
        <a
          href="/products/22-hp-submersible"
          class="group rounded-2xl bg-gray-50 p-5 transition hover:bg-brand-teal/10 md:p-6"
        >
          <h3 class="font-bold text-lg text-brand-teal group-hover:text-brand-green">
            ⚙️ 22 HP Submersible
          </h3>
          <p class="text-sm text-gray-600 mt-1">
            {isHindi ? "₹4.8 लाख से शुरू" : "Starting ₹4.8 Lakh"}
          </p>
        </a>
        <a
          href={withLocalePrefix("/contact", locale)}
          class="group rounded-2xl bg-gray-50 p-5 transition hover:bg-brand-teal/10 md:p-6"
        >
          <h3 class="font-bold text-lg text-brand-teal group-hover:text-brand-green">
            📞 {isHindi ? "संपर्क करें" : "Contact Us"}
          </h3>
          <p class="text-sm text-gray-600 mt-1">
            {isHindi ? "अभी संपर्क करें" : "Get in touch now"}
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section
    class="bg-gradient-to-r from-brand-teal to-brand-green py-10 text-white md:py-12"
  >
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-3 text-2xl font-bold md:mb-4 md:text-3xl">
        {isHindi ? "क्या आपको मदद चाहिए?" : "Need Help Finding Something?"}
      </h2>
      <p class="mb-5 text-lg opacity-90 md:mb-6">
        {isHindi
          ? "हमारी टीम आपकी मदद के लिए उपलब्ध है।"
          : "Our team is available to help you."}
      </p>
      <div class="flex flex-col justify-center gap-3 sm:flex-row sm:gap-4">
        <a
          href={`tel:${phone}`}
          class="rounded-2xl bg-white px-6 py-3 font-bold text-brand-teal transition hover:bg-gray-100"
        >
          📞 {phone}
        </a>
        <a
          href={`https://wa.me/${whatsapp.replace(/[^0-9]/g, "")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-2xl bg-brand-green px-6 py-3 font-bold text-white transition hover:bg-brand-green/90"
        >
          💬 WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>
