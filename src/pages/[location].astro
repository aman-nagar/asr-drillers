---
import LocationPageTemplate from "../components/templates/LocationPageTemplate.astro";
import { commonData, locationsData } from "../data/locations-i18n.js";

const { location } = Astro.params;
const locale = "en";
const locationData = locationsData[location as keyof typeof locationsData];
const pageData = locationData?.[locale as "en" | "hi"];

if (!pageData) {
  throw new Error(`Location "${location}" not found`);
}

export function getStaticPaths() {
  return Object.keys(locationsData).map((loc) => ({
    params: { location: loc },
  }));
}
---

<LocationPageTemplate
  locale="en"
  location={location}
  pageData={pageData}
  faqItems={commonData.commonFAQEn}
/>
