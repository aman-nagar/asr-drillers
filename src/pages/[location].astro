---
import Layout from "../layouts/Layout.astro";
import TrustBadges from "../components/TrustBadges.astro";
import ModelsTable from "../components/ModelsTable.astro";
import LocalProblemsSolutions from "../components/LocalProblemsSolutions.astro";
import TestimonialsGrid from "../components/TestimonialsGrid.astro";
import FAQSection from "../components/FAQSection.astro";
import CommonCTA from "../components/CommonCTA.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { commonData, locationsData } from "../data/locations-i18n.js";
import { getAbsoluteUrl, siteConfig } from "../config/site";

interface Props {
  location: string;
}

const { location } = Astro.params;
const locale = "en";
const locationData = locationsData[location as keyof typeof locationsData];
const pageData = locationData?.[locale as "en" | "hi"];

if (!pageData) {
  throw new Error(`Location "${location}" not found`);
}

export function getStaticPaths() {
  return Object.keys(locationsData).map((loc) => ({
    params: { location: loc },
  }));
}

const pageTitle = `${pageData.title} | ASR Drillers - Boring Machines`;
const pageDescription = pageData.description;

const breadcrumbs = [
  { label: pageData.title, href: `/${location}` },
];

// LocalBusiness Schema
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `https://asrdrillers.com/${location}/#localbusiness`,
  name: `ASR Drillers - ${pageData.title}`,
  image: getAbsoluteUrl(siteConfig.logoPath),
  description: pageData.description,
  url: `https://asrdrillers.com/${location}`,
  address: {
    "@type": "PostalAddress",
    addressLocality: pageData.title,
    addressRegion: "Uttar Pradesh",
    addressCountry: "IN",
  },
  telephone: commonData.phone,
  areaServed: pageData.areaServed,
  priceRange: "₹450000-₹750000",
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
    opens: "08:00",
    closes: "20:00",
  },
};

// FAQPage Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: commonData.commonFAQEn.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Breadcrumbs -->
  <Breadcrumbs breadcrumbs={breadcrumbs} />

  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-brand-teal to-brand-green text-white py-16 md:py-24">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
        {pageData.heroHeadline}
      </h1>
      <p class="text-lg md:text-xl mb-8 leading-relaxed opacity-95">
        {pageData.description}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={`https://wa.me/${commonData.whatsapp.replace(/[^0-9]/g, "")}?text=${encodeURIComponent(`Hi! I'm interested in boring machines in ${pageData.title}. Please share details.`)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-brand-green hover:bg-brand-green/90 text-white font-bold py-3 px-6 rounded text-center transition flex items-center justify-center gap-2"
        >
          💬 WhatsApp Now
        </a>
        <a
          href={`tel:${commonData.phone}`}
          class="bg-white text-brand-teal hover:bg-gray-100 font-bold py-3 px-6 rounded text-center transition"
        >
          📞 Get Quote
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Badges -->
  <TrustBadges />

  <!-- Local Problems & Solutions -->
  {
    pageData.localProblems && pageData.localSolutions && (
      <LocalProblemsSolutions
        problems={pageData.localProblems}
        solutions={pageData.localSolutions}
      />
    )
  }

  <!-- Featured Products -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center text-gray-900">
        Our Best-Selling Boring Machines
      </h2>
      <p class="text-center text-gray-600 mb-12 text-lg">
        Professional-grade machines designed for Indian terrain
      </p>
      <ModelsTable />
    </div>
  </section>

  <!-- Local Testimonials -->
  {
    pageData.localTestimonials && pageData.localTestimonials.length > 0 && (
      <section class="py-16 bg-white">
        <div class="container mx-auto px-4 md:px-8 max-w-6xl">
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center text-gray-900">
            Success Stories from {pageData.title}
          </h2>
          <p class="text-center text-gray-600 mb-12 text-lg">
            Real feedback from contractors and farmers in {pageData.title}
          </p>
          <TestimonialsGrid testimonials={pageData.localTestimonials} />
        </div>
      </section>
    )
  }

  <!-- Shipping Info -->
  {
    pageData.shippingInfo && (
      <section class="py-16 bg-gray-50">
        <div class="container mx-auto px-4 md:px-8 max-w-6xl">
          <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center text-gray-900">
            Delivery & Support in {pageData.title}
          </h2>
          <div class="bg-white p-8 rounded-lg border-l-4 border-brand-teal max-w-2xl mx-auto shadow-sm">
            <p class="text-lg text-gray-700 leading-relaxed">
              {pageData.shippingInfo}
            </p>
          </div>
        </div>
      </section>
    )
  }

  <!-- FAQ Section with Schema -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-4xl">
      <FAQSection
        faqs={commonData.commonFAQEn}
        title="Common Questions About Our Boring Machines"
      />
    </div>
  </section>

  <!-- CTA Section -->
  <CommonCTA
    headline={`Ready to Get Started in ${pageData.title}?`}
    subheadline="Get a custom quote from Kanpur's trusted manufacturer. We serve your area with quick delivery and on-site support."
  />
</Layout>
