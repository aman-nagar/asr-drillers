---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getAbsoluteUrl } from "../../config/site";

const pageTitle = "22 HP Submersible Boring Machine | ASR Drillers Kanpur";
const pageDescription =
  "22 HP submersible boring machine for tubewell drilling. 150-300 feet depth. Cast iron build. Kirloskar engine. ₹4.8 lakh. Free installation & training in UP.";

const breadcrumbs = [{ label: "22 HP Submersible", href: "/products/22-hp-submersible" }];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "22 HP Submersible Boring Machine",
  image: "https://asrdrillers.com/images/22-hp-submersible.jpg",
  description:
    "High-quality submersible boring machine for deep tubewell drilling. 150-300 feet depth capacity. Kirloskar 22 HP diesel engine.",
  brand: {
    "@type": "Brand",
    name: "ASR Drillers",
  },
  manufacturer: {
    "@type": "Organization",
    name: "ASR Drillers",
    url: "https://asrdrillers.com",
  },
  model: "22 HP Submersible",
  sku: "ASR-22HP-SUB",
  offers: {
    "@type": "Offer",
    priceCurrency: "INR",
    price: "480000",
    priceValidUntil: "2026-12-31",
    availability: "https://schema.org/InStock",
    seller: {
      "@type": "Organization",
      name: "ASR Drillers",
    },
    hasMerchantReturnPolicy: {
      "@type": "MerchantReturnPolicy",
      applicableCountry: "IN",
      returnPolicyCategory: "https://schema.org/MerchantReturnFiniteReturnWindow",
      merchantReturnDays: 30,
    },
  },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.8",
    bestRating: "5",
    worstRating: "1",
    ratingCount: "45",
  },
  hasProductSpecification: [
    { "@type": "PropertyValue", name: "Power", value: "22 HP" },
    { "@type": "PropertyValue", name: "Engine", value: "Kirloskar Diesel" },
    { "@type": "PropertyValue", name: "Max Depth", value: "300 feet" },
    { "@type": "PropertyValue", name: "Bore Diameter", value: "4-6 inch" },
    { "@type": "PropertyValue", name: "Fuel Consumption", value: "8-10 L/day" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Can the 22 HP drill 300 feet every time?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Not guaranteed. Depth depends on soil composition. Soft clay/sandy: 300 ft possible. Hard rock layers: May hit 150-200 ft. Best practice: Survey soil before drilling. ASR engineer can advise.",
      },
    },
    {
      "@type": "Question",
      name: "How much does fuel cost per borewell?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "For a 200-foot borewell: ~₹150-200 in fuel at current rates (₹90/liter). A 150-foot well might cost ₹100-120. Actual cost varies by soil hardness.",
      },
    },
    {
      "@type": "Question",
      name: "Is installation included in the price?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Price includes delivery and on-site setup in UP. ASR engineer sets up machine, tests it, trains your operator. No hidden charges. Installation takes 2-4 hours.",
      },
    },
    {
      "@type": "Question",
      name: "Can I get this machine on EMI?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Partner banks (HDFC, Axis, ICICI) offer 24-36 month EMI at 9-12% interest. Loan amount: 80-90% of price. Approval in 3-5 days. We handle paperwork.",
      },
    },
  ],
};

---

<Layout
  title={pageTitle}
  description={pageDescription}
  alternateUrls={{
    en: getAbsoluteUrl("/products/22-hp-submersible/"),
    xDefault: getAbsoluteUrl("/products/22-hp-submersible/"),
  }}
>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Breadcrumb -->
  <Breadcrumbs breadcrumbs={breadcrumbs} />

  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-blue-600 to-blue-500 text-white py-16">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div>
          <h1 class="text-4xl md:text-5xl font-bold mb-6">
            22 HP Submersible Boring Machine
          </h1>
          <p class="text-lg mb-6 opacity-95">
            Lightweight, high-precision tubewell boring. Drills 150–300 feet in
            clay, sandy soil, and soft rock. Perfect for farmers and small
            contractors.
          </p>
          <div class="bg-white bg-opacity-20 p-6 rounded-lg mb-6">
            <p class="text-3xl font-bold mb-2">₹4.8 Lakh</p>
            <p class="text-sm opacity-90">
              Includes basic accessories. Free installation & training in UP.
            </p>
          </div>
          <a
            href="https://wa.me/919876543210?text=Interested%20in%2022%20HP%20Submersible%20boring%20machine"
            class="bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-6 rounded inline-block"
          >
            📱 Get Quote on WhatsApp
          </a>
        </div>
        <div
          class="bg-blue-400 h-96 rounded-lg flex items-center justify-center"
        >
          <span class="text-white text-center">
            [22 HP Submersible Machine Image]
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Specs -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2 class="text-3xl font-bold mb-12 text-center text-gray-900">
        Technical Specifications
      </h2>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div>
          <h3 class="text-2xl font-bold mb-6 text-blue-900">Engine & Power</h3>
          <ul class="space-y-3 text-gray-700">
            <li><strong>Engine:</strong> Kirloskar 22 HP Diesel</li>
            <li><strong>Fuel Capacity:</strong> 20 liters</li>
            <li>
              <strong>Daily Consumption:</strong> 8–10 liters (continuous)
            </li>
            <li><strong>RPM Range:</strong> 1200–1500 variable</li>
            <li><strong>Starting:</strong> Hand crank + electric starter</li>
            <li><strong>Cooling:</strong> Air-cooled with radiator</li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-6 text-blue-900">
            Drilling Capability
          </h3>
          <ul class="space-y-3 text-gray-700">
            <li><strong>Max Depth:</strong> 300 feet (in soft soil)</li>
            <li><strong>Min Depth:</strong> 150 feet (economic viability)</li>
            <li><strong>Borehole Diameter:</strong> 4–6 inch</li>
            <li><strong>Soil Types:</strong> Clay, sandy soil, soft rock</li>
            <li><strong>Drilling Speed:</strong> 20–30 feet/hour (average)</li>
            <li><strong>Torque:</strong> 180 Nm at full power</li>
          </ul>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-2xl font-bold mb-6 text-blue-900">Physical Build</h3>
          <ul class="space-y-3 text-gray-700">
            <li>
              <strong>Body Material:</strong> Cast iron frame + steel drilling head
            </li>
            <li><strong>Weight:</strong> 850 kg (machine only)</li>
            <li>
              <strong>Dimensions:</strong> 2.5 m (L) × 1.8 m (W) × 2.1 m (H)
            </li>
            <li>
              <strong>Mounting:</strong> Trolley-based (tractor-compatible)
            </li>
            <li>
              <strong>Color:</strong> Factory blue with yellow safety markings
            </li>
            <li><strong>Durability:</strong> 15+ years with maintenance</li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-6 text-blue-900">
            Accessories Included
          </h3>
          <ul class="space-y-3 text-gray-700">
            <li>✓ Drilling pipes (4-inch diameter, 20 ft sections)</li>
            <li>✓ Coupling joints & safety straps</li>
            <li>✓ Spoon tool & cutter for soil extraction</li>
            <li>✓ Tool kit (wrenches, pliers, screwdrivers)</li>
            <li>✓ User manual (Hindi + English)</li>
            <li>✓ Basic spare parts (filter, oil, piston seals)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose This Model -->
  <section class="py-16 bg-blue-50">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2 class="text-3xl font-bold mb-12 text-center text-gray-900">
        Why the 22 HP is Perfect for You
      </h2>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div>
          <h3 class="text-2xl font-bold mb-6 text-blue-900">Best For</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex gap-3">
              <span class="text-green-600 font-bold">✓</span>
              <span
                ><strong>Small Farmers:</strong> 10–30 acre farms needing 1–2 borewells/year</span
              >
            </li>
            <li class="flex gap-3">
              <span class="text-green-600 font-bold">✓</span>
              <span
                ><strong>Village Cooperatives:</strong> Affordable entry point for
                shared drilling</span
              >
            </li>
            <li class="flex gap-3">
              <span class="text-green-600 font-bold">✓</span>
              <span
                ><strong>Young Contractors:</strong> Building drilling business on
                budget</span
              >
            </li>
            <li class="flex gap-3">
              <span class="text-green-600 font-bold">✓</span>
              <span
                ><strong>Shallow-to-Medium Borewells:</strong> 150–250 feet is sweet
                spot</span
              >
            </li>
            <li class="flex gap-3">
              <span class="text-green-600 font-bold">✓</span>
              <span
                ><strong>UP/Bihar Soil Types:</strong> Excels in clay & sandy terrain</span
              >
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-6 text-blue-900">Key Advantages</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex gap-3">
              <span class="text-green-600 font-bold">✓</span>
              <span
                ><strong>Affordable:</strong> ₹4.8 lakh vs. ₹5.8–7.2 lakh for bigger
                models</span
              >
            </li>
            <li class="flex gap-3">
              <span class="text-green-600 font-bold">✓</span>
              <span
                ><strong>Fuel Efficient:</strong> 8–10 L/day costs ₹150–200 per borewell</span
              >
            </li>
            <li class="flex gap-3">
              <span class="text-green-600 font-bold">✓</span>
              <span
                ><strong>Easy to Transport:</strong> Lighter, fits standard tractor
                PTO</span
              >
            </li>
            <li class="flex gap-3">
              <span class="text-green-600 font-bold">✓</span>
              <span
                ><strong>Quick Payback:</strong> ROI in 12–18 months at 6–8 wells/year</span
              >
            </li>
            <li class="flex gap-3">
              <span class="text-green-600 font-bold">✓</span>
              <span
                ><strong>Low Maintenance:</strong> Simple design, local spares always
                available</span
              >
            </li>
          </ul>
        </div>
      </div>

      <div class="bg-white p-8 rounded-lg">
        <h3 class="text-2xl font-bold mb-4 text-blue-900">
          Real-World Drilling Time Example
        </h3>
        <p class="text-gray-700 mb-6">
          Drilling a 200-foot borewell in typical UP clay soil with 4-inch
          diameter:
        </p>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="border-2 border-blue-600 p-4 rounded">
            <p class="text-sm text-gray-600 mb-1">Drilling Time</p>
            <p class="text-3xl font-bold text-blue-600">8–10 Hours</p>
          </div>
          <div class="border-2 border-blue-600 p-4 rounded">
            <p class="text-sm text-gray-600 mb-1">Fuel Used</p>
            <p class="text-3xl font-bold text-blue-600">9–11 Liters</p>
          </div>
          <div class="border-2 border-blue-600 p-4 rounded">
            <p class="text-sm text-gray-600 mb-1">Cost per Well</p>
            <p class="text-3xl font-bold text-blue-600">₹2,000</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2 class="text-3xl font-bold mb-12 text-center text-gray-900">
        How 22 HP Compares
      </h2>

      <div class="overflow-x-auto">
        <table class="w-full bg-white rounded-lg overflow-hidden shadow">
          <thead class="bg-blue-900 text-white">
            <tr>
              <th class="p-4 text-left">Feature</th>
              <th class="p-4 text-center">22 HP (This)</th>
              <th class="p-4 text-center">30 HP</th>
              <th class="p-4 text-center">38 HP</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b">
              <td class="p-4 font-semibold">Price</td>
              <td class="p-4 text-center font-bold text-green-600">₹4.8 L</td>
              <td class="p-4 text-center">₹5.8 L</td>
              <td class="p-4 text-center">₹7.2 L</td>
            </tr>
            <tr class="border-b bg-gray-50">
              <td class="p-4 font-semibold">Max Depth</td>
              <td class="p-4 text-center font-bold text-green-600">300 ft</td>
              <td class="p-4 text-center">400 ft</td>
              <td class="p-4 text-center">500+ ft</td>
            </tr>
            <tr class="border-b">
              <td class="p-4 font-semibold">Fuel/Day</td>
              <td class="p-4 text-center font-bold text-green-600">9–10 L</td>
              <td class="p-4 text-center">13–14 L</td>
              <td class="p-4 text-center">18–20 L</td>
            </tr>
            <tr class="border-b bg-gray-50">
              <td class="p-4 font-semibold">Hard Rock</td>
              <td class="p-4 text-center">Good</td>
              <td class="p-4 text-center font-bold text-green-600">Excellent</td
              >
              <td class="p-4 text-center">Maximum</td>
            </tr>
            <tr class="border-b">
              <td class="p-4 font-semibold">Portability</td>
              <td class="p-4 text-center font-bold text-green-600">Excellent</td
              >
              <td class="p-4 text-center">Good</td>
              <td class="p-4 text-center">Fair</td>
            </tr>
            <tr class="border-b bg-gray-50">
              <td class="p-4 font-semibold">Maintenance</td>
              <td class="p-4 text-center font-bold text-green-600">Simple</td>
              <td class="p-4 text-center">Simple</td>
              <td class="p-4 text-center">Simple</td>
            </tr>
            <tr>
              <td class="p-4 font-semibold">Best Use Case</td>
              <td class="p-4 text-center font-bold text-green-600">Farmers</td>
              <td class="p-4 text-center">Contractors</td>
              <td class="p-4 text-center">Heavy Duty</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- User Testimonials -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2 class="text-3xl font-bold mb-12 text-center text-gray-900">
        What Users Say About the 22 HP
      </h2>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white p-8 rounded-lg shadow">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-blue-200 rounded-full"></div>
            <div>
              <p class="font-bold text-gray-900">Farmer Rajesh</p>
              <p class="text-sm text-gray-600">Kanpur District</p>
            </div>
          </div>
          <p class="text-gray-700 mb-4">
            "Bought the 22 HP two years ago. Drilled three successful wells.
            Machine never failed. Spare parts from Kanpur factory are always
            available. Best investment I made for my farm."
          </p>
          <p class="text-yellow-500 font-semibold">★★★★★</p>
        </div>

        <div class="bg-white p-8 rounded-lg shadow">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-blue-200 rounded-full"></div>
            <div>
              <p class="font-bold text-gray-900">Contractor Amit</p>
              <p class="text-sm text-gray-600">Lucknow</p>
            </div>
          </div>
          <p class="text-gray-700 mb-4">
            "Started my drilling business with this 22 HP. Fuel cost is
            manageable. Speed is good for my client base. In 18 months, ROI is
            already hit. Quality is top-notch."
          </p>
          <p class="text-yellow-500 font-semibold">★★★★★</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ for 22 HP -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2 class="text-3xl font-bold mb-12 text-center text-gray-900">
        22 HP Submersible – Frequently Asked Questions
      </h2>

      <div class="space-y-6 max-w-3xl mx-auto">
        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary
            class="font-bold text-lg text-gray-900 flex items-center gap-3"
          >
            <span class="group-open:rotate-180 transition text-blue-600">▼</span
            >
            Can the 22 HP drill 300 feet every time?
          </summary>
          <p class="mt-4 text-gray-700 ml-6">
            Not guaranteed. Depth depends on soil composition. Soft clay/sandy:
            300 ft possible. Hard rock layers: May hit 150–200 ft. Best
            practice: Survey soil before drilling. ASR engineer can advise.
          </p>
        </details>

        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary
            class="font-bold text-lg text-gray-900 flex items-center gap-3"
          >
            <span class="group-open:rotate-180 transition text-blue-600">▼</span
            >
            How much does fuel cost per borewell?
          </summary>
          <p class="mt-4 text-gray-700 ml-6">
            For a 200-foot borewell: ~₹150–200 in fuel at current rates
            (₹90/liter). A 150-foot well might cost ₹100–120. Actual cost varies
            by soil hardness and drilling speed.
          </p>
        </details>

        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary
            class="font-bold text-lg text-gray-900 flex items-center gap-3"
          >
            <span class="group-open:rotate-180 transition text-blue-600">▼</span
            >
            Is installation included in the price?
          </summary>
          <p class="mt-4 text-gray-700 ml-6">
            Yes. Price includes delivery and on-site setup in UP. ASR engineer
            sets up machine, tests it, trains your operator. No hidden charges.
            Installation takes 2–4 hours.
          </p>
        </details>

        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary
            class="font-bold text-lg text-gray-900 flex items-center gap-3"
          >
            <span class="group-open:rotate-180 transition text-blue-600">▼</span
            >
            How long does the 22 HP last?
          </summary>
          <p class="mt-4 text-gray-700 ml-6">
            With proper maintenance: 12–15 years or more. Annual servicing is
            key. We run machines 10+ years reliably. Engine parts are
            standardized Kirloskar — easy to replace.
          </p>
        </details>

        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary
            class="font-bold text-lg text-gray-900 flex items-center gap-3"
          >
            <span class="group-open:rotate-180 transition text-blue-600">▼</span
            >
            Can I rent this machine instead?
          </summary>
          <p class="mt-4 text-gray-700 ml-6">
            Yes. Rental: ₹800–1,000/day including operator support. Minimum 7
            days. Delivery free within 50 km. If renting multiple times, buying
            usually pays off faster.
          </p>
        </details>

        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary
            class="font-bold text-lg text-gray-900 flex items-center gap-3"
          >
            <span class="group-open:rotate-180 transition text-blue-600">▼</span
            >
            What warranty is included?
          </summary>
          <p class="mt-4 text-gray-700 ml-6">
            1-year comprehensive warranty covering manufacturing defects. Year 2
            available at discounted rate. Free annual service camp included.
            Post-warranty repairs: ₹2,000–3,000 per service.
          </p>
        </details>

        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary
            class="font-bold text-lg text-gray-900 flex items-center gap-3"
          >
            <span class="group-open:rotate-180 transition text-blue-600">▼</span
            >
            Can I get this machine on EMI?
          </summary>
          <p class="mt-4 text-gray-700 ml-6">
            Yes. Partner banks (HDFC, Axis, ICICI) offer 24–36 month EMI at
            9–12% interest. Loan amount: 80–90% of price. Approval in 3–5 days.
            We handle paperwork.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-16 bg-gradient-to-r from-blue-600 to-blue-500 text-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Ready to Start Drilling?
      </h2>
      <p class="text-xl mb-8 opacity-95">
        Get detailed specs, pricing, and financing options. Response in 1 hour.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://wa.me/919876543210?text=22HP%20Submersible%20quotation"
          class="bg-green-500 hover:bg-green-600 text-white font-bold py-4 px-8 rounded-lg text-lg"
        >
          💬 WhatsApp Quote
        </a>
        <a
          href="tel:+919876543210"
          class="bg-yellow-400 text-gray-900 hover:bg-yellow-500 font-bold py-4 px-8 rounded-lg text-lg"
        >
          📞 Call: +91-98765-43210
        </a>
      </div>
    </div>
  </section>
</Layout>
