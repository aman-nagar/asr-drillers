---
import Layout from "../../layouts/Layout.astro";

const pageTitle = "30 HP Hydraulic Boring Machine | ASR Drillers Kanpur";
const pageDescription =
  "30 HP hydraulic boring machine for precision tubewell drilling. 250-400 feet depth. Variable RPM. Hard rock specialist. ₹5.8 lakh. On-site installation & 24/7 support.";
const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "30 HP Hydraulic Boring Machine",
  brand: "ASR Drillers",
  manufacturer: "ASR Drillers",
  description:
    "Professional-grade hydraulic boring machine for challenging terrain",
  offers: {
    "@type": "Offer",
    priceCurrency: "INR",
    price: "580000",
    availability: "https://schema.org/InStock",
  },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.9",
    bestRating: "5",
    worstRating: "1",
    ratingCount: "52",
  },
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Breadcrumb -->
  <nav class="bg-gray-100 py-3 px-4">
    <div class="container mx-auto max-w-6xl text-sm text-gray-600">
      <a href="/" class="text-blue-600 hover:underline">Home</a> /
      <a href="#products" class="text-blue-600 hover:underline">Products</a> /
      <span>30 HP Hydraulic</span>
    </div>
  </nav>

  <!-- Hero Section -->
  <section
    class="bg-gradient-to-r from-purple-600 to-purple-500 text-white py-16"
  >
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div>
          <h1 class="text-4xl md:text-5xl font-bold mb-6">
            30 HP Hydraulic Boring Machine
