---
import Layout from "../../layouts/Layout.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import ModelsTable from "../../components/ModelsTable.astro";
import LocalProblemsSolutions from "../../components/LocalProblemsSolutions.astro";
import TestimonialsGrid from "../../components/TestimonialsGrid.astro";
import FAQSection from "../../components/FAQSection.astro";
import CommonCTA from "../../components/CommonCTA.astro";
import { commonData, locationsData } from "../../data/locations-i18n.js";

interface Props {
  location: string;
}

const { location } = Astro.params;
const locale = "hi"; // Hindi for /hi/[location] routes
const locationData = locationsData[location as keyof typeof locationsData];
const pageData = locationData?.[locale as "en" | "hi"];

if (!pageData) {
  throw new Error(`Location "${location}" not found in Hindi`);
}

export function getStaticPaths() {
  return Object.keys(locationsData).map((location) => ({
    params: { location },
  }));
}

const pageTitle = `${pageData.title} | ASR ड्रिलर्स - बोरिंग मशीनें`;
const pageDescription = pageData.description;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: `ASR ड्रिलर्स - ${pageData.title}`,
  image: "https://asrdrillers.com/logo.png",
  description: pageData.description,
  address: {
    "@type": "PostalAddress",
    addressLocality: pageData.title,
    addressRegion: "UP",
    addressCountry: "IN",
  },
  telephone: `+${commonData.phone}`,
  areaServed: pageData.areaServed,
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Hero Section -->
  <section
    class="hero-section bg-gradient-to-r from-teal-700 to-teal-600 text-white py-16 md:py-24"
  >
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
        {pageData.heroHeadline}
      </h1>
      <p class="text-lg md:text-xl mb-8 leading-relaxed opacity-95">
        {pageData.description}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={`https://wa.me/${commonData.whatsapp.replace(/[^0-9]/g, "")}?text=नमस्ते%20ASR%20ड्रिलर्स%21%20मुझे%20बोरिंग%20मशीन%20के%20बारे%20में%20जानना%20है।`}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-6 rounded text-center transition"
        >
          📱 व्हाट्सऐप पर संपर्क करें
        </a>
        <a
          href={`tel:${commonData.phone}`}
          class="bg-white text-teal-700 hover:bg-gray-100 font-bold py-3 px-6 rounded text-center transition"
        >
          📞 कॉल करें
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Badges -->
  <TrustBadges />

  <!-- Local Problems & Solutions -->
  {
    pageData.localProblems && pageData.localSolutions && (
      <LocalProblemsSolutions
        problems={pageData.localProblems}
        solutions={pageData.localSolutions}
      />
    )
  }

  <!-- Featured Products -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2
        class="text-3xl md:text-4xl font-bold mb-12 text-center text-gray-900"
      >
        हमारी सर्वश्रेष्ठ मॉडल
      </h2>
      <ModelsTable models={commonData.models} />
    </div>
  </section>

  <!-- Local Testimonials -->
  {
    pageData.localTestimonials && (
      <section class="py-16 bg-white">
        <div class="container mx-auto px-4 md:px-8 max-w-6xl">
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center text-gray-900">
            {pageData.title} में सफलता की कहानियाँ
          </h2>
          <p class="text-center text-gray-600 mb-12 text-lg">
            देखें कि {pageData.title} के स्थानीय ठेकेदार और किसान ASR ड्रिलर्स
            से कैसे लाभान्वित हो रहे हैं।
          </p>
          <TestimonialsGrid testimonials={pageData.localTestimonials} />
        </div>
      </section>
    )
  }

  <!-- Shipping Info -->
  {
    pageData.shippingInfo && (
      <section class="py-16 bg-gray-50">
        <div class="container mx-auto px-4 md:px-8 max-w-6xl">
          <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center text-gray-900">
            {pageData.title} में डिलीवरी और समर्थन
          </h2>
          <div class="bg-white p-8 rounded-lg border-l-4 border-teal-700 max-w-2xl mx-auto">
            <p class="text-lg text-gray-700 leading-relaxed">
              {pageData.shippingInfo}
            </p>
          </div>
        </div>
      </section>
    )
  }

  <!-- FAQ Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <FAQSection
        faqs={commonData.commonFAQHi}
        title="हमारी बोरिंग मशीनों के बारे में आम प्रश्न"
      />
    </div>
  </section>

  <!-- CTA Section -->
  <CommonCTA
    headline={`${pageData.title} में शुरुआत करने के लिए तैयार?`}
    subheadline="कानपुर के विश्वस्त निर्माता से कस्टम उद्धरण प्राप्त करें। हम आपके क्षेत्र में तेज़ डिलीवरी और स्थल पर समर्थन के साथ सेवा देते हैं।"
  />
</Layout>
