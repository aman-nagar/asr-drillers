---
import Layout from "../../layouts/Layout.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import ModelsTable from "../../components/ModelsTable.astro";
import LocalProblemsSolutions from "../../components/LocalProblemsSolutions.astro";
import TestimonialsGrid from "../../components/TestimonialsGrid.astro";
import FAQSection from "../../components/FAQSection.astro";
import CommonCTA from "../../components/CommonCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { commonData, locationsData } from "../../data/locations-i18n.js";

interface Props {
  location: string;
}

const { location } = Astro.params;
const locale = "hi";
const locationData = locationsData[location as keyof typeof locationsData];
const pageData = locationData?.[locale as "en" | "hi"];

if (!pageData) {
  throw new Error(`Location "${location}" not found in Hindi`);
}

export function getStaticPaths() {
  return Object.keys(locationsData).map((loc) => ({
    params: { location: loc },
  }));
}

const pageTitle = `${pageData.title} | ASR Drillers - बोरिंग मशीनें`;
const pageDescription = pageData.description;

const breadcrumbs = [
  { label: "हिंदी", href: `/hi/${location}` },
  { label: location.charAt(0).toUpperCase() + location.slice(1), href: `/${location}` },
];

// LocalBusiness Schema (Hindi)
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `https://asrdrillers.com/hi/${location}/#localbusiness`,
  name: `ASR Drillers - ${pageData.title}`,
  image: "https://asrdrillers.com/logo.png",
  description: pageData.description,
  url: `https://asrdrillers.com/hi/${location}`,
  address: {
    "@type": "PostalAddress",
    addressLocality: pageData.title,
    addressRegion: "Uttar Pradesh",
    addressCountry: "IN",
  },
  telephone: commonData.phone,
  areaServed: pageData.areaServed,
  priceRange: "₹450000-₹750000",
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
    opens: "08:00",
    closes: "20:00",
  },
};

// FAQPage Schema (Hindi)
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: commonData.commonFAQHi.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

// BreadcrumbList Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "होम",
      item: "https://asrdrillers.com",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: location.charAt(0).toUpperCase() + location.slice(1),
      item: `https://asrdrillers.com/${location}`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "हिंदी",
      item: `https://asrdrillers.com/hi/${location}`,
    },
  ],
};
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Breadcrumbs -->
  <Breadcrumbs breadcrumbs={breadcrumbs} />

  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-brand-teal to-brand-green text-white py-16 md:py-24">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
        {pageData.heroHeadline}
      </h1>
      <p class="text-lg md:text-xl mb-8 leading-relaxed opacity-95">
        {pageData.description}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={`https://wa.me/${commonData.whatsapp.replace(/[^0-9]/g, "")}?text=${encodeURIComponent(`नमस्ते! मुझे ${pageData.title} में बोरिंग मशीनों के बारे में जानना है। कृपया विवरण साझा करें।`)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-brand-green hover:bg-brand-green/90 text-white font-bold py-3 px-6 rounded text-center transition flex items-center justify-center gap-2"
        >
          💬 व्हाट्सऐप पर संपर्क करें
        </a>
        <a
          href={`tel:${commonData.phone}`}
          class="bg-white text-brand-teal hover:bg-gray-100 font-bold py-3 px-6 rounded text-center transition"
        >
          📞 कॉल करें
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Badges -->
  <TrustBadges />

  <!-- Local Problems & Solutions -->
  {
    pageData.localProblems && pageData.localSolutions && (
      <LocalProblemsSolutions
        problems={pageData.localProblems}
        solutions={pageData.localSolutions}
      />
    )
  }

  <!-- Featured Products -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center text-gray-900">
        हमारी सर्वश्रेष्ठ बोरिंग मशीनें
      </h2>
      <p class="text-center text-gray-600 mb-12 text-lg">
        भारतीय इलाके के लिए डिज़ाइन की गई पेशेवर-ग्रेड मशीनें
      </p>
      <ModelsTable models={commonData.models} />
    </div>
  </section>

  <!-- Local Testimonials -->
  {
    pageData.localTestimonials && pageData.localTestimonials.length > 0 && (
      <section class="py-16 bg-white">
        <div class="container mx-auto px-4 md:px-8 max-w-6xl">
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center text-gray-900">
            {pageData.title} में सफलता की कहानियाँ
          </h2>
          <p class="text-center text-gray-600 mb-12 text-lg">
            {pageData.title} के ठेकेदारों और किसानों से असली प्रतिक्रिया
          </p>
          <TestimonialsGrid testimonials={pageData.localTestimonials} />
        </div>
      </section>
    )
  }

  <!-- Shipping Info -->
  {
    pageData.shippingInfo && (
      <section class="py-16 bg-gray-50">
        <div class="container mx-auto px-4 md:px-8 max-w-6xl">
          <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center text-gray-900">
            {pageData.title} में डिलीवरी और समर्थन
          </h2>
          <div class="bg-white p-8 rounded-lg border-l-4 border-brand-teal max-w-2xl mx-auto shadow-sm">
            <p class="text-lg text-gray-700 leading-relaxed">
              {pageData.shippingInfo}
            </p>
          </div>
        </div>
      </section>
    )
  }

  <!-- FAQ Section with Schema -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-4xl">
      <FAQSection
        faqs={commonData.commonFAQHi}
        title="हमारी बोरिंग मशीनों के बारे में आम प्रश्न"
      />
    </div>
  </section>

  <!-- CTA Section -->
  <CommonCTA
    headline={`${pageData.title} में शुरुआत करने के लिए तैयार?`}
    subheadline="कानपुर के विश्वस्त निर्माता से कस्टम उद्धरण प्राप्त करें। हम आपके क्षेत्र में तेज़ डिलीवरी और स्थल पर समर्थन के साथ सेवा देते हैं।"
  />
</Layout>
