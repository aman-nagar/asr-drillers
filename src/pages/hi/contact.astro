---
import Layout from "../../layouts/Layout.astro";
import { commonData } from "../../data/locations-i18n.js";

const { phone, whatsapp } = commonData;

const pageTitle = "ASR Drillers से संपर्क करें - बोरिंग मशीन उद्धरण";
const pageDescription =
  "ASR Drillers से संपर्क करें बोरिंग मशीन उद्धरण, पूछताछ और समर्थन के लिए। कॉल, WhatsApp या संपर्क फॉर्म सबमिट करें।";
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Hero Section -->
  <section
    class="py-16 md:py-24 bg-gradient-to-r from-brand-teal to-brand-green text-white"
  >
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">हमसे संपर्क करें</h1>
        <p class="text-lg md:text-xl text-teal-100">
          हमारे बोरिंग मशीन विशेषज्ञों से संपर्क करें। हम 2 घंटे के भीतर जवाब
          देते हैं।
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Methods -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <!-- Phone -->
        <div
          class="text-center p-8 bg-slate-50 rounded-lg border-t-4 border-brand-teal"
        >
          <div class="text-5xl mb-4">📞</div>
          <h3 class="text-xl font-bold text-slate-900 mb-4">फोन</h3>
          <p class="text-slate-600 mb-4">तत्काल सहायता के लिए कॉल करें</p>
          <a
            href={`tel:${phone}`}
            class="text-brand-teal font-bold text-lg hover:text-brand-green transition-colors"
          >
            {phone}
          </a>
        </div>

        <!-- WhatsApp -->
        <div
          class="text-center p-8 bg-slate-50 rounded-lg border-t-4 border-brand-green"
        >
          <div class="text-5xl mb-4">💬</div>
          <h3 class="text-xl font-bold text-slate-900 mb-4">WhatsApp</h3>
          <p class="text-slate-600 mb-4">किसी भी समय संदेश दें (24/7)</p>
          <a
            href={`https://wa.me/${whatsapp}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand-green font-bold text-lg hover:text-brand-teal transition-colors"
          >
            {whatsapp}
          </a>
        </div>

        <!-- Email -->
        <div
          class="text-center p-8 bg-slate-50 rounded-lg border-t-4 border-brand-teal"
        >
          <div class="text-5xl mb-4">📧</div>
          <h3 class="text-xl font-bold text-slate-900 mb-4">ईमेल</h3>
          <p class="text-slate-600 mb-4">हमें अपनी पूछताछ भेजें</p>
          <a
            href="mailto:info@asrdrillers.com"
            class="text-brand-teal font-bold text-lg hover:text-brand-green transition-colors"
          >
            info@asrdrillers.com
          </a>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="max-w-2xl mx-auto bg-slate-50 p-8 rounded-lg">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-8">
          हमें एक संदेश भेजें
        </h2>
        <form class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-slate-900 mb-2"
                >आपका नाम *</label
              >
              <input
                type="text"
                required
                class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal focus:ring-opacity-20"
                placeholder="अपना नाम दर्ज करें"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-900 mb-2"
                >फोन नंबर *</label
              >
              <input
                type="tel"
                required
                class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal focus:ring-opacity-20"
                placeholder="आपका फोन नंबर"
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-900 mb-2"
              >ईमेल *</label
            >
            <input
              type="email"
              required
              class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal focus:ring-opacity-20"
              placeholder="आपका ईमेल पता"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-900 mb-2"
              >स्थान / जिला *</label
            >
            <select
              required
              class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal focus:ring-opacity-20"
            >
              <option value="">अपना स्थान चुनें</option>
              <option value="kanpur">कानपुर</option>
              <option value="lucknow">लखनऊ</option>
              <option value="bihar">बिहार</option>
              <option value="rajasthan">राजस्थान</option>
              <option value="delhi">दिल्ली</option>
              <option value="kolkata">कोलकाता</option>
              <option value="mp">मध्य प्रदेश</option>
              <option value="other">अन्य</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-900 mb-2"
              >मशीन का प्रकार (वैकल्पिक)</label
            >
            <select
              class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal focus:ring-opacity-20"
            >
              <option value="">मशीन प्रकार चुनें</option>
              <option value="22hp">22 HP सबमर्सिबल</option>
              <option value="30hp">30 HP हाइड्रोलिक</option>
              <option value="38hp">38 HP हेवी ड्यूटी</option>
              <option value="custom">कस्टम समाधान</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-900 mb-2"
              >आपका संदेश *</label
            >
            <textarea
              required
              rows="5"
              class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal focus:ring-opacity-20"
              placeholder="अपनी ड्रिलिंग आवश्यकताओं के बारे में बताएं..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-gradient-to-r from-brand-teal to-brand-green text-white py-3 rounded-lg font-bold hover:shadow-lg transition-shadow"
          >
            संदेश भेजें
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Office Locations -->
  <section class="py-16 md:py-24 bg-slate-50">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2
        class="text-3xl md:text-4xl font-bold text-slate-900 mb-12 text-center"
      >
        हमारा कार्यालय
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Address -->
        <div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4">ASR Drillers</h3>
          <div class="space-y-4 text-slate-600">
            <p>
              <strong>फैक्टरी पता:</strong><br />
              औद्योगिक क्षेत्र, कानपुर<br />
              उत्तर प्रदेश, भारत
            </p>
            <p>
              <strong>कार्यालय पता:</strong><br />
              कानपुर, उत्तर प्रदेश<br />
              भारत - 208001
            </p>
            <p>
              <strong>व्यावसायिक घंटे:</strong><br />
              सोमवार - शनिवार: 9:00 AM - 6:00 PM<br />
              रविवार: बंद<br />
              WhatsApp: 24/7 उपलब्ध
            </p>
          </div>
        </div>

        <!-- Map Placeholder -->
        <div class="bg-white rounded-lg overflow-hidden shadow-md h-80">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3560.5168749999996!2d75.85!3d26.15!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1sKanpur!2sIndia!5e0!3m2!1sen!2sin!4v1234567890"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-4xl">
      <h2
        class="text-3xl md:text-4xl font-bold text-slate-900 mb-12 text-center"
      >
        अक्सर पूछे जाने वाले प्रश्न
      </h2>
      <div class="space-y-6">
        <details class="bg-slate-50 p-6 rounded-lg group cursor-pointer">
          <summary
            class="font-bold text-lg text-slate-900 flex justify-between items-center"
          >
            उद्धरण प्राप्त करने में कितना समय लगता है?
            <span class="text-brand-teal">+</span>
          </summary>
          <p class="text-slate-600 mt-4">
            हम सभी पूछताछों का जवाब 2 घंटे के भीतर देते हैं। बस हमें कॉल करें या
            अपनी आवश्यकताओं के साथ WhatsApp संदेश भेजें।
          </p>
        </details>

        <details class="bg-slate-50 p-6 rounded-lg group cursor-pointer">
          <summary
            class="font-bold text-lg text-slate-900 flex justify-between items-center"
          >
            क्या आप मुफ्त इंस्टॉलेशन प्रदान करते हैं?
            <span class="text-brand-teal">+</span>
          </summary>
          <p class="text-slate-600 mt-4">
            हां! हम सभी बोरिंग मशीनों के साथ मुफ्त ऑन-साइट इंस्टॉलेशन और
            प्रशिक्षण प्रदान करते हैं। हमारे विशेषज्ञ तकनीशियन सब कुछ स्थापित
            करेंगे।
          </p>
        </details>

        <details class="bg-slate-50 p-6 rounded-lg group cursor-pointer">
          <summary
            class="font-bold text-lg text-slate-900 flex justify-between items-center"
          >
            आप कौन सी वारंटी प्रदान करते हैं?
            <span class="text-brand-teal">+</span>
          </summary>
          <p class="text-slate-600 mt-4">
            हमारी सभी मशीनें व्यापक वारंटी के साथ आती हैं। हम विस्तारित वारंटी
            विकल्प भी प्रदान करते हैं। विवरण के लिए हमसे संपर्क करें।
          </p>
        </details>

        <details class="bg-slate-50 p-6 rounded-lg group cursor-pointer">
          <summary
            class="font-bold text-lg text-slate-900 flex justify-between items-center"
          >
            क्या आप पूरे भारत में डिलीवरी करते हैं?
            <span class="text-brand-teal">+</span>
          </summary>
          <p class="text-slate-600 mt-4">
            हां, हम सुरक्षित परिवहन और संभालने के साथ पूरे भारत में डिलीवरी करते
            हैं। हमारे ग्राहक लगभग हर राज्य में हैं।
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section
    class="py-16 bg-gradient-to-r from-brand-teal to-brand-green text-white"
  >
    <div class="container mx-auto px-4 md:px-8 max-w-6xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        शुरू करने के लिए तैयार हैं?
      </h2>
      <p class="text-lg text-teal-100 mb-8">
        आज ही हमसे संपर्क करें और अपनी बोरिंग मशीन की आवश्यकताओं पर चर्चा करें।
      </p>
      <a
        href={`https://wa.me/${whatsapp}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-white text-brand-teal px-8 py-3 rounded-lg font-bold hover:bg-slate-100 transition-colors"
      >
        WhatsApp पर संदेश दें →
      </a>
    </div>
  </section>
</Layout>
