---
import HomePageTemplate from "../../components/templates/HomePageTemplate.astro";
import { commonData } from "../../data/locations-i18n.js";
import { getAbsoluteUrl, siteConfig } from "../../config/site";

const pageTitle =
  "भारत में सर्वश्रेष्ठ बोरिंग मशीन निर्माता | ASR ड्रिलर्स कानपुर";
const pageDescription =
  "ASR ड्रिलर्स कानपुर का विश्वस्त बोरिंग मशीन निर्माता है। यहां 22-38 HP सबमर्सिबल, हाइड्रोलिक और पोर्टेबल बोरिंग मशीनें, ऑन-साइट इंस्टॉलेशन और हिंदी-अंग्रेजी सहायता मिलती है।";

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "ASR ड्रिलर्स",
  image: getAbsoluteUrl(siteConfig.logoPath),
  description:
    "ट्यूबवेल और बोरवेल ड्रिलिंग के लिए उच्च गुणवत्ता की बोरिंग मशीनों का निर्माता",
  address: {
    "@type": "PostalAddress",
    streetAddress: "पुखरायन, कानपुर",
    addressLocality: "कानपुर",
    addressRegion: "UP",
    postalCode: "208201",
    addressCountry: "IN",
  },
  telephone: siteConfig.phone,
  priceRange: "₹450000-₹750000",
  areaServed: ["UP", "Bihar", "Rajasthan", "MP", "Delhi-NCR"],
  sameAs: ["https://www.facebook.com/asrdrillers"],
};

const content = {
  pageTitle,
  pageDescription,
  schema,
  hero: {
    eyebrow: "कानपुर से फैक्टरी-डायरेक्ट बोरिंग सिस्टम",
