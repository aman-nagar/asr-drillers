---
import Layout from "../../layouts/Layout.astro";
import { commonData } from "../../data/locations-i18n.js";

const { phone, whatsapp } = commonData;

const pageTitle = "गैलरी - ASR Drillers बोरिंग मशीनें";
const pageDescription =
  "ASR Drillers में हमारी बोरिंग मशीनों, फैक्टरी सेटअप, इंस्टॉलेशन और ड्रिलिंग उपकरणों का संग्रह देखें।";

// Sample gallery items - in production these would come from a CMS
const galleryItems = [
  {
    title: "22 HP सबमर्सिबल बोरिंग मशीन",
    category: "मशीनें",
    image: "🏗️",
  },
  {
    title: "30 HP हाइड्रोलिक बोरिंग मशीन",
    category: "मशीनें",
    image: "⚙️",
  },
  {
    title: "38 HP हेवी ड्यूटी बोरिंग मशीन",
    category: "मशीनें",
    image: "🔧",
  },
  {
    title: "फैक्टरी प्रोडक्शन लाइन",
    category: "फैक्टरी",
    image: "🏭",
  },
  {
    title: "गुणवत्ता नियंत्रण परीक्षण",
    category: "फैक्टरी",
    image: "✓",
  },
  {
    title: "ऑन-साइट इंस्टॉलेशन",
    category: "इंस्टॉलेशन",
    image: "📍",
  },
  {
    title: "कानपुर में ग्राहक इंस्टॉलेशन",
    category: "इंस्टॉलेशन",
    image: "🚚",
  },
  {
    title: "ड्रिलिंग प्रगति में",
    category: "इंस्टॉलेशन",
    image: "💧",
  },
];
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Hero Section -->
  <section
    class="py-16 md:py-24 bg-gradient-to-r from-brand-teal to-brand-green text-white"
  >
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">गैलरी</h1>
        <p class="text-lg md:text-xl text-teal-100">
          हमारी बोरिंग मशीनों, विनिर्माण सुविधाओं और सफल इंस्टॉलेशन की खोज करें
        </p>
      </div>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <!-- Filters (Optional) -->
      <div class="flex flex-wrap justify-center gap-4 mb-12">
        <button
          class="px-6 py-2 bg-brand-teal text-white rounded-lg font-medium hover:bg-brand-green transition-colors"
        >
          सभी
        </button>
        <button
          class="px-6 py-2 border-2 border-brand-teal text-brand-teal rounded-lg font-medium hover:bg-brand-teal hover:text-white transition-colors"
        >
          मशीनें
        </button>
        <button
          class="px-6 py-2 border-2 border-brand-teal text-brand-teal rounded-lg font-medium hover:bg-brand-teal hover:text-white transition-colors"
        >
          फैक्टरी
        </button>
        <button
          class="px-6 py-2 border-2 border-brand-teal text-brand-teal rounded-lg font-medium hover:bg-brand-teal hover:text-white transition-colors"
        >
          इंस्टॉलेशन
        </button>
      </div>

      <!-- Gallery Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          galleryItems.map((item) => (
            <div class="group relative overflow-hidden rounded-lg shadow-md hover:shadow-xl transition-shadow cursor-pointer bg-slate-50">
              <div class="relative h-64 bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center overflow-hidden">
                <div class="text-8xl group-hover:scale-110 transition-transform duration-300">
                  {item.image}
                </div>
              </div>
              <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-4">
                <h3 class="text-white font-bold text-lg mb-1">{item.title}</h3>
                <span class="inline-block bg-brand-teal text-white text-xs px-3 py-1 rounded-full w-fit">
                  {item.category}
                </span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Machine Models Section -->
  <section class="py-16 md:py-24 bg-slate-50">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2
        class="text-3xl md:text-4xl font-bold text-slate-900 mb-12 text-center"
      >
        हमारे मशीन मॉडल
      </h2>

      <div class="space-y-12">
        <!-- 22 HP Model -->
        <div
          class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center bg-white p-8 rounded-lg shadow-md"
        >
          <div
            class="bg-gradient-to-br from-slate-100 to-slate-200 h-64 rounded-lg flex items-center justify-center text-7xl"
          >
            🔧
          </div>
          <div>
            <h3 class="text-2xl font-bold text-slate-900 mb-4">
              22 HP सबमर्सिबल बोरिंग मशीन
            </h3>
            <p class="text-slate-600 mb-4">
              छोटे से मध्यम आकार के बोरिंग प्रोजेक्ट्स के लिए आदर्श। यह
              कॉम्पैक्ट और कुशल मशीन 300 फीट तक बोर की गहराई के लिए आदर्श है।
            </p>
            <ul class="space-y-2 text-slate-600 mb-6">
              <li>✓ शक्ति: 22 HP डीजल इंजन</li>
              <li>✓ अधिकतम गहराई: 300+ फीट</li>
              <li>✓ वजन: 2500 किग्रा</li>
              <li>✓ परिवहन और इंस्टॉलेशन में आसान</li>
            </ul>
            <a
              href={`https://wa.me/${whatsapp}?text=I%20am%20interested%20in%2022%20HP%20boring%20machine`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block bg-brand-teal text-white px-6 py-2 rounded-lg font-bold hover:bg-brand-green transition-colors"
            >
              उद्धरण प्राप्त करें
            </a>
          </div>
        </div>

        <!-- 30 HP Model -->
        <div
          class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center bg-white p-8 rounded-lg shadow-md"
        >
          <div
            class="order-2 md:order-1 bg-gradient-to-br from-slate-100 to-slate-200 h-64 rounded-lg flex items-center justify-center text-7xl"
          >
            ⚙️
          </div>
          <div class="order-1 md:order-2">
            <h3 class="text-2xl font-bold text-slate-900 mb-4">
              30 HP हाइड्रोलिक बोरिंग मशीन
            </h3>
            <p class="text-slate-600 mb-4">
              हमारा सबसे लोकप्रिय मॉडल! असाधारण प्रदर्शन के साथ भारी-शुल्क
              बोरिंग संचालन के लिए उच्च-शक्ति हाइड्रोलिक प्रणाली।
            </p>
            <ul class="space-y-2 text-slate-600 mb-6">
              <li>✓ शक्ति: 30 HP डीजल इंजन</li>
              <li>✓ अधिकतम गहराई: 500+ फीट</li>
              <li>✓ वजन: 3500 किग्रा</li>
              <li>✓ उन्नत हाइड्रोलिक प्रणाली</li>
            </ul>
            <a
              href={`https://wa.me/${whatsapp}?text=I%20am%20interested%20in%2030%20HP%20boring%20machine`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block bg-brand-teal text-white px-6 py-2 rounded-lg font-bold hover:bg-brand-green transition-colors"
            >
              उद्धरण प्राप्त करें
            </a>
          </div>
        </div>

        <!-- 38 HP Model -->
        <div
          class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center bg-white p-8 rounded-lg shadow-md"
        >
          <div
            class="bg-gradient-to-br from-slate-100 to-slate-200 h-64 rounded-lg flex items-center justify-center text-7xl"
          >
            🏗️
          </div>
          <div>
            <h3 class="text-2xl font-bold text-slate-900 mb-4">
              38 HP हेवी ड्यूटी बोरिंग मशीन
            </h3>
            <p class="text-slate-600 mb-4">
              सबसे मांग वाली बोरिंग प्रोजेक्ट्स के लिए अंतिम शक्ति और प्रदर्शन।
              अधिकतम गहराई और स्थायित्व के लिए इंजीनियर किया गया।
            </p>
            <ul class="space-y-2 text-slate-600 mb-6">
              <li>✓ शक्ति: 38 HP डीजल इंजन</li>
              <li>✓ अधिकतम गहराई: 800+ फीट</li>
              <li>✓ वजन: 4500 किग्रा</li>
              <li>✓ औद्योगिक-ग्रेड घटक</li>
            </ul>
            <a
              href={`https://wa.me/${whatsapp}?text=I%20am%20interested%20in%2038%20HP%20boring%20machine`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block bg-brand-teal text-white px-6 py-2 rounded-lg font-bold hover:bg-brand-green transition-colors"
            >
              उद्धरण प्राप्त करें
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Installation Success Stories -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2
        class="text-3xl md:text-4xl font-bold text-slate-900 mb-12 text-center"
      >
        इंस्टॉलेशन सफलता की कहानियां
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-slate-50 p-8 rounded-lg">
          <div class="text-5xl mb-4">🏢</div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">कानपुर ठेकेदार</h3>
          <p class="text-slate-600">
            "ASR Drillers ने उत्कृष्ट सेवा प्रदान की। 30 HP मशीन अविश्वसनीय रूप
            से विश्वसनीय है और हमारा समय और पैसा बचाती है।"
          </p>
          <p class="text-brand-teal font-bold mt-4">- राजेश कुमार</p>
        </div>

        <div class="bg-slate-50 p-8 rounded-lg">
          <div class="text-5xl mb-4">👨‍🌾</div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">खेत के मालिक</h3>
          <p class="text-slate-600">
            "शानदार गुणवत्ता और बेजोड़ समर्थन। उन्होंने मेरी जगह मशीन स्थापित की
            और मेरी टीम को व्यक्तिगत रूप से प्रशिक्षित किया।"
          </p>
          <p class="text-brand-teal font-bold mt-4">- विक्रम सिंह</p>
        </div>

        <div class="bg-slate-50 p-8 rounded-lg">
          <div class="text-5xl mb-4">🏭</div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">उद्योग भागीदार</h3>
          <p class="text-slate-600">
            "5 सालों से उनकी मशीनें इस्तेमाल कर रहे हैं। विश्वसनीयता और बिक्रय
            के बाद का समर्थन शानदार है।"
          </p>
          <p class="text-brand-teal font-bold mt-4">- अरुण मेहता</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section
    class="py-16 bg-gradient-to-r from-brand-teal to-brand-green text-white"
  >
    <div class="container mx-auto px-4 md:px-8 max-w-6xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        कस्टम मशीन की जरूरत है?
      </h2>
      <p class="text-lg text-teal-100 mb-8 max-w-2xl mx-auto">
        आपकी विशिष्ट आवश्यकताओं के लिए तैयार कस्टम बोरिंग मशीन समाधानों पर चर्चा
        करने के लिए हमसे संपर्क करें।
      </p>
      <a
        href="/hi/contact"
        class="inline-block bg-white text-brand-teal px-8 py-3 rounded-lg font-bold hover:bg-slate-100 transition-colors"
      >
        अभी पूछताछ करें
      </a>
    </div>
  </section>
</Layout>
