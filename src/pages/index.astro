---
import HomePageTemplate from "../components/templates/HomePageTemplate.astro";
import { getAbsoluteUrl, siteConfig } from "../config/site";

const pageTitle =
  "Best Boring Machine Manufacturer in India | ASR Drillers Kanpur";
const pageDescription =
  "ASR Drillers is a trusted boring machine manufacturer in Kanpur offering 22-38 HP submersible, hydraulic, and portable boring machines with on-site installation and bilingual support.";

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "ASR Drillers",
  image: getAbsoluteUrl(siteConfig.logoPath),
  description:
    "Manufacturer of high-quality boring machines for tubewell and borewell drilling",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Pukhrayan, Kanpur",
    addressLocality: "Kanpur",
    addressRegion: "UP",
    postalCode: "208201",
    addressCountry: "IN",
  },
  telephone: siteConfig.phone,
  priceRange: "₹450000-₹750000",
  areaServed: ["UP", "Bihar", "Rajasthan", "MP", "Delhi-NCR"],
  sameAs: ["https://www.facebook.com/asrdrillers"],
};

const content = {
  pageTitle,
  pageDescription,
  schema,
  hero: {
    eyebrow: "Factory-direct boring systems from Kanpur",
    title:
      "Boring Machines Built for Hard Ground, Tight Timelines, and Real Field Work",
    description:
      "ASR Drillers manufactures durable boring machines for contractors and farm owners who need consistent depth, dependable support, and fast spare access across UP, Bihar, Rajasthan, MP, and Delhi-NCR.",
    signals: [
      { value: "14+", label: "Years in Manufacturing" },
      { value: "22-38 HP", label: "Machine Lineup" },
      { value: "100-500+ ft", label: "Depth Range" },
    ],
    visualTitle: "Field-ready machine lineup",
    visualLines: [
      "Photo slots can be updated later without changing the page structure.",
      "22 HP for lighter operations, 30 HP for contractor work, 38 HP for deeper and tougher boring.",
      "Factory guidance, on-site installation, and Hindi/English support in one sales flow.",
    ],
    primaryActionLabel: "WhatsApp Now",
    secondaryActionLabel: "Call the Team",
    whatsappMessage: "Hi! I want help choosing the right boring machine.",
  },
  stripItems: [
    {
      value: "Kanpur",
      label: "Factory Base",
      note: "Direct dispatch and local support",
    },
    {
      value: "24/7",
      label: "Response Window",
      note: "WhatsApp-first service team",
    },
    {
      value: "500+",
      label: "Customer Trust",
      note: "Farmers and contractors across North India",
    },
    {
      value: "1-2 Years",
      label: "Warranty",
      note: "Manufacturing-defect cover and support",
    },
  ],
  problems: {
    title: "What Usually Breaks a Drilling Business",
    subtitle:
      "The machines are expensive, the ground conditions are harsh, and weak support turns every job into a risk.",
    cards: [
      {
        title: "Breakdowns mid-project",
        body: "Cheap or unsupported rigs fail under hard-rock pressure, and every lost day destroys drilling margins.",
      },
      {
        title: "Shallow output in difficult soil",
        body: "Underpowered engines struggle in clay-heavy and rocky zones, so contractors lose depth-driven jobs.",
      },
      {
        title: "After-sales support that disappears",
        body: "Many sellers ship the machine and vanish. Repairs, spares, and guidance become your problem.",
      },
    ],
  },
  advantages: {
    title: "Why Contractors Buy from ASR Drillers",
    subtitle:
      "The differentiator is not just horsepower. It is how fast the machine reaches the site, how well it handles the soil, and how confidently your team can keep it running.",
    cards: [
      {
        title: "Built in Kanpur for field conditions",
        body: "Machines are configured around the kind of clay, rock, and mixed soil boring teams actually face across UP and nearby states.",
      },
      {
        title: "Three machine bands, clear buying path",
        body: "22 HP for leaner field work, 30 HP for contractor depth jobs, and 38 HP for maximum output and harder formations.",
      },
      {
        title: "Support that feels local",
        body: "On-site installation, operator onboarding, and quick spare access make the machine easier to own, not just easier to buy.",
      },
    ],
  },
  decisionPanel: {
    eyebrow: "Quick decision panel",
    title: "What the lineup covers",
    stats: [
      { label: "Depth Band", value: "100-500+ feet" },
      { label: "Price Range", value: "₹4.8-7.2 lakh" },
      { label: "Support Model", value: "Factory direct" },
    ],
    ctaLabel: "Ask which model fits your work",
    whatsappMessage: "Hi! I want help choosing the right model for my boring work.",
  },
  models: {
    title: "Compare Our Boring Machine Models",
    subtitle:
      "Use the lineup below to compare depth, diameter, fuel use, and price before you speak with the team.",
  },
  testimonials: {
    title: "Results from Real Field Operators",
    subtitle:
      "These testimonials highlight what buyers usually care about most: drilling depth, fuel efficiency, spare availability, and response speed.",
    items: [
      {
        name: "Mr. Ram Singh",
        location: "Lucknow, UP",
        role: "Boring Contractor",
        text: "I've been drilling for 20 years. ASR's 30 HP machine drilled 450 feet in hard rock in just 2 days. Previous machines took 5-6 days. Fuel efficiency is 30% better. Spare parts are always available locally.",
        rating: 5,
        project: "Deep well drilling - Lucknow",
      },
      {
        name: "Farmer Rajesh Kumar",
        location: "Kanpur District",
        role: "Farm Owner",
        text: "My farm has clay and hard rock. Hired ASR's 22 HP for a 250-foot well. Perfect. They installed it personally, trained my operator, and checked back. This is real local support, not just a sale.",
        rating: 5,
        project: "Farm irrigation well - Kanpur",
      },
      {
        name: "Contractor Akshay Verma",
        location: "Rajasthan",
        role: "Boring Business Owner",
        text: "Running 3 ASR machines in Rajasthan for 2+ years. Reliability is 99%. When I had a question at 10 PM, their team answered on WhatsApp. That's why I trust them with my business.",
        rating: 5,
        project: "Multiple commercial projects",
      },
    ],
  },
  faq: {
    title: "Common Questions Before You Buy",
    items: [
      {
        question: "What is the maximum depth of ASR boring machines?",
        answer:
          "Our 38 HP model can drill 300-500+ feet depending on soil type. 30 HP handles 250-400 feet. 22 HP works well for 150-300 feet. Hard rock needs more power; sandy soil allows greater depths.",
      },
      {
        question:
          "Do you provide installation in other states like Bihar or Rajasthan?",
        answer:
          "Yes. We provide on-site installation and training across North India (UP, Bihar, Rajasthan, MP, Delhi-NCR). Travel and labor costs apply based on distance. Contact us for an exact quote.",
      },
      {
        question: "How much fuel does your boring machine use per day?",
        answer:
          "22 HP uses about 8-10 liters/day in continuous operation. 30 HP uses about 12-14 liters. 38 HP uses about 16-20 liters. Actual consumption depends on soil hardness and drilling depth.",
      },
      {
        question: "What warranty do you offer?",
        answer:
          "We offer 1-2 years from purchase covering manufacturing defects, plus free annual service camps across North India. Extended warranty is available on request.",
      },
      {
        question: "Can your machine drill through rock and hard soil?",
        answer:
          "Yes. Our machines are designed for hard rock and clay-rich UP and Bihar soils. The 30 HP and 38 HP models are the best fit for challenging terrain.",
      },
      {
        question: "Do you provide financing or EMI options?",
        answer:
          "We work with partner banks and NBFCs to offer EMI plans, usually with 24-36 month tenures for contractors. Contact our sales team for current availability.",
      },
    ],
  },
  cta: {
    headline: "Need a machine recommendation, price band, or delivery estimate?",
    subheadline:
      "Send your soil type, expected bore depth, and location on WhatsApp. We can guide you to the right machine without making the page harder to browse.",
  },
};
---

<HomePageTemplate content={content} />
