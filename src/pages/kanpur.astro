---
import Layout from "../layouts/Layout.astro";

const pageTitle = "Boring Machine Manufacturer in Kanpur, UP | ASR Drillers";
const pageDescription =
  "ASR Drillers - Kanpur-based tubewell boring machine manufacturer. Local factory at Pukhrayan. 22-38 HP models. Same-day installation. 24/7 WhatsApp support. ₹4.5-7.5 lakhs.";
const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "ASR Drillers - Kanpur",
  description:
    "Manufacturer of high-quality boring machines for tubewell and borewell drilling in Kanpur",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Pukhrayan Industrial Area",
    addressLocality: "Kanpur",
    addressRegion: "Uttar Pradesh",
    postalCode: "208201",
    addressCountry: "IN",
  },
  telephone: "+91-9876543210",
  url: "https://asrdrillers.com/kanpur",
  sameAs: ["https://www.facebook.com/asrdrillers"],
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Breadcrumb -->
  <nav class="bg-gray-100 py-3 px-4">
    <div class="container mx-auto max-w-6xl text-sm text-gray-600">
      <a href="/" class="text-blue-600 hover:underline">Home</a> /
      <span>Kanpur</span>
    </div>
  </nav>

  <!-- Hero Section -->
  <section
    class="bg-gradient-to-r from-orange-600 to-orange-500 text-white py-16"
  >
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        Boring Machine Manufacturer in Kanpur, Uttar Pradesh
      </h1>
      <p class="text-xl mb-8 opacity-95">
        ASR Drillers – Kanpur's trusted factory-based manufacturer since 2012.
        Visit us in Pukhrayan. Same-day delivery & installation. ₹4.8–7.2 lakhs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="https://wa.me/919876543210"
          class="bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-6 rounded"
        >
          🏭 Visit Factory
        </a>
        <a
          href="#quote"
          class="bg-white text-orange-600 hover:bg-gray-100 font-bold py-3 px-6 rounded"
        >
          Get Quote
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Kanpur-Based -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2
        class="text-3xl md:text-4xl font-bold mb-12 text-center text-gray-900"
      >
        Why Buy from Kanpur's Local Manufacturer?
      </h2>

      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h3 class="text-2xl font-bold mb-6 text-orange-600">
            The Kanpur Advantage
          </h3>
          <ul class="space-y-4">
            <li class="flex gap-3">
              <span class="text-green-600 font-bold text-2xl">✓</span>
              <div>
                <strong>Factory-Direct Pricing:</strong> No middlemen. Save 15–20%
                vs. dealers. Order today, install tomorrow.
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-green-600 font-bold text-2xl">✓</span>
              <div>
                <strong>Pukhrayan Industrial Hub Heritage:</strong> 40+ years of boring
                machine expertise in this region. We know UP soil inside-out.
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-green-600 font-bold text-2xl">✓</span>
              <div>
                <strong>Same-Day Installation Team:</strong> Our engineers live in
                Kanpur. No 2-day wait. Machine at your site by morning.
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-green-600 font-bold text-2xl">✓</span>
              <div>
                <strong>1-Hour Spare Parts Response:</strong> Hydraulic hose burst?
                Piston damaged? Our warehouse in Kanpur delivers in 1–2 hours.
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-green-600 font-bold text-2xl">✓</span>
              <div>
                <strong>Visit Our Factory:</strong> See machines being built, tested,
                assembled. Talk to engineers in person. Build trust before buying.
              </div>
            </li>
          </ul>
        </div>

        <div class="bg-orange-50 p-8 rounded-lg">
          <h3 class="text-2xl font-bold mb-6 text-gray-900">Factory Details</h3>
          <div class="space-y-6">
            <div class="border-l-4 border-orange-600 pl-4">
              <p class="text-sm text-gray-600 uppercase font-semibold">
                Location
              </p>
              <p class="text-lg font-bold text-gray-900">Pukhrayan, Kanpur</p>
              <p class="text-sm text-gray-700 mt-1">
                30 km from Kanpur city center, accessible via NH-2
              </p>
            </div>
            <div class="border-l-4 border-orange-600 pl-4">
              <p class="text-sm text-gray-600 uppercase font-semibold">Hours</p>
              <p class="text-lg font-bold text-gray-900">8 AM – 8 PM Daily</p>
              <p class="text-sm text-gray-700 mt-1">
                Weekend visits welcome. Call ahead for weekend tours.
              </p>
            </div>
            <div class="border-l-4 border-orange-600 pl-4">
              <p class="text-sm text-gray-600 uppercase font-semibold">
                Equipment
              </p>
              <p class="text-lg font-bold text-gray-900">10+ Machines Live</p>
              <p class="text-sm text-gray-700 mt-1">
                See the 22 HP, 30 HP, 38 HP in action. Test drilling.
              </p>
            </div>
            <div class="border-l-4 border-orange-600 pl-4">
              <p class="text-sm text-gray-600 uppercase font-semibold">
                Service
              </p>
              <p class="text-lg font-bold text-gray-900">In-House Repairs</p>
              <p class="text-sm text-gray-700 mt-1">
                Any machine – ASR or competitor – we service.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Success Stories - Kanpur Focus -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2
        class="text-3xl md:text-4xl font-bold mb-12 text-center text-gray-900"
      >
        Success Stories from Kanpur & District
      </h2>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Case Study 1 -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div
            class="bg-gradient-to-r from-blue-600 to-blue-500 h-48 flex items-center justify-center"
          >
            <span class="text-white text-center">
              <p class="text-2xl font-bold">500 FT</p>
              <p class="text-sm">Drilling Record</p>
            </span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2 text-gray-900">
              Deep Well Success
            </h3>
            <p class="text-sm text-gray-600 mb-4">
              Mr. Rajesh Sharma, Kanpur District
            </p>
            <p class="text-gray-700 mb-4">
              "Needed 500 feet for irrigation. ASR's 38 HP drilled through hard
              rock in 4 days. On-site team trained my operator. They still
              support us 18 months later."
            </p>
            <p class="text-yellow-500 font-semibold">★★★★★</p>
          </div>
        </div>

        <!-- Case Study 2 -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div
            class="bg-gradient-to-r from-purple-600 to-purple-500 h-48 flex items-center justify-center"
          >
            <span class="text-white text-center">
              <p class="text-2xl font-bold">15 WELLS</p>
              <p class="text-sm">Annual Output</p>
            </span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2 text-gray-900">
              Contractor Growth Story
            </h3>
            <p class="text-sm text-gray-600 mb-4">
              Contractor Amit Singh, Jajmau, Kanpur
            </p>
            <p class="text-gray-700 mb-4">
              "Started with ASR's 22 HP. So reliable, I bought a 30 HP next
              year. Now drilling 12–15 wells/year. Downtime is almost zero.
              Spares from factory same-day."
            </p>
            <p class="text-yellow-500 font-semibold">★★★★★</p>
          </div>
        </div>

        <!-- Case Study 3 -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div
            class="bg-gradient-to-r from-green-600 to-green-500 h-48 flex items-center justify-center"
          >
            <span class="text-white text-center">
              <p class="text-2xl font-bold">30%</p>
              <p class="text-sm">Better Margins</p>
            </span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2 text-gray-900">
              Efficiency Gains
            </h3>
            <p class="text-sm text-gray-600 mb-4">
              Farmer Mohan Lal, Kalyanpur, Kanpur
            </p>
            <p class="text-gray-700 mb-4">
              "Fuel cost cut by ₹200/day. ASR's 22 HP drills faster than my old
              machine. Per-well profit up 25%. No regrets switching to Kanpur's
              own."
            </p>
            <p class="text-yellow-500 font-semibold">★★★★★</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Models Available in Kanpur -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center text-gray-900">
        All Models Available for Immediate Pickup
      </h2>
      <p class="text-center text-gray-600 mb-12 text-lg max-w-3xl mx-auto">
        Stock varies. Call to confirm availability. On-site installation within
        24 hours.
      </p>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="border-2 border-blue-600 rounded-lg p-6">
          <h3 class="text-2xl font-bold text-blue-900 mb-4">
            22 HP Submersible
          </h3>
          <ul class="space-y-3 text-gray-700 mb-6">
            <li>✓ Depth: 150–300 feet</li>
            <li>✓ Diameter: 4–6 inch</li>
            <li>✓ Cast iron build</li>
            <li>✓ Kirloskar engine</li>
            <li>✓ Fuel: ~9 L/day</li>
          </ul>
          <p class="text-3xl font-bold text-blue-600 mb-4">₹4.8 Lakh</p>
          <a
            href="https://wa.me/919876543210?text=Interested%20in%2022%20HP%20Submersible%20boring%20machine"
            class="block text-center bg-blue-600 text-white font-bold py-2 rounded hover:bg-blue-700"
          >
            WhatsApp Inquiry
          </a>
        </div>

        <div class="border-2 border-purple-600 rounded-lg p-6">
          <h3 class="text-2xl font-bold text-purple-900 mb-4">
            30 HP Hydraulic
          </h3>
          <ul class="space-y-3 text-gray-700 mb-6">
            <li>✓ Depth: 250–400 feet</li>
            <li>✓ Diameter: 6–10 inch</li>
            <li>✓ Variable RPM</li>
            <li>✓ Hard rock specialist</li>
            <li>✓ Fuel: ~13 L/day</li>
          </ul>
          <p class="text-3xl font-bold text-purple-600 mb-4">₹5.8 Lakh</p>
          <a
            href="https://wa.me/919876543210?text=Interested%20in%2030%20HP%20Hydraulic%20boring%20machine"
            class="block text-center bg-purple-600 text-white font-bold py-2 rounded hover:bg-purple-700"
          >
            WhatsApp Inquiry
          </a>
        </div>

        <div class="border-2 border-orange-600 rounded-lg p-6">
          <h3 class="text-2xl font-bold text-orange-900 mb-4">
            38 HP Tractor-Mount
          </h3>
          <ul class="space-y-3 text-gray-700 mb-6">
            <li>✓ Depth: 300–500+ feet</li>
            <li>✓ Diameter: 8–12 inch</li>
            <li>✓ Field Marshal engine</li>
            <li>✓ Maximum power</li>
            <li>✓ Fuel: ~18 L/day</li>
          </ul>
          <p class="text-3xl font-bold text-orange-600 mb-4">₹7.2 Lakh</p>
          <a
            href="https://wa.me/919876543210?text=Interested%20in%2038%20HP%20Tractor-Mount%20boring%20machine"
            class="block text-center bg-orange-600 text-white font-bold py-2 rounded hover:bg-orange-700"
          >
            WhatsApp Inquiry
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Kanpur-Specific FAQ -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2
        class="text-3xl md:text-4xl font-bold mb-12 text-center text-gray-900"
      >
        Questions About Buying from Kanpur?
      </h2>

      <div class="space-y-6 max-w-3xl mx-auto">
        <details class="bg-white p-6 rounded-lg cursor-pointer group">
          <summary
            class="font-bold text-lg text-gray-900 flex items-center gap-3"
          >
            <span class="group-open:rotate-180 transition text-orange-600"
              >▼</span
            >
            Can I visit the factory before buying?
          </summary>
          <p class="mt-4 text-gray-700 ml-6">
            Absolutely. We encourage factory visits. See machines being
            assembled, tested, and drilling. Talk to our engineers directly.
            Weekday visits: 8 AM–8 PM. Weekend by appointment. Address:
            Pukhrayan Industrial Area, Kanpur. Call +91-9876543210 to schedule.
          </p>
        </details>

        <details class="bg-white p-6 rounded-lg cursor-pointer group">
          <summary
            class="font-bold text-lg text-gray-900 flex items-center gap-3"
          >
            <span class="group-open:rotate-180 transition text-orange-600"
              >▼</span
            >
            Do you deliver outside Kanpur (Lucknow, Jhansi, etc.)?
          </summary>
          <p class="mt-4 text-gray-700 ml-6">
            Yes. We deliver across North India. Kanpur delivery: Free. Up to 100
            km (e.g., Lucknow, Allahabad): ₹3,000–5,000. Farther: ₹8,000+.
            Installation team charges ₹2,000–3,000 per day on-site. Total
            delivery time: 2–5 days.
          </p>
        </details>

        <details class="bg-white p-6 rounded-lg cursor-pointer group">
          <summary
            class="font-bold text-lg text-gray-900 flex items-center gap-3"
          >
            <span class="group-open:rotate-180 transition text-orange-600"
              >▼</span
            >
            What about after-sales service in Kanpur?
          </summary>
          <p class="mt-4 text-gray-700 ml-6">
            We're based in Kanpur. Service center in Pukhrayan is open 6
            days/week. Free annual maintenance camps. Emergency repairs:
            WhatsApp call, engineer on-site in 2–4 hours. Spare parts always in
            stock.
          </p>
        </details>

        <details class="bg-white p-6 rounded-lg cursor-pointer group">
          <summary
            class="font-bold text-lg text-gray-900 flex items-center gap-3"
          >
            <span class="group-open:rotate-180 transition text-orange-600"
              >▼</span
            >
            Can I pay in installments from Kanpur?
          </summary>
          <p class="mt-4 text-gray-700 ml-6">
            Yes. Partner with 3–4 banks offering 24–36 month EMI at 9–12%
            interest. HDFC, ICICI, Axis Bank supported. Approval in 3–5 days. We
            handle paperwork.
          </p>
        </details>

        <details class="bg-white p-6 rounded-lg cursor-pointer group">
          <summary
            class="font-bold text-lg text-gray-900 flex items-center gap-3"
          >
            <span class="group-open:rotate-180 transition text-orange-600"
              >▼</span
            >
            How long does delivery take from Kanpur factory?
          </summary>
          <p class="mt-4 text-gray-700 ml-6">
            Stock availability permitting: Same-day pickup. Next-day delivery
            within 50 km. 3–5 days for 100+ km. Custom configurations: 7–10
            days. Call to confirm current stock before ordering.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- Contact / CTA -->
  <section class="py-16 bg-gradient-to-r from-orange-600 to-red-600 text-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">
            Visit ASR Drillers in Kanpur Today
          </h2>
          <p class="text-lg mb-6 opacity-95">
            See our factory. Meet our engineers. Test-run a machine. No pressure
            to buy — just honest conversation about your boring needs.
          </p>
          <div class="bg-white bg-opacity-20 p-6 rounded-lg mb-6">
            <p class="font-bold text-lg mb-2">📍 Factory Address</p>
            <p class="mb-4">Pukhrayan Industrial Area, Kanpur, UP 208201</p>
            <p class="font-bold text-lg mb-2">⏰ Hours</p>
            <p class="mb-4">Mon–Sat: 8 AM–8 PM | Sun: By Appointment</p>
            <p class="font-bold text-lg mb-2">📱 Direct Contact</p>
            <p>+91-98765-43210</p>
          </div>
        </div>
        <div>
          <div class="bg-white bg-opacity-10 backdrop-blur-sm p-8 rounded-lg">
            <h3 class="text-2xl font-bold mb-6">Quick Inquiry Form</h3>
            <form class="space-y-4">
              <input
                type="text"
                placeholder="Your Name"
                class="w-full p-3 rounded text-gray-900"
              />
              <input
                type="tel"
                placeholder="WhatsApp Number"
                class="w-full p-3 rounded text-gray-900"
              />
              <select class="w-full p-3 rounded text-gray-900">
                <option>Select Model</option>
                <option>22 HP Submersible</option>
                <option>30 HP Hydraulic</option>
                <option>38 HP Tractor-Mount</option>
                <option>Not sure yet</option>
              </select>
              <textarea
                placeholder="Questions/Requirements"
                rows="4"
                class="w-full p-3 rounded text-gray-900"></textarea>
              <button
                type="submit"
                class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-3 rounded"
              >
                Get Quote
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust & Credentials -->
  <section class="py-12 bg-gray-900 text-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <div class="grid md:grid-cols-4 gap-8 text-center mb-8">
        <div>
          <p class="text-3xl font-bold text-yellow-400">12+</p>
          <p class="text-gray-400">Years in Kanpur</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-yellow-400">300+</p>
          <p class="text-gray-400">Local Clients</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-yellow-400">1000+</p>
          <p class="text-gray-400">Wells Drilled</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-yellow-400">99%</p>
          <p class="text-gray-400">Uptime</p>
