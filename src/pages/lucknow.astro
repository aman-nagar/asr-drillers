---
import Layout from "../layouts/Layout.astro";

const pageTitle =
  "Best Tubewell Boring Machine in Lucknow, Uttar Pradesh | ASR Drillers";
const pageDescription =
  "ASR Drillers supplies premium boring machines to Lucknow & UP. 22-38 HP diesel models. Free installation. 24/7 WhatsApp support from Kanpur factory. ₹4.5-7.5 lakhs.";
const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "ASR Drillers - Lucknow Service",
  description: "Tubewell boring machine supplier for Lucknow and Uttar Pradesh",
  areaServed: "Lucknow, Kanpur, Uttar Pradesh",
  telephone: "+91-9876543210",
  url: "https://asrdrillers.com/lucknow",
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Breadcrumb -->
  <nav class="bg-gray-100 py-3 px-4">
    <div class="container mx-auto max-w-6xl text-sm text-gray-600">
      <a href="/" class="text-blue-600 hover:underline">Home</a> /
      <span>Lucknow</span>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-green-600 to-teal-600 text-white py-16">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        Best Boring Machine Supplier in Lucknow
      </h1>
      <p class="text-xl mb-8 opacity-95">
        ASR Drillers delivers premium tubewell boring machines to Lucknow
        contractors and farmers. Same-day installation. 24/7 WhatsApp support.
        ₹4.8–7.2 lakhs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="https://wa.me/919876543210"
          class="bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-6 rounded"
        >
          🚚 Order for Lucknow
        </a>
        <a
          href="#quote"
