---
import Layout from "../layouts/Layout.astro";
import { commonData } from "../data/locations-i18n.js";

const { phone, whatsapp } = commonData;
const isHindi = Astro.url?.pathname?.startsWith("/hi/") || false;

const pageTitle = isHindi
  ? "ASR Drillers से संपर्क करें - बोरिंग मशीन कोट"
  : "Contact ASR Drillers - Get Your Boring Machine Quote";
const pageDescription = isHindi
  ? "ASR Drillers से संपर्क करें - बोरिंग मशीन उद्धरण, पूछताछ और समर्थन के लिए। कॉल करें, WhatsApp करें, या संपर्क फॉर्म भरें।"
  : "Contact ASR Drillers for boring machine quotes, inquiries, and support. Call, WhatsApp, or submit a contact form.";
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Hero Section -->
  <section class="py-16 md:py-24 bg-gradient-to-r from-brand-teal to-brand-green text-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">
          {isHindi ? "संपर्क करें" : "Contact Us"}
        </h1>
        <p class="text-lg md:text-xl text-teal-100">
          {isHindi
            ? "हमारे बोरिंग मशीन विशेषज्ञों से संपर्क करें। हम 2 घंटे में जवाब देते हैं।"
            : "Get in touch with our boring machine experts. We respond within 2 hours."}
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Methods -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <!-- Phone -->
        <a
          href={`tel:${phone}`}
          class="text-center p-8 bg-slate-50 rounded-lg border-t-4 border-brand-teal hover:shadow-lg transition-shadow cursor-pointer"
        >
          <div class="text-5xl mb-4">📞</div>
          <h3 class="text-xl font-bold text-slate-900 mb-4">
            {isHindi ? "फोन" : "Phone"}
          </h3>
          <p class="text-slate-600 mb-4">
            {isHindi ? "तुरंत सहायता के लिए कॉल करें" : "Call for immediate assistance"}
          </p>
          <span class="text-brand-teal font-bold text-lg">{phone}</span>
        </a>

        <!-- WhatsApp -->
        <a
          href={`https://wa.me/${whatsapp.replace(/[^0-9]/g, "")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-center p-8 bg-slate-50 rounded-lg border-t-4 border-green-500 hover:shadow-lg transition-shadow cursor-pointer"
        >
          <div class="text-5xl mb-4">💬</div>
          <h3 class="text-xl font-bold text-slate-900 mb-4">WhatsApp</h3>
          <p class="text-slate-600 mb-4">
            {isHindi ? "24/7 संदेश भेजें" : "Message anytime (24/7)"}
          </p>
          <span class="text-green-600 font-bold text-lg">{whatsapp}</span>
        </a>

        <!-- Email -->
        <a
          href="mailto:info@asrdrillers.com"
          class="text-center p-8 bg-slate-50 rounded-lg border-t-4 border-brand-teal hover:shadow-lg transition-shadow cursor-pointer"
        >
          <div class="text-5xl mb-4">📧</div>
          <h3 class="text-xl font-bold text-slate-900 mb-4">Email</h3>
          <p class="text-slate-600 mb-4">
            {isHindi ? "अपनी पूछताछ भेजें" : "Send us your inquiry"}
          </p>
          <span class="text-brand-teal font-bold text-lg">info@asrdrillers.com</span>
        </a>
      </div>

      <!-- Contact Form -->
      <div class="max-w-2xl mx-auto bg-slate-50 p-8 rounded-lg" id="contact-form-section">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-8">
          {isHindi ? "हमें संदेश भेजें" : "Send us a Message"}
        </h2>
        <form id="contact-form" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-slate-900 mb-2">
                {isHindi ? "आपका नाम *" : "Your Name *"}
              </label>
              <input
                type="text"
                id="form-name"
                required
                class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal focus:ring-opacity-20"
                placeholder={isHindi ? "अपना नाम दर्ज करें" : "Enter your name"}
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-900 mb-2">
                {isHindi ? "फोन नंबर *" : "Phone Number *"}
              </label>
              <input
                type="tel"
                id="form-phone"
                required
                class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal focus:ring-opacity-20"
                placeholder={isHindi ? "आपका फोन नंबर" : "Your phone number"}
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-900 mb-2">
              Email *
            </label>
            <input
              type="email"
              id="form-email"
              required
              class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal focus:ring-opacity-20"
              placeholder={isHindi ? "आपका ईमेल पता" : "Your email address"}
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-900 mb-2">
              {isHindi ? "स्थान / जिला *" : "Location / District *"}
            </label>
            <select
              id="form-location"
              required
              class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal focus:ring-opacity-20"
            >
              <option value="">
                {isHindi ? "अपना स्थान चुनें" : "Select your location"}
              </option>
              <option value="Kanpur">Kanpur</option>
              <option value="Lucknow">Lucknow</option>
              <option value="Bihar">Bihar</option>
              <option value="Rajasthan">Rajasthan</option>
              <option value="Delhi">Delhi</option>
              <option value="Kolkata">Kolkata</option>
              <option value="Madhya Pradesh">Madhya Pradesh</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-900 mb-2">
              {isHindi ? "मशीन का प्रकार (वैकल्पिक)" : "Machine Type (Optional)"}
            </label>
            <select
              id="form-machine"
              class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal focus:ring-opacity-20"
            >
              <option value="">
                {isHindi ? "मशीन का प्रकार चुनें" : "Select machine type"}
              </option>
              <option value="22 HP Submersible">
                22 HP Submersible (₹4.8 Lakh)
              </option>
              <option value="30 HP Hydraulic">
                30 HP Hydraulic (₹5.8 Lakh)
              </option>
              <option value="38 HP Heavy Duty">
                38 HP Heavy Duty (₹7.2 Lakh)
              </option>
              <option value="Custom Solution">
                {isHindi ? "कस्टम समाधान" : "Custom Solution"}
              </option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-900 mb-2">
              {isHindi ? "आपका संदेश *" : "Your Message *"}
            </label>
            <textarea
              id="form-message"
              required
              rows="5"
              class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal focus:ring-opacity-20"
              placeholder={isHindi
                ? "अपनी बोरिंग आवश्यकताओं के बारे में बताएं..."
                : "Tell us about your boring requirements..."}
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-gradient-to-r from-brand-teal to-brand-green text-white py-3 rounded-lg font-bold hover:shadow-lg transition-shadow flex items-center justify-center gap-2"
          >
            <span>💬</span>
            <span>{isHindi ? "WhatsApp पर भेजें" : "Send via WhatsApp"}</span>
          </button>

          <p class="text-center text-sm text-slate-500">
            {isHindi
              ? "या ईमेल करें: info@asrdrillers.com"
              : "Or email us: info@asrdrillers.com"}
          </p>
        </form>
      </div>
    </div>
  </section>

  <!-- Office Locations -->
  <section class="py-16 md:py-24 bg-slate-50">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-12 text-center">
        {isHindi ? "हमारा कार्यालय" : "Our Office"}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Address -->
        <div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4">ASR Drillers</h3>
          <div class="space-y-4 text-slate-600">
            <p>
              <strong>{isHindi ? "कारखाना पता:" : "Factory Address:"}</strong><br />
              Pukhrayan Industrial Area<br />
              Kanpur, Uttar Pradesh 208201<br />
              India
            </p>
            <p>
              <strong>{isHindi ? "GST नंबर:" : "GST Number:"}</strong><br />
              09ABCDE1234F2Z5
            </p>
            <p>
              <strong>{isHindi ? "व्यवसायिक घंटे:" : "Business Hours:"}</strong><br />
              {isHindi ? "सोमवार - शनिवार: सुबह 9:00 - शाम 6:00" : "Monday - Saturday: 9:00 AM - 6:00 PM"}<br />
              {isHindi ? "रविवार: बंद" : "Sunday: Closed"}<br />
              WhatsApp: 24/7
            </p>
          </div>
        </div>

        <!-- Map -->
        <div class="bg-white rounded-lg overflow-hidden shadow-md h-80">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3560.5168749999996!2d80.1456!3d26.4589!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1sPukhrayan%2C%20Kanpur%2C%20Uttar%20Pradesh!2sIndia!5e0!3m2!1sen!2sin!4v1234567890"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="ASR Drillers Factory Location - Pukhrayan, Kanpur"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-4xl">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-12 text-center">
        {isHindi ? "अक्सर पूछे जाने वाले प्रश्न" : "Frequently Asked Questions"}
      </h2>
      <div class="space-y-6">
        <details class="bg-slate-50 p-6 rounded-lg group cursor-pointer">
          <summary class="font-bold text-lg text-slate-900 flex justify-between items-center">
            {isHindi ? "कोटे के लिए कितना समय लगता है?" : "How long does it take to get a quote?"}
            <span class="text-brand-teal group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-slate-600 mt-4">
            {isHindi
              ? "हम सभी पूछताछ को 2 घंटे के भीतर जवाब देते हैं। बस हमें कॉल करें या अपनी आवश्यकताओं के साथ WhatsApp संदेश भेजें।"
              : "We respond to all inquiries within 2 hours. Simply call us or send a WhatsApp message with your requirements."}
          </p>
        </details>

        <details class="bg-slate-50 p-6 rounded-lg group cursor-pointer">
          <summary class="font-bold text-lg text-slate-900 flex justify-between items-center">
            {isHindi ? "क्या आप मुफ्त स्थापना प्रदान करते हैं?" : "Do you offer free installation?"}
            <span class="text-brand-teal group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-slate-600 mt-4">
            {isHindi
              ? "हाँ! हम अपनी सभी बोरिंग मशीनों के साथ मुफ्त ऑन-साइट इंस्टॉलेशन और प्रशिक्षण प्रदान करते हैं।"
              : "Yes! We provide free on-site installation and training with all our boring machines."}
          </p>
        </details>

        <details class="bg-slate-50 p-6 rounded-lg group cursor-pointer">
          <summary class="font-bold text-lg text-slate-900 flex justify-between items-center">
            {isHindi ? "आप क्या वारंटी प्रदान करते हैं?" : "What warranty do you provide?"}
            <span class="text-brand-teal group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-slate-600 mt-4">
            {isHindi
              ? "हमारी सभी मशीनें व्यापक वारंटी के साथ आती हैं। हम विस्तारित वारंटी विकल्प भी प्रदान करते हैं।"
              : "All our machines come with a comprehensive warranty. We also offer extended warranty options."}
          </p>
        </details>

        <details class="bg-slate-50 p-6 rounded-lg group cursor-pointer">
          <summary class="font-bold text-lg text-slate-900 flex justify-between items-center">
            {isHindi ? "क्या आप भारत भर में डिलीवरी करते हैं?" : "Do you deliver across India?"}
            <span class="text-brand-teal group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-slate-600 mt-4">
            {isHindi
              ? "हाँ, हम सुरक्षित परिवहन और हैंडलिंग के साथ भारत भर में डिलीवर करते हैं। हमारे ग्राहक लगभग हर राज्य में हैं।"
              : "Yes, we deliver across India with safe transportation and handling. We have clients in almost every state."}
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-brand-teal to-brand-green text-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        {isHindi ? "शुरू करने के लिए तैयार?" : "Ready to Get Started?"}
      </h2>
      <p class="text-lg text-teal-100 mb-8">
        {isHindi
          ? "आज ही हमसे संपर्क करें और अपनी बोरिंग मशीन की जरूरतों पर चर्चा करें।"
          : "Contact us today and let's discuss your boring machine needs."}
      </p>
      <a
        href={`https://wa.me/${whatsapp.replace(/[^0-9]/g, "")}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-white text-brand-teal px-8 py-3 rounded-lg font-bold hover:bg-slate-100 transition-colors"
      >
        💬 Message on WhatsApp →
      </a>
    </div>
  </section>
</Layout>

<script define:vars={{ whatsapp, isHindi }}>
  const form = document.getElementById("contact-form");
  
  form.addEventListener("submit", (e) => {
    e.preventDefault();
    
    const name = document.getElementById("form-name").value;
    const phone = document.getElementById("form-phone").value;
    const email = document.getElementById("form-email").value;
    const location = document.getElementById("form-location").value;
    const machine = document.getElementById("form-machine").value;
    const message = document.getElementById("form-message").value;
    
    const whatsappNumber = whatsapp.replace(/[^0-9]/g, "");
    
    let whatsappMessage = isHindi
      ? `नमस्ते! मैं ASR Drillers से संपर्क करना चाहता/चाहती हूँ।\n\n`
      : `Hi! I want to contact ASR Drillers.\n\n`;
    
    whatsappMessage += `*Name:* ${name}\n`;
    whatsappMessage += `*Phone:* ${phone}\n`;
    whatsappMessage += `*Email:* ${email}\n`;
    whatsappMessage += `*Location:* ${location}\n`;
    if (machine) {
      whatsappMessage += `*Machine Interest:* ${machine}\n`;
    }
    whatsappMessage += `*Message:* ${message}`;
    
    const encodedMessage = encodeURIComponent(whatsappMessage);
    const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodedMessage}`;
    
    window.open(whatsappUrl, "_blank");
  });
</script>
