---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
import TrustBar from "../components/TrustBar.astro";
import SEOHead from "../components/SEOHead.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  schema?: any;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = "ASR Drillers - Boring Machine Manufacturer",
  description = "ASR Drillers manufactures high-quality tubewell and borewell boring machines in Kanpur, India. 22-38 HP diesel-powered models. On-site installation & 24/7 support.",
  schema = null,
  canonicalUrl,
  ogImage = "/og-image.jpg",
  noindex = false,
} = Astro.props;

// Determine locale from URL
const currentPath = Astro.url?.pathname || "/";
const isHindi = currentPath.startsWith("/hi/");
const locale = isHindi ? "hi" : "en";

// Organization Schema (always included)
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://asrdrillers.com/#organization",
  name: "ASR Drillers",
  url: "https://asrdrillers.com",
  logo: "https://asrdrillers.com/logo.png",
  description: "Leading boring machine manufacturer in India. 14+ years experience, 500+ happy customers.",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Pukhrayan Industrial Area",
    addressLocality: "Kanpur",
    addressRegion: "Uttar Pradesh",
    postalCode: "208201",
    addressCountry: "IN",
  },
  telephone: "+91-98765-43210",
  email: "info@asrdrillers.com",
  foundingDate: "2012",
  sameAs: [
    "https://www.facebook.com/asrdrillers",
    "https://www.instagram.com/asrdrillers",
    "https://wa.me/919876543210",
  ],
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <SEOHead
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
      locale={locale}
      noindex={noindex}
    />

    <!-- Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    <!-- Page-specific Schema -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <title>{title}</title>

    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html,
      body {
        width: 100%;
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu,
          Cantarell, sans-serif;
        line-height: 1.6;
        color: #333;
        background-color: #f8fafc;
      }

      .container {
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1rem;
      }

      details summary::-webkit-details-marker {
        display: none;
      }

      details summary {
        list-style: none;
      }

      @media (max-width: 768px) {
        .container {
          padding: 0 1rem;
        }
      }

      /* Smooth scroll */
      html {
        scroll-behavior: smooth;
      }

      /* Custom scrollbar */
      ::-webkit-scrollbar {
        width: 10px;
      }

      ::-webkit-scrollbar-track {
        background: #f1f1f1;
      }

      ::-webkit-scrollbar-thumb {
        background: #0F766E;
        border-radius: 5px;
      }

      ::-webkit-scrollbar-thumb:hover {
        background: #166534;
      }
    </style>
  </head>

  <body>
    <!-- Trust Bar -->
    <TrustBar />

    <!-- Header -->
    <Header />

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <Footer />

    <!-- Floating WhatsApp Button -->
    <FloatingWhatsApp />
  </body>
</html>
