---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  schema?: any;
}

const {
  title = "ASR Drillers - Boring Machine Manufacturer",
  description = "ASR Drillers manufactures high-quality tubewell and borewell boring machines in Kanpur, India. 22-38 HP diesel-powered models. On-site installation & 24/7 support.",
  schema = null,
} = Astro.props;

// Get current path and locale
const currentPath = Astro.url.pathname;
const isHindi = currentPath.startsWith('/hi/');
const basePathWithoutLocale = isHindi 
  ? currentPath.replace('/hi/', '/') 
  : currentPath;
const cleanPath = basePathWithoutLocale === '/' ? '/' : basePathWithoutLocale;

// Generate hreflang URLs
const siteUrl = 'https://asrdrillers.com';
const englishUrl = cleanPath === '/' ? siteUrl : `${siteUrl}${cleanPath}`;
const hindiUrl = cleanPath === '/' ? `${siteUrl}/hi/` : `${siteUrl}/hi${cleanPath}`;
---

<!doctype html>
<html lang={isHindi ? "hi" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="boring machine, tubewell boring, borewell drilling, Kanpur manufacturer, India"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Hreflang tags for multilingual SEO -->
    <link rel="alternate" hreflang="en" href={englishUrl} />
    <link rel="alternate" hreflang="hi" href={hindiUrl} />
    <link rel="alternate" hreflang="x-default" href={englishUrl} />
    
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
    
    <title>{title}</title>
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html,
      body {
        width: 100%;
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu,
          Cantarell, sans-serif;
        line-height: 1.6;
        color: #333;
      }

      .container {
        width: 100%;
        margin: 0 auto;
      }

      details summary::-webkit-details-marker {
        display: none;
      }

      details summary {
        list-style: none;
      }

      @media (max-width: 768px) {
        .container {
          width: 100%;
          padding: 0 1rem;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
