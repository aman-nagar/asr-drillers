---
import { commonData } from "../data/locations-i18n.js";
---

<section class="py-16 bg-gray-50">
  <div class="container mx-auto px-4 md:px-8 max-w-6xl">
    <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center text-gray-900">
      Why ASR Drillers Wins
    </h2>

    <div class="grid md:grid-cols-2 gap-12 mb-12">
      <div>
        <h3 class="text-2xl font-bold mb-6 text-brand-teal">Why Choose ASR?</h3>
        <ul class="space-y-4">
          <li class="flex gap-3">
            <span class="text-brand-green font-bold text-2xl">✓</span>
            <div>
              <strong>Proven Kanpur Manufacturing:</strong> 14+ years crafting boring
              machines in Pukhrayan industrial hub. In-house assembly, quality control,
              field-tested.
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-brand-green font-bold text-2xl">✓</span>
            <div>
              <strong>High-Torque, Fuel-Efficient Engines:</strong> 22 HP, 30 HP,
              38 HP models with Kirloskar/Field Marshal engines. Drill 100–500 feet
              in clay, rock, sandy soil.
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-brand-green font-bold text-2xl">✓</span>
            <div>
              <strong>3 Proven Machine Types:</strong> Submersible (lightweight, deep
              drilling), Hydraulic (precision control), Portable (tractor-mounted,
              flexible).
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-brand-green font-bold text-2xl">✓</span>
            <div>
              <strong>Local Support You Can Count On:</strong> On-site installation/training
              in UP/North India. 24/7 WhatsApp support. Quick spare parts from Kanpur
              factory.
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-brand-green font-bold text-2xl">✓</span>
            <div>
              <strong>Warranty + Service Camps:</strong> 1–2 year warranty. Annual
              free service camps across UP/Bihar. Never stranded.
            </div>
          </li>
        </ul>
      </div>

      <div
        class="bg-white p-8 rounded-lg shadow-lg border-l-4 border-brand-teal"
      >
        <h3 class="text-2xl font-bold mb-6 text-gray-900">Quick Specs</h3>
        <div class="space-y-4">
          <div>
            <p class="text-sm text-gray-600 uppercase font-semibold">
              Depth Capacity
            </p>
            <p class="text-2xl font-bold text-brand-teal">100–500+ Feet</p>
          </div>
          <div>
            <p class="text-sm text-gray-600 uppercase font-semibold">
              Engine Types
            </p>
            <p class="text-2xl font-bold text-brand-teal">22–38 HP Diesel</p>
          </div>
          <div>
            <p class="text-sm text-gray-600 uppercase font-semibold">
              Borehole Diameter
            </p>
            <p class="text-2xl font-bold text-brand-teal">4–12 Inch</p>
          </div>
          <div>
            <p class="text-sm text-gray-600 uppercase font-semibold">
              Price Range
            </p>
            <p class="text-2xl font-bold text-brand-teal">₹4.5–7.5 Lakhs</p>
          </div>
          <div>
            <p class="text-sm text-gray-600 uppercase font-semibold">
              Warranty
            </p>
            <p class="text-2xl font-bold text-brand-teal">1–2 Years</p>
          </div>
        </div>

        <a
          href={`https://wa.me/${commonData.whatsapp.replace("+", "")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="block mt-6 bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-6 rounded text-center transition"
        >
          Get Custom Quote
        </a>
      </div>
    </div>
  </div>
</section>
