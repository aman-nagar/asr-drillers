---
import { getLocaleFromPath } from "../../lib/i18n.js";

interface ActionLink {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
  external?: boolean;
  icon?: string;
}

interface HeroSignal {
  value: string;
  label: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  actions?: ActionLink[];
  signals?: HeroSignal[];
  visualTitle?: string;
  visualLines?: string[];
}

const {
  eyebrow,
  title,
  description,
  actions = [],
  signals = [],
  visualTitle,
  visualLines = [],
} = Astro.props;

const locale = getLocaleFromPath(Astro.url?.pathname || "/");
const isHindi = locale === "hi";
const supportPills = isHindi
  ? ["फैक्टरी-डायरेक्ट", "हिंदी/English सहायता", "तेज़ कोट जवाब"]
  : ["Factory-direct", "Hindi/English support", "Fast quote response"];
const groundChips = isHindi
  ? ["हार्ड रॉक", "क्ले सॉइल", "सैंडी बोर"]
  : ["Hard Rock", "Clay Soil", "Sandy Bore"];
---

<section class="section-shell relative overflow-hidden bg-[linear-gradient(135deg,#071b1f_0%,#0f766e_44%,#13343b_100%)] text-white md:py-24">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.16),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(132,204,22,0.14),transparent_22%)]"></div>
  <div class="absolute inset-y-0 right-0 hidden w-1/2 bg-[linear-gradient(90deg,transparent,rgba(255,255,255,0.05))] lg:block"></div>

  <div class="container relative mx-auto max-w-[1400px] px-4 md:px-8">
    <div class="grid items-center gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.1fr)] lg:gap-16">
      
      {/* ========================================= */}
      {/* LEFT SIDE: Text, Buttons, and Signals     */}
      {/* ========================================= */}
      <div class="max-w-2xl py-8">
        {eyebrow && (
          <p class="mb-3 inline-flex rounded-full border border-white/15 bg-white/10 px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.24em] text-emerald-100 backdrop-blur-sm md:mb-4">
            {eyebrow}
          </p>
        )}

        <h1 class="text-4xl font-bold leading-[1.05] md:text-5xl lg:text-6xl">{title}</h1>
        <p class="mt-4 text-base leading-relaxed text-emerald-50/90 md:mt-6 md:text-xl">
          {description}
        </p>

        {actions.length > 0 && (
          <div class="mt-6 flex flex-col gap-3 sm:flex-row md:mt-8">
            {actions.map((action) => (
              <a
                href={action.href}
                target={action.external ? "_blank" : undefined}
                rel={action.external ? "noopener noreferrer" : undefined}
                class:list={[
                  "flex min-h-[3.75rem] w-full items-center justify-center gap-2 rounded-2xl px-6 py-4 text-center font-bold transition duration-300 sm:w-auto",
                  action.variant === "secondary"
                    ? "border border-white/20 bg-slate-950/40 text-white backdrop-blur hover:bg-slate-950/55"
                    : "bg-white text-slate-950 shadow-[0_18px_40px_rgba(15,23,42,0.22)] hover:bg-slate-100",
                ]}
              >
                {action.icon && <span aria-hidden="true">{action.icon}</span>}
                <span>{action.label}</span>
              </a>
            ))}
          </div>
        )}

        <div class="mt-5 flex flex-wrap gap-2">
          {supportPills.map((pill) => (
            <span class="inline-flex rounded-full border border-white/15 bg-white/10 px-3 py-2 text-xs font-semibold text-emerald-50/90 backdrop-blur-sm">
              {pill}
            </span>
          ))}
        </div>

        {signals.length > 0 && (
          <div class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-3 md:mt-10">
            {signals.map((signal) => (
              <div class="rounded-3xl border border-white/15 bg-white/5 px-4 py-4 backdrop-blur-sm">
                <p class="text-3xl font-bold text-white">{signal.value}</p>
                <p class="mt-1 text-sm text-emerald-100/85">{signal.label}</p>
              </div>
            ))}
          </div>
        )}
      </div>

      {/* ========================================= */}
      {/* RIGHT SIDE: Floating Card Over Image      */}
      {/* ========================================= */}
      <div class="relative mt-4 flex min-h-[550px] w-full flex-col justify-end lg:mt-0 lg:min-h-[700px]">
        
        {/* 1. The Machine Image (Pinned to Top Right) */}
        <div class="absolute right-0 top-0 h-full w-full overflow-hidden rounded-[2rem] border border-white/10 shadow-2xl lg:w-[85%]">
          {/* Dark gradient overlay to ensure the floating card and machine contrast beautifully */}
          <div class="absolute inset-0 z-10 bg-gradient-to-t from-slate-950/90 via-slate-900/20 to-transparent"></div>
          <img
            src="https://res.cloudinary.com/deyu6gc0h/image/upload/q_auto/f_auto/v1775317095/hero-banner_opurir.png"
            alt="ASR Boring Machine Equipment"
            class="h-full w-full object-cover object-center transition-transform duration-1000 hover:scale-105"
          />
        </div>

        <!-- {/* 2. The Floating Dark Card (Pulled Left and Down) */}
        <div class="surface-panel relative z-20 mb-4 mr-auto mt-48 w-full overflow-hidden border border-white/15 bg-slate-950/85 p-4 shadow-[0_30px_80px_rgba(8,51,68,0.5)] backdrop-blur-md md:p-6 lg:-ml-12 lg:mb-12 lg:mt-auto lg:w-[85%]">
          
          {/* Card Header */}
          <div class="flex items-center justify-between gap-2 text-xs uppercase tracking-[0.24em] text-emerald-200/75">
            <div class="flex items-center gap-2">
              <span class="inline-block h-2.5 w-2.5 rounded-full bg-emerald-400 shadow-[0_0_10px_rgba(52,211,153,0.5)]"></span>
              <span>ASR Field Build Profile</span>
            </div>
            <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[10px] text-white/80">
              {isHindi ? "फैक्टरी सपोर्ट" : "Factory support"}
            </span>
          </div>

          {/* Machine Specs Inner Block */}
          <div class="relative mt-5 overflow-hidden rounded-[1.75rem] border border-white/10 bg-[linear-gradient(145deg,rgba(15,118,110,0.3),rgba(2,6,23,0.8))] p-5 md:p-6">
            <div class="absolute right-4 top-2 text-[5rem] font-bold leading-none text-white/5">ASR</div>
            <div class="grid gap-4 sm:grid-cols-[1fr_auto]">
              <div class="relative z-10">
                <p class="text-sm uppercase tracking-[0.24em] text-emerald-200/70">
                  {visualTitle ?? "Field-Ready Machine Lineup"}
                </p>
                <p class="mt-3 text-3xl font-bold text-white lg:text-4xl">22 HP • 30 HP • 38 HP</p>
                <p class="mt-3 max-w-md text-sm leading-relaxed text-slate-300">
                  {isHindi
                    ? "कॉन्ट्रैक्टर और फार्म उपयोग के लिए फैक्टरी-डायरेक्ट सपोर्ट वाली बोरिंग मशीनें।"
                    : "Contractor-ready boring systems with factory-direct service and fast support."}
                </p>
              </div>
              <div class="relative z-10 flex flex-row flex-wrap gap-2 sm:flex-col sm:gap-3">
                {groundChips.map((chip) => (
                  <span class="rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs font-semibold text-white backdrop-blur-sm">
                    {chip}
                  </span>
                ))}
              </div>
            </div>
          </div>

          {/* Feature List */}
          <div class="mt-5 space-y-3">
            {(visualLines.length > 0
              ? visualLines
              : [
                  "Factory-direct guidance from Kanpur",
                  "Faster spare-part response across North India",
                  "Hindi and English support for farmers and contractors",
                ]
            ).map((line) => (
              <div class="flex items-start gap-3 rounded-2xl border border-white/5 bg-white/5 px-4 py-3 hover:bg-white/10 transition-colors">
                <span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-emerald-400/20 text-emerald-300">+</span>
                <p class="text-sm text-slate-200">{line}</p>
              </div>
            ))}
          </div>
        </div> -->

      </div>
    </div>
  </div>
</section>