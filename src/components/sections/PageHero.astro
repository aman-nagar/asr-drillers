---
interface ActionLink {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
  external?: boolean;
  icon?: string;
}

interface Props {
  title: string;
  description: string;
  actions?: ActionLink[];
}

const { title, description, actions = [] } = Astro.props;
---

<section class="bg-gradient-to-r from-brand-teal to-brand-green text-white py-16 md:py-24">
  <div class="container mx-auto px-4 md:px-8 max-w-6xl">
    <div class="max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">{title}</h1>
      <p class="text-lg md:text-xl mb-8 leading-relaxed opacity-95">{description}</p>

      {actions.length > 0 && (
        <div class="flex flex-col sm:flex-row gap-4">
          {actions.map((action) => (
            <a
              href={action.href}
              target={action.external ? "_blank" : undefined}
              rel={action.external ? "noopener noreferrer" : undefined}
              class:list={[
                "font-bold py-3 px-6 rounded text-center transition flex items-center justify-center gap-2",
                action.variant === "secondary"
                  ? "bg-white text-brand-teal hover:bg-gray-100"
                  : "bg-brand-green hover:bg-brand-green/90 text-white",
              ]}
            >
              {action.icon && <span>{action.icon}</span>}
              <span>{action.label}</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</section>
