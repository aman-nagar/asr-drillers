---
interface ActionLink {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
  external?: boolean;
  icon?: string;
}

interface HeroSignal {
  value: string;
  label: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  actions?: ActionLink[];
  signals?: HeroSignal[];
  visualTitle?: string;
  visualLines?: string[];
}

const {
  eyebrow,
  title,
  description,
  actions = [],
  signals = [],
  visualTitle,
  visualLines = [],
} = Astro.props;
---

<section class="section-shell relative overflow-hidden bg-[radial-gradient(circle_at_top_left,_rgba(255,255,255,0.18),_transparent_30%),linear-gradient(135deg,#083344_0%,#0f766e_42%,#14532d_100%)] text-white md:py-24">
  <div class="absolute inset-x-0 top-0 h-40 bg-[linear-gradient(180deg,rgba(255,255,255,0.12),transparent)]"></div>
  <div class="absolute right-[-6rem] top-10 h-72 w-72 rounded-full bg-white/10 blur-3xl"></div>
  <div class="absolute left-[-4rem] bottom-[-5rem] h-64 w-64 rounded-full bg-emerald-300/10 blur-3xl"></div>

  <div class="container relative mx-auto max-w-6xl px-4 md:px-8">
    <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)]">
      <div class="max-w-3xl">
        {eyebrow && (
          <p class="mb-4 inline-flex rounded-full border border-white/15 bg-white/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.22em] text-emerald-100 backdrop-blur-sm">
            {eyebrow}
          </p>
        )}

        <h1 class="text-4xl font-bold leading-tight md:text-5xl lg:text-6xl">{title}</h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-emerald-50/90 md:text-xl">
          {description}
        </p>

        {actions.length > 0 && (
          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            {actions.map((action) => (
              <a
                href={action.href}
                target={action.external ? "_blank" : undefined}
                rel={action.external ? "noopener noreferrer" : undefined}
                class:list={[
                  "flex items-center justify-center gap-2 rounded-2xl px-6 py-4 text-center font-bold transition duration-300",
                  action.variant === "secondary"
                    ? "border border-white/20 bg-white text-brand-teal hover:bg-slate-100"
                    : "bg-slate-950/80 text-white shadow-[0_18px_40px_rgba(15,23,42,0.22)] hover:bg-slate-950",
                ]}
              >
                {action.icon && <span aria-hidden="true">{action.icon}</span>}
                <span>{action.label}</span>
              </a>
            ))}
          </div>
        )}

        {signals.length > 0 && (
          <div class="mt-10 grid grid-cols-2 gap-4 md:grid-cols-3">
            {signals.map((signal) => (
              <div class="rounded-2xl border border-white/15 bg-white/8 px-4 py-4 backdrop-blur-sm">
                <p class="text-2xl font-bold text-white">{signal.value}</p>
                <p class="mt-1 text-sm text-emerald-100/85">{signal.label}</p>
              </div>
            ))}
          </div>
        )}
      </div>

      <div class="relative">
        <div class="surface-panel border border-white/15 bg-slate-950/75 p-6 shadow-[0_30px_80px_rgba(8,51,68,0.35)] backdrop-blur-sm">
          <div class="flex items-center gap-2 text-xs uppercase tracking-[0.24em] text-emerald-200/75">
            <span class="inline-block h-2.5 w-2.5 rounded-full bg-emerald-300"></span>
            <span>ASR Field Build Profile</span>
          </div>

          <div class="mt-6 rounded-[1.5rem] border border-white/10 bg-[linear-gradient(145deg,rgba(15,118,110,0.35),rgba(2,6,23,0.9))] p-6">
            <div class="grid grid-cols-[1fr_auto] gap-4">
              <div>
                <p class="text-sm uppercase tracking-[0.24em] text-emerald-200/70">
                  {visualTitle ?? "Built for Indian Ground Conditions"}
                </p>
                <p class="mt-3 text-3xl font-bold text-white">22 HP • 30 HP • 38 HP</p>
                <p class="mt-3 text-sm leading-relaxed text-slate-200">
                  Contractor-ready boring systems with factory-direct service and fast support.
                </p>
              </div>
              <div class="flex flex-col gap-3">
                <span class="rounded-full border border-white/10 bg-white/10 px-3 py-1 text-xs font-semibold text-white">
                  Hard Rock
                </span>
                <span class="rounded-full border border-white/10 bg-white/10 px-3 py-1 text-xs font-semibold text-white">
                  Clay Soil
                </span>
                <span class="rounded-full border border-white/10 bg-white/10 px-3 py-1 text-xs font-semibold text-white">
                  Sandy Bore
                </span>
              </div>
            </div>
          </div>

          <div class="mt-5 space-y-3">
            {(visualLines.length > 0
              ? visualLines
              : [
                  "Factory-direct guidance from Kanpur",
                  "Faster spare-part response across North India",
                  "Hindi and English support for farmers and contractors",
                ]
            ).map((line) => (
              <div class="flex items-start gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                <span class="mt-0.5 text-emerald-300">+</span>
                <p class="text-sm text-slate-100">{line}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
