---
interface SignalItem {
  value: string;
  label: string;
  note?: string;
}

interface Props {
  items: SignalItem[];
  sectionClass?: string;
}

const { items, sectionClass = "py-10" } = Astro.props;
---

<section class={sectionClass}>
  <div class="container mx-auto px-4 md:px-8 max-w-6xl">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {items.map((item) => (
        <div class="surface-card border border-white/10 bg-slate-950/80 p-5 shadow-[0_18px_45px_rgba(15,23,42,0.18)] backdrop-blur-sm">
          <p class="text-2xl md:text-3xl font-bold text-white">{item.value}</p>
          <p class="mt-2 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-200/80">
            {item.label}
          </p>
          {item.note && <p class="mt-2 text-sm text-slate-300">{item.note}</p>}
        </div>
      ))}
    </div>
  </div>
</section>
