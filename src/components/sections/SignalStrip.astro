---
interface SignalItem {
  value: string;
  label: string;
  note?: string;
}

interface Props {
  items: SignalItem[];
  sectionClass?: string;
}

const { items, sectionClass = "py-10" } = Astro.props;
---

<section class={sectionClass}>
  <div class="container mx-auto px-4 md:px-8 max-w-6xl">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {items.map((item) => (
        <div class="surface-card overflow-hidden border border-white/10 bg-slate-950/80 shadow-[0_18px_45px_rgba(15,23,42,0.18)] backdrop-blur-sm">
          <div class="border-b border-white/10 bg-[linear-gradient(90deg,rgba(20,184,166,0.18),rgba(15,23,42,0))] px-5 py-3">
            <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-emerald-200/80">
              {item.label}
            </p>
          </div>
          <div class="px-5 py-5">
            <p class="text-3xl font-bold text-white md:text-4xl">{item.value}</p>
            {item.note && <p class="mt-3 text-sm leading-relaxed text-slate-300">{item.note}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
