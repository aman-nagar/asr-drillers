---
interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  titleClass?: string;
  subtitleClass?: string;
}

const {
  title,
  subtitle,
  align = "center",
  titleClass = "text-gray-900",
  subtitleClass = "text-gray-600",
} = Astro.props;

const alignmentClass = align === "left" ? "text-left" : "text-center";
---

<div class={`mb-8 md:mb-10 ${alignmentClass}`}>
  <h2 class={`mb-3 text-2xl leading-tight font-bold md:mb-4 md:text-4xl ${titleClass}`}>{title}</h2>
  {subtitle && (
    <p class={`text-base leading-relaxed md:text-lg max-w-3xl ${align === "center" ? "mx-auto" : ""} ${subtitleClass}`}>
      {subtitle}
    </p>
  )}
</div>
