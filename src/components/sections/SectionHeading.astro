---
interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  titleClass?: string;
  subtitleClass?: string;
}

const {
  title,
  subtitle,
  align = "center",
  titleClass = "text-gray-900",
  subtitleClass = "text-gray-600",
} = Astro.props;

const alignmentClass = align === "left" ? "text-left" : "text-center";
---

<div class={`mb-12 ${alignmentClass}`}>
  <h2 class={`text-3xl md:text-4xl font-bold mb-4 ${titleClass}`}>{title}</h2>
  {subtitle && (
    <p class={`text-lg max-w-3xl ${align === "center" ? "mx-auto" : ""} ${subtitleClass}`}>
      {subtitle}
    </p>
  )}
</div>
