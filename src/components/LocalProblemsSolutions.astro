---
import InsightCard from "./cards/InsightCard.astro";

interface Problem {
  title: string;
  desc: string;
}

interface Solution {
  title: string;
  desc: string;
}

interface Props {
  problems: Problem[];
  solutions: Solution[];
  problemsTitle?: string;
  solutionsTitle?: string;
}

const {
  problems,
  solutions,
  problemsTitle = "Your Drilling Challenges",
  solutionsTitle = "ASR Drillers Solution",
} = Astro.props;
---

<section class="section-shell bg-white">
  <div class="container mx-auto px-4 md:px-8 max-w-6xl">
    <div class="grid gap-8 md:grid-cols-2 lg:gap-10">
      <div>
        <h3 class="mb-6 text-2xl font-bold text-slate-950 md:mb-8 md:text-3xl">
          {problemsTitle}
        </h3>
        <div class="grid gap-6">
          {
            problems.map((problem) => (
              <InsightCard title={problem.title} body={problem.desc} tone="danger" icon="X" />
            ))
          }
        </div>
      </div>

      <div>
        <h3 class="mb-6 text-2xl font-bold text-slate-950 md:mb-8 md:text-3xl">
          {solutionsTitle}
        </h3>
        <div class="grid gap-6">
          {
            solutions.map((solution) => (
              <InsightCard
                title={solution.title}
                body={solution.desc}
                tone="success"
                icon="+"
              />
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
