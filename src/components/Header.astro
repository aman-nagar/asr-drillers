---
import { commonData } from "../data/locations-i18n.js";

const { phone, whatsapp } = commonData;

// Static nav links (no path logic here)
const navLinks = [
  { en: "Home", hi: "होम", path: "/" },
  { en: "Kanpur", hi: "कानपुर", path: "/kanpur" },
  { en: "Lucknow", hi: "लखनऊ", path: "/lucknow" },
  { en: "Bihar", hi: "बिहार", path: "/bihar" },
  { en: "About", hi: "हमारे बारे में", path: "/about" },
  { en: "Contact", hi: "संपर्क", path: "/contact" },
];
---

<header class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="flex items-center justify-between py-3">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <div
          class="w-12 h-12 bg-gradient-to-br from-brand-teal to-brand-green rounded-lg flex items-center justify-center text-white text-2xl font-bold shadow-md"
        >
          ⚙️
        </div>
        <div>
          <span class="text-xl font-bold text-slate-900">ASR Drillers</span>
          <p class="text-xs text-brand-teal font-semibold -mt-0.5">Est. 2015</p>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {
          navLinks.map((link) => (
            <a
              href={link.path}
              class="text-sm font-medium text-slate-700 hover:text-brand-teal hover:bg-slate-100 px-3 py-2 rounded-md transition-colors"
            >
              {link.en}
            </a>
          ))
        }
      </nav>

      <!-- Right Section -->
      <div class="flex items-center gap-3 lg:gap-4">
        <!-- Language Toggle (will be updated client-side) -->
        <div
          id="lang-toggle"
          class="flex items-center gap-1 border-r border-slate-200 pr-3"
        >
          <span
            class="text-xs font-semibold px-2 py-1 text-brand-teal bg-brand-teal bg-opacity-10 rounded"
          >
            English
          </span>
          <span class="text-slate-300">|</span>
          <a
            href="#"
            class="text-xs font-semibold px-2 py-1 text-slate-600 hover:text-brand-teal hover:bg-slate-100 rounded transition-colors"
          >
            हिंदी
          </a>
        </div>

        <!-- Phone -->
        <a
          href={`tel:${phone}`}
          class="hidden sm:flex text-xs lg:text-sm font-semibold text-slate-700 hover:text-brand-teal transition-colors items-center gap-1"
        >
          📞 <span class="hidden md:inline">{phone}</span>
        </a>

        <!-- WhatsApp Button -->
        <a
          href={`https://wa.me/${whatsapp.replace(/[^0-9]/g, "")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-brand-green hover:bg-brand-green/90 hover:shadow-lg hover:scale-105 text-white px-3 lg:px-4 py-2 rounded-lg font-semibold flex items-center gap-2 transition-all text-sm"
        >
          💬 <span class="hidden sm:inline">WhatsApp</span>
        </a>

        <!-- Mobile Menu Button -->
        <button
          class="lg:hidden text-slate-700 hover:text-brand-teal p-2 rounded-lg hover:bg-slate-100 transition-colors"
          id="mobile-menu-btn"
          aria-label="Toggle menu"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div
      id="mobile-menu"
      class="hidden lg:hidden border-t border-slate-200 py-4"
    >
      <nav class="flex flex-col gap-2">
        {
          navLinks.map((link) => (
            <a
              href={link.path}
              class="text-sm font-medium text-slate-700 hover:text-brand-teal hover:bg-slate-100 px-3 py-2 rounded-md transition-colors"
            >
              {link.en}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</header>

<script>
  // Client-side only: safe access to location
  const currentPath = window.location.pathname;
  const isHindi = currentPath.startsWith("/hi/");

  const basePath = isHindi
    ? currentPath.replace(/^\/hi/, "") || "/"
    : currentPath;

  const englishUrl = basePath === "/" ? "/" : basePath;
  const hindiUrl = basePath === "/" ? "/hi/" : `/hi${basePath}`;

  // Update language toggle links & active state
  const langToggle = document.getElementById("lang-toggle");
  if (langToggle) {
    langToggle.innerHTML = isHindi
      ? `
        <a href="${englishUrl}" class="text-xs font-semibold px-2 py-1 text-slate-600 hover:text-brand-teal hover:bg-slate-100 rounded transition-colors">
          English
        </a>
        <span class="text-slate-300">|</span>
        <span class="text-xs font-semibold px-2 py-1 text-brand-teal bg-brand-teal bg-opacity-10 rounded">
          हिंदी
        </span>
      `
      : `
        <span class="text-xs font-semibold px-2 py-1 text-brand-teal bg-brand-teal bg-opacity-10 rounded">
          English
        </span>
        <span class="text-slate-300">|</span>
        <a href="${hindiUrl}" class="text-xs font-semibold px-2 py-1 text-slate-600 hover:text-brand-teal hover:bg-slate-100 rounded transition-colors">
          हिंदी
        </a>
      `;
  }

  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  mobileMenuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
    });
  });
</script>
