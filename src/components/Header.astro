---
import { commonData } from "../data/locations-i18n.js";

const { phone, whatsapp } = commonData;

// Static nav links (no path logic here)
const navLinks = [
  { en: "Home", hi: "होम", path: "/" },
  { en: "Kanpur", hi: "कानपुर", path: "/kanpur" },
  { en: "Lucknow", hi: "लखनऊ", path: "/lucknow" },
  { en: "Bihar", hi: "बिहार", path: "/bihar" },
  { en: "About", hi: "हमारे बारे में", path: "/about" },
  { en: "Contact", hi: "संपर्क", path: "/contact" },
  { en: "Gallery", hi: "गैलरी", path: "/gallery" },
];
---

<header
  class="bg-white border-b-2 border-slate-300 sticky top-0 z-50 shadow-md"
>
  <div class="container mx-auto px-4 md:px-6 max-w-7xl">
    <div class="flex items-center justify-between py-4 md:py-5">
      <!-- Logo Section -->
      <a href="/" class="flex items-center gap-3 shrink-0 group">
        <div
          class="w-14 h-14 bg-gradient-to-br from-brand-teal to-brand-green rounded-xl flex items-center justify-center text-white text-3xl font-bold shadow-lg group-hover:shadow-xl transition-shadow"
        >
          ⚙️
        </div>
        <div class="flex flex-col gap-0.5">
          <span class="text-2xl font-bold text-slate-900 tracking-tight"
            >ASR Drillers</span
          >
          <p
            class="text-xs font-semibold text-brand-teal uppercase tracking-widest"
          >
            Est. 2015
          </p>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1">
        {
          navLinks.map((link) => (
            <a
              href={link.path}
              class="text-sm font-semibold text-slate-700 hover:text-brand-teal px-4 py-2 rounded-lg hover:bg-slate-100/50 transition-all duration-300"
            >
              {link.en}
            </a>
          ))
        }
      </nav>

      <!-- Right Section -->
      <div class="flex items-center gap-2 md:gap-4 lg:gap-5">
        <!-- Language Toggle -->
        <div
          id="lang-toggle"
          class="flex items-center gap-1 pl-3 md:pl-4 border-l-2 border-slate-300"
        >
          <span
            class="text-xs font-bold px-3 py-1.5 text-brand-teal bg-brand-teal/10 rounded-lg"
          >
            English
          </span>
          <a
            href="#"
            class="text-xs font-bold px-3 py-1.5 text-slate-600 hover:text-brand-teal hover:bg-slate-100/50 rounded-lg transition-all duration-300"
          >
            हिंदी
          </a>
        </div>

        <!-- Phone (hidden on small mobile) -->
        <a
          href={`tel:${phone}`}
          class="hidden sm:flex text-sm font-semibold text-slate-700 hover:text-brand-teal transition-colors items-center gap-2"
          title="Call us"
        >
          <span class="text-lg">📞</span>
          <span class="hidden md:inline">{phone}</span>
        </a>

        <!-- WhatsApp CTA Button -->
        <a
          href={`https://wa.me/${whatsapp.replace(/[^0-9]/g, "")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-brand-green hover:bg-brand-green/90 text-white font-bold px-4 md:px-5 py-2.5 rounded-xl flex items-center gap-2 transition-all duration-300 hover:shadow-lg hover:scale-105 text-sm md:text-base"
        >
          💬 <span class="hidden sm:inline">WhatsApp</span>
        </a>

        <!-- Mobile Menu Button -->
        <button
          class="lg:hidden text-slate-700 hover:text-brand-teal p-2.5 rounded-lg hover:bg-slate-100/50 transition-all duration-300"
          id="mobile-menu-btn"
          aria-label="Toggle menu"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div
      id="mobile-menu"
      class="hidden lg:hidden border-t-2 border-slate-200 py-4 px-4"
    >
      <nav class="flex flex-col gap-2">
        {
          navLinks.map((link) => (
            <a
              href={link.path}
              class="text-sm font-semibold text-slate-700 hover:text-brand-teal px-4 py-3 rounded-lg hover:bg-slate-100/50 transition-all duration-300"
            >
              {link.en}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</header>

<script>
  // Client-side only: safe access to location
  const currentPath = window.location.pathname;
  const isHindi = currentPath.startsWith("/hi/");

  const basePath = isHindi
    ? currentPath.replace(/^\/hi/, "") || "/"
    : currentPath;

  const englishUrl = basePath === "/" ? "/" : basePath;
  const hindiUrl = basePath === "/" ? "/hi/" : `/hi${basePath}`;

  // Update language toggle links & active state
  const langToggle = document.getElementById("lang-toggle");
  if (langToggle) {
    langToggle.innerHTML = isHindi
      ? `
        <a href="${englishUrl}" class="text-xs font-bold px-3 py-1.5 text-slate-600 hover:text-brand-teal hover:bg-slate-100/50 rounded-lg transition-all duration-300">
          English
        </a>
        <span class="text-brand-teal/30">•</span>
        <span class="text-xs font-bold px-3 py-1.5 text-brand-teal bg-brand-teal/10 rounded-lg">
          हिंदी
        </span>
      `
      : `
        <span class="text-xs font-bold px-3 py-1.5 text-brand-teal bg-brand-teal/10 rounded-lg">
          English
        </span>
        <span class="text-brand-teal/30">•</span>
        <a href="${hindiUrl}" class="text-xs font-bold px-3 py-1.5 text-slate-600 hover:text-brand-teal hover:bg-slate-100/50 rounded-lg transition-all duration-300">
          हिंदी
        </a>
      `;
  }

  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  mobileMenuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
    });
  });
</script>
