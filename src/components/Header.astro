---
import { siteConfig, getWhatsAppNumber } from "../config/site";
import { primaryNavLinks } from "../data/navigation";
import {
  getAlternateLocalePath,
  getLocaleFromPath,
  withLocalePrefix,
} from "../lib/i18n";
import {
  ShieldCheck,
  Award,
  Users,
  Phone,
  MessageCircle,
  Menu,
  X,
  Globe,
} from "@lucide/astro";

const currentPath = Astro.url?.pathname || "/";
const locale = getLocaleFromPath(currentPath);
const isHindi = locale === "hi";
const whatsappNumber = getWhatsAppNumber();
const languageTogglePath = getAlternateLocalePath(currentPath);
---

<header
  class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-slate-200 shadow-sm"
>
  <div class="container mx-auto px-4 md:px-6 max-w-7xl">
    <div class="flex items-center justify-between h-14 md:h-18">
      <a
        href={withLocalePrefix("/", locale)}
        class="flex items-center gap-2 md:gap-3 group shrink-0 min-w-0"
      >
        <div
          class="bg-brand-teal p-1 md:p-2 rounded-lg shadow-md group-hover:shadow-brand-teal/20 transition-all shrink-0"
        >
          <img
            src={siteConfig.logoPath}
            alt="ASR Logo"
            class="h-6 w-6 md:h-8 md:w-8 brightness-0 invert object-contain"
          />
        </div>
        <div class="flex flex-col justify-center min-w-0">
          <span
            class="text-sm md:text-xl font-black text-slate-900 leading-none tracking-tight uppercase"
          >
            ASR <span class="text-brand-teal">Drillers</span>
          </span>
          <span
            class="text-[7px] md:text-[9px] uppercase font-extrabold tracking-[0.15em] text-slate-500 mt-0.5"
          >
            {isHindi ? "बोरवेल विशेषज्ञ" : "Borewell Specialists"}
          </span>
        </div>
      </a>

      <nav class="hidden xl:flex items-center gap-1">
        {
          primaryNavLinks.map((link) => (
            <a
              href={withLocalePrefix(link.path, locale)}
              class="px-4 py-2 text-[13px] font-bold text-slate-600 hover:text-brand-teal rounded-lg hover:bg-slate-50 transition-all"
            >
              {link.label[locale]}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-1 md:gap-2 shrink-0">
        <a
          href={`tel:${siteConfig.phone}`}
          class="hidden lg:inline-flex items-center gap-1.5 px-2 md:px-3 py-1.5 text-slate-700 font-bold text-xs md:text-sm hover:text-brand-teal transition-all"
        >
          <Phone class="w-4 h-4 text-brand-teal shrink-0" />
          <span class="hidden xl:inline">{siteConfig.phone}</span>
        </a>

        <a
          href={languageTogglePath}
          class="hidden md:inline-flex items-center gap-1 text-brand-green hover:text-brand-teal transition-colors group h-full px-2 py-1.5 text-xs md:text-sm font-bold"
        >
          <Globe
            class="w-3.5 h-3.5 group-hover:rotate-12 transition-transform duration-300 shrink-0"
          />
          <span class="hidden lg:inline"
            >{isHindi ? "English" : "हिंदी में"}</span
          >
        </a>

        <button
          id="menu-toggle"
          class="md:hidden p-1.5 text-slate-900 bg-slate-100 rounded-lg hover:bg-slate-200 transition-colors focus:ring-2 focus:ring-brand-teal/50 outline-none shrink-0"
          aria-label="Toggle Menu"
        >
          <Menu id="icon-open" class="w-5 h-5 block" />
          <X id="icon-close" class="w-5 h-5 hidden" />
        </button>
      </div>
    </div>
  </div>

  <div
    id="mobile-nav"
    class="grid transition-all duration-300 ease-in-out xl:hidden overflow-hidden grid-rows-[0fr] opacity-0"
  >
    <div class="min-h-0 bg-slate-50 border-t border-slate-200">
      <div class="px-4 py-4 flex flex-col gap-2 shadow-inner">
        {
          primaryNavLinks.map((link) => (
            <a
              href={withLocalePrefix(link.path, locale)}
              class="px-4 py-3.5 rounded-xl bg-white text-slate-800 font-bold text-sm border border-slate-100 shadow-sm hover:border-brand-teal hover:text-brand-teal transition-all active:scale-[0.98] flex items-center justify-between"
            >
              {link.label[locale]}
            </a>
          ))
        }

        <div class="grid grid-cols-2 gap-3 mt-2">
          <a
            href={`tel:${siteConfig.phone}`}
            class="flex flex-col items-center justify-center gap-1.5 p-4 bg-white border border-slate-200 shadow-sm rounded-xl font-bold text-[10px] sm:text-xs uppercase text-slate-700 hover:border-brand-teal hover:text-brand-teal transition-colors"
          >
            <Phone class="w-5 h-5 text-brand-teal" />
            {isHindi ? "कॉल करें" : "Call Us"}
          </a>
          <a
            href={languageTogglePath}
            class="flex flex-col items-center justify-center gap-1.5 p-4 bg-white border border-slate-200 shadow-sm rounded-xl font-bold text-[10px] sm:text-xs uppercase text-slate-700 hover:border-brand-teal hover:text-brand-teal transition-colors"
          >
            <Globe class="w-5 h-5 text-brand-teal" />
            {isHindi ? "English" : "हिंदी"}
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("menu-toggle");
  const nav = document.getElementById("mobile-nav");
  const open = document.getElementById("icon-open");
  const close = document.getElementById("icon-close");

  btn?.addEventListener("click", () => {
    const isOpened = nav?.classList.contains("grid-rows-[1fr]");

    if (isOpened) {
      nav?.classList.remove("grid-rows-[1fr]", "opacity-100");
      nav?.classList.add("grid-rows-[0fr]", "opacity-0");
      open?.classList.remove("hidden");
      close?.classList.add("hidden");
    } else {
      nav?.classList.remove("grid-rows-[0fr]", "opacity-0");
      nav?.classList.add("grid-rows-[1fr]", "opacity-100");
      open?.classList.add("hidden");
      close?.classList.remove("hidden");
    }
  });
</script>
