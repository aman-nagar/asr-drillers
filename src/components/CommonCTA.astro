---
import { siteConfig, getWhatsAppNumber } from "../config/site";
import { getLocaleFromPath } from "../lib/i18n";

interface Props {
  headline?: string;
  subheadline?: string;
  bgColor?: string;
}

const locale = getLocaleFromPath(Astro.url?.pathname || "/");
const isHindi = locale === "hi";
const whatsappNumber = getWhatsAppNumber();

const {
  headline = isHindi
    ? "क्या आप अविश्वसनीय बोरिंग मशीनों पर पैसा बर्बाद करना बंद करना चाहते हैं?"
    : "Ready to Stop Wasting Money on Unreliable Boring Machines?",
  subheadline = isHindi
    ? "कानपुर के विश्वसनीय निर्माता से कस्टम कोट प्राप्त करें। 2 घंटे के भीतर जवाब।"
    : "Get a custom quote from Kanpur's most trusted manufacturer. Response in 2 hours.",
  bgColor = "from-brand-teal to-brand-green",
} = Astro.props;
---

<section class={`py-16 bg-gradient-to-r ${bgColor} text-white`}>
  <div class="container mx-auto px-4 md:px-8 max-w-6xl text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-6">
      {headline}
    </h2>
    <p class="text-xl mb-8 opacity-95 max-w-2xl mx-auto">
      {subheadline}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={`https://wa.me/${whatsappNumber}`}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-white text-brand-teal hover:bg-gray-100 font-bold py-4 px-8 rounded-lg text-lg transition"
      >
        💬 {isHindi ? "व्हाट्सऐप पर बात करें" : "Chat on WhatsApp"}
      </a>
      <a
        href={`tel:${siteConfig.phone}`}
        class="bg-brand-amber text-gray-900 hover:bg-amber-600 font-bold py-4 px-8 rounded-lg text-lg transition"
      >
        📞 {isHindi ? "अभी कॉल करें" : "Call Now"}: {siteConfig.phone}
      </a>
    </div>
    <p class="mt-6 text-sm opacity-90">
      {
        isHindi
          ? "हिंदी और अंग्रेजी में सहायता • बिना दबाव वाली बिक्री • वास्तविक इंजीनियरिंग जवाब"
          : "Dedicated support in Hindi/English • No pushy sales • Real engineering answers"
      }
    </p>
  </div>
</section>
