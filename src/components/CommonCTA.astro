---
import { siteConfig, getWhatsAppNumber } from "../config/site";
import { getLocaleFromPath } from "../lib/i18n";

interface Props {
  headline?: string;
  subheadline?: string;
  bgColor?: string;
}

const locale = getLocaleFromPath(Astro.url?.pathname || "/");
const isHindi = locale === "hi";
const whatsappNumber = getWhatsAppNumber();
const trustPoints = isHindi
  ? ["तेज़ जवाब", "हिंदी और English", "बिना दबाव सलाह"]
  : ["Fast response", "Hindi and English", "No-pressure guidance"];

const {
  headline = isHindi
    ? "अपनी जरूरत के लिए सही बोरिंग मशीन पर बात करनी है?"
    : "Ready to Talk About the Right Boring Machine for Your Work?",
  subheadline = isHindi
    ? "कानपुर की फैक्टरी टीम से कीमत, मॉडल सुझाव और डिलीवरी गाइडेंस पाएं। आम तौर पर 2 घंटे के भीतर जवाब।"
    : "Get pricing, model guidance, and delivery support directly from the Kanpur factory team. Typical response within 2 hours.",
  bgColor = "from-brand-teal to-brand-green",
} = Astro.props;
---

<section class="section-shell">
  <div class="container mx-auto max-w-6xl px-4 md:px-8">
    <div class={`surface-panel relative overflow-hidden bg-gradient-to-r ${bgColor} px-6 py-10 text-white md:px-10 md:py-12`}>
      <div class="absolute right-[-3rem] top-[-3rem] h-32 w-32 rounded-full bg-white/10 blur-2xl"></div>
      <div class="absolute bottom-[-4rem] left-[-2rem] h-40 w-40 rounded-full bg-black/10 blur-3xl"></div>
      <div class="relative">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-100/85">
          {isHindi ? "अगला कदम" : "Next Step"}
        </p>
        <h2 class="mt-4 text-3xl font-bold md:text-4xl">
          {headline}
        </h2>
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-white/90 md:text-xl">
          {subheadline}
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          {trustPoints.map((point) => (
            <span class="inline-flex rounded-full border border-white/15 bg-white/10 px-3 py-2 text-xs font-semibold text-white/90">
              {point}
            </span>
          ))}
        </div>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href={`https://wa.me/${whatsappNumber}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-h-[3.75rem] items-center justify-center rounded-2xl bg-slate-950 px-7 py-4 text-base font-bold text-white transition hover:bg-black"
          >
            {isHindi ? "व्हाट्सऐप पर बात करें" : "Chat on WhatsApp"}
          </a>
          <a
            href={`tel:${siteConfig.phone}`}
            class="inline-flex min-h-[3.75rem] items-center justify-center rounded-2xl border border-white/20 bg-white/95 px-7 py-4 text-base font-bold text-slate-950 transition hover:bg-white"
          >
            {isHindi ? "अभी कॉल करें" : "Call Now"}: {siteConfig.phone}
          </a>
        </div>
        <p class="mt-6 text-sm opacity-90">
      {
        isHindi
          ? "हिंदी और अंग्रेजी में सहायता • बिना दबाव वाली बिक्री • वास्तविक इंजीनियरिंग जवाब"
          : "Dedicated support in Hindi/English • No pushy sales • Real engineering answers"
      }
        </p>
      </div>
    </div>
  </div>
</section>
