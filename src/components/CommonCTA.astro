---
import { commonData } from "../data/locations-i18n.js";

interface Props {
  headline?: string;
  subheadline?: string;
  bgColor?: string;
}

const {
  headline = "Ready to Stop Wasting Money on Unreliable Boring Machines?",
  subheadline = "Get a custom quote from Kanpur's most trusted manufacturer. Response in 2 hours.",
  bgColor = "from-brand-teal to-brand-green",
} = Astro.props;
---

<section class={`py-16 bg-gradient-to-r ${bgColor} text-white`}>
  <div class="container mx-auto px-4 md:px-8 max-w-6xl text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-6">
      {headline}
    </h2>
    <p class="text-xl mb-8 opacity-95 max-w-2xl mx-auto">
      {subheadline}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={`https://wa.me/${commonData.whatsapp.replace("+", "")}`}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-white text-brand-teal hover:bg-gray-100 font-bold py-4 px-8 rounded-lg text-lg transition"
      >
        💬 Chat on WhatsApp
      </a>
      <a
        href={`tel:${commonData.phone}`}
        class="bg-brand-amber text-gray-900 hover:bg-amber-600 font-bold py-4 px-8 rounded-lg text-lg transition"
      >
        📞 Call Now: {commonData.phone}
      </a>
    </div>
    <p class="mt-6 text-sm opacity-90">
      Dedicated support in Hindi/English • No pushy sales • Real engineering
      answers
    </p>
  </div>
</section>
