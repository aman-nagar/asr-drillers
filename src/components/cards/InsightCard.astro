---
interface Props {
  title: string;
  body: string;
  tone?: "danger" | "success" | "neutral";
  icon?: string;
  className?: string;
}

const {
  title,
  body,
  tone = "neutral",
  icon = tone === "danger" ? "X" : tone === "success" ? "+" : "•",
  className = "",
} = Astro.props;

const toneClasses = {
  danger:
    "border-rose-200 bg-[linear-gradient(180deg,#fff1f2_0%,#ffffff_100%)]",
  success:
    "border-emerald-200 bg-[linear-gradient(180deg,#ecfdf5_0%,#ffffff_100%)]",
  neutral:
    "border-slate-200 bg-[linear-gradient(180deg,#ffffff_0%,#f8fafc_100%)]",
};

const iconClasses = {
  danger: "bg-rose-100 text-rose-600",
  success: "bg-emerald-100 text-emerald-700",
  neutral: "bg-slate-100 text-slate-700",
};
---

<article
  class:list={[
    "surface-card border p-7 transition duration-300 hover:-translate-y-1",
    toneClasses[tone],
    className,
  ]}
>
  <div
    class:list={[
      "inline-flex h-11 w-11 items-center justify-center rounded-2xl text-lg font-bold",
      iconClasses[tone],
    ]}
  >
    {icon}
  </div>
  <h3 class="mt-5 text-xl font-bold text-slate-950">{title}</h3>
  <p class="mt-3 leading-relaxed text-slate-700">{body}</p>
</article>
