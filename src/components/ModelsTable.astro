---
import { commonData } from "../data/locations-i18n.js";
---

<!-- Models Table Component - Reusable across all pages -->
<section class="py-16 bg-white">
  <div class="container mx-auto px-4 md:px-8 max-w-6xl">
    <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center text-gray-900">
      Our Boring Machine Models
    </h2>

    <div class="overflow-x-auto">
      <table class="w-full bg-white rounded-lg overflow-hidden shadow">
        <thead class="bg-brand-teal text-white">
          <tr>
            <th class="p-4 text-left">Model</th>
            <th class="p-4 text-center">HP</th>
            <th class="p-4 text-center">Max Depth</th>
            <th class="p-4 text-center">Diameter</th>
            <th class="p-4 text-center">Fuel/Day</th>
            <th class="p-4 text-center">Price</th>
            <th class="p-4 text-center">Action</th>
          </tr>
        </thead>
        <tbody>
          {
            commonData.models.map((model, idx) => (
              <tr class={idx % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                <td class="p-4 font-semibold text-gray-900">{model.name}</td>
                <td class="p-4 text-center text-lg font-bold text-brand-teal">
                  {model.hp}
                </td>
                <td class="p-4 text-center">
                  {model.minDepth}–{model.maxDepth}
                </td>
                <td class="p-4 text-center">{model.diameter}</td>
                <td class="p-4 text-center">{model.fuelPerDay}</td>
                <td class="p-4 text-center font-bold text-green-600">
                  {model.price}
                </td>
                <td class="p-4 text-center">
                  <a
                    href={`https://wa.me/${commonData.whatsapp.replace("+", "")}?text=Interested%20in%20${model.hp}HP`}
                    class="text-brand-teal hover:text-brand-green font-semibold text-sm"
                  >
                    Quote
                  </a>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <p class="text-center text-gray-600 mt-6 text-sm">
      Click "Quote" for instant WhatsApp inquiry | Free installation & training
      included
    </p>
  </div>
</section>
