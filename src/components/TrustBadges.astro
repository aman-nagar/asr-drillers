---
import { commonData } from "../data/locations-i18n.js";
import { getLocaleFromPath } from "../lib/i18n.js";

const locale = getLocaleFromPath(Astro.url?.pathname || "/");
const isHindi = locale === "hi";
---

<section class="section-shell bg-brand-teal text-white">
  <div class="container mx-auto px-4 md:px-8 max-w-6xl">
    <div class="grid grid-cols-2 gap-5 text-center md:grid-cols-5 md:gap-6">
      <div>
        <p class="text-3xl md:text-4xl font-bold">{commonData.yearsActive}</p>
        <p class="text-sm text-teal-100 mt-1">
          {isHindi ? "निर्माण का अनुभव" : "Years Manufacturing"}
        </p>
      </div>
      <div>
        <p class="text-3xl md:text-4xl font-bold">500+</p>
        <p class="text-sm text-teal-100 mt-1">
          {isHindi ? "संतुष्ट ग्राहक" : "Happy Clients"}
        </p>
      </div>
      <div>
        <p class="text-3xl md:text-4xl font-bold">1000+</p>
        <p class="text-sm text-teal-100 mt-1">
          {isHindi ? "ड्रिल किए गए बोरवेल" : "Borewells Drilled"}
        </p>
      </div>
      <div>
        <p class="text-3xl md:text-4xl font-bold">99%</p>
        <p class="text-sm text-teal-100 mt-1">
          {isHindi ? "अपटाइम रिकॉर्ड" : "Uptime Record"}
        </p>
      </div>
      <div>
        <p class="text-3xl md:text-4xl font-bold">24/7</p>
        <p class="text-sm text-teal-100 mt-1">
          {isHindi ? "व्हाट्सऐप सहायता" : "WhatsApp Support"}
        </p>
      </div>
    </div>
  </div>
</section>
