---
import { commonData } from "../data/locations-i18n.js";
---

<section class="py-12 bg-brand-teal text-white">
  <div class="container mx-auto px-4 md:px-8 max-w-6xl">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-6 text-center">
      <div>
        <p class="text-3xl md:text-4xl font-bold">{commonData.yearsActive}</p>
        <p class="text-sm text-teal-100 mt-1">Years Manufacturing</p>
      </div>
      <div>
        <p class="text-3xl md:text-4xl font-bold">500+</p>
        <p class="text-sm text-teal-100 mt-1">Happy Clients</p>
      </div>
      <div>
        <p class="text-3xl md:text-4xl font-bold">1000+</p>
        <p class="text-sm text-teal-100 mt-1">Borewells Drilled</p>
      </div>
      <div>
        <p class="text-3xl md:text-4xl font-bold">99%</p>
        <p class="text-sm text-teal-100 mt-1">Uptime Record</p>
      </div>
      <div>
        <p class="text-3xl md:text-4xl font-bold">24/7</p>
        <p class="text-sm text-teal-100 mt-1">WhatsApp Support</p>
      </div>
    </div>
  </div>
</section>
