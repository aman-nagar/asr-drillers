---
import { siteConfig } from "../config/site";
import { getLocaleFromPath } from "../lib/i18n";

const isHindi = getLocaleFromPath(Astro.url?.pathname || "/") === "hi";

const trustItems = [
  {
    icon: "🏭",
    label: isHindi ? "14+ वर्षों का अनुभव" : "14+ Years Experience",
    value: isHindi ? `सन् ${siteConfig.foundingYear} से` : `Since ${siteConfig.foundingYear}`,
  },
  {
    icon: "👥",
    label: isHindi ? "500+ संतुष्ट ग्राहक" : "500+ Happy Customers",
    value: isHindi ? "पूरे भारत में" : "Across India",
  },
  {
    icon: "⭐",
    label: isHindi ? "4.8/5 ग्राहक रेटिंग" : "4.8/5 Customer Rating",
    value: isHindi ? "ग्राहक समीक्षा" : "Customer Reviews",
  },
  {
    icon: "🏆",
    label: isHindi ? "ISO 9001 प्रमाणित" : "ISO 9001 Certified",
    value: isHindi ? "गुणवत्ता आश्वासन" : "Quality Assured",
  },
  {
    icon: "🚚",
    label: isHindi ? "भारत भर में डिलीवरी" : "Delivery Across India",
    value: isHindi ? "पैन इंडिया" : "Pan India",
  },
  {
    icon: "📞",
    label: isHindi ? "24/7 समर्थन" : "24/7 Support",
    value: isHindi ? "व्हाट्सऐप" : "WhatsApp",
  },
];
---

<div class="border-y border-slate-800 bg-[linear-gradient(135deg,#081c1f_0%,#0f172a_48%,#0b3b36_100%)] py-3">
  <div class="container mx-auto max-w-7xl px-4 md:px-8">
    <div class="flex snap-x gap-3 overflow-x-auto pb-1 md:flex-wrap md:justify-between md:overflow-visible">
      {trustItems.map((item) => (
        <div class="min-w-[13rem] snap-start rounded-2xl border border-white/10 bg-white/6 px-3 py-3 text-white backdrop-blur-sm md:min-w-0 md:flex-1">
          <div class="flex items-center gap-3">
            <span class="text-xl md:text-2xl">{item.icon}</span>
            <div class="flex flex-col">
              <span class="text-sm font-semibold leading-tight">{item.label}</span>
              <span class="text-xs text-slate-300">{item.value}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
