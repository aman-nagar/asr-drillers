---
import SectionHeading from "./sections/SectionHeading.astro";

interface Props {
  testimonials: Array<{
    name: string;
    location: string;
    role: string;
    text: string;
    rating: number;
    project?: string;
  }>;
  title?: string;
  subtitle?: string;
  sectionClass?: string;
}

const {
  testimonials,
  title = "What Our Clients Say",
  subtitle = "Real results from real boring professionals across India",
  sectionClass = "section-shell section-tint",
} = Astro.props;
---

<section class={sectionClass}>
  <div class="container mx-auto px-4 md:px-8 max-w-6xl">
    <SectionHeading title={title} subtitle={subtitle} />

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        testimonials.map((testimonial, index) => (
          <article
            class:list={[
              "surface-card relative overflow-hidden border border-slate-200 p-7 transition duration-300 hover:-translate-y-1 hover:shadow-[0_30px_70px_rgba(15,23,42,0.12)] md:p-8",
              index === 0
                ? "bg-[linear-gradient(135deg,#0f172a_0%,#0f766e_100%)] text-white xl:col-span-2"
                : "bg-white",
            ]}
          >
            <div class="absolute inset-x-0 top-0 h-1.5 bg-[linear-gradient(90deg,#0f766e,#84cc16)]"></div>
            <div class="absolute right-5 top-5 text-6xl font-bold leading-none text-white/8">
              "
            </div>

            <div class="mb-5 flex items-start justify-between gap-4">
              <div class="flex items-center gap-4">
              <div class:list={[
                "flex h-12 w-12 items-center justify-center rounded-2xl",
                index === 0 ? "bg-white/12" : "bg-brand-teal/12",
              ]}>
                <span class:list={["font-bold text-lg", index === 0 ? "text-white" : "text-brand-teal"]}>
                  {testimonial.name.charAt(0)}
                </span>
              </div>
              <div>
                <p class:list={["font-bold", index === 0 ? "text-white" : "text-gray-900"]}>{testimonial.name}</p>
                <p class:list={["text-sm", index === 0 ? "text-emerald-100/85" : "text-gray-600"]}>{testimonial.location}</p>
                <p class:list={["text-xs italic", index === 0 ? "text-slate-200/80" : "text-gray-500"]}>{testimonial.role}</p>
              </div>
              </div>
              <div class:list={[
                "inline-flex rounded-full px-3 py-1 text-xs font-semibold",
                index === 0 ? "bg-white/10 text-white" : "bg-amber-50 text-amber-700",
              ]}>
                {"★".repeat(testimonial.rating)}
              </div>
            </div>

            <p class:list={[
              "mb-5 leading-relaxed",
              index === 0 ? "max-w-2xl text-slate-100" : "text-slate-700",
            ]}>
              "{testimonial.text}"
            </p>

            <div class="flex flex-wrap items-center justify-between gap-3">
              {testimonial.project ? (
                <p class:list={[
                  "inline-flex rounded-full px-3 py-1 text-sm font-semibold",
                  index === 0 ? "bg-white/10 text-emerald-100" : "bg-emerald-50 text-emerald-700",
                ]}>
                  + {testimonial.project}
                </p>
              ) : <span></span>}

              <p class:list={[
                "text-xs font-semibold uppercase tracking-[0.18em]",
                index === 0 ? "text-slate-200/75" : "text-slate-500",
              ]}>
                {testimonial.role}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
