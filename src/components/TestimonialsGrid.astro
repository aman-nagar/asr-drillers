---
import SectionHeading from "./sections/SectionHeading.astro";

interface Props {
  testimonials: Array<{
    name: string;
    location: string;
    role: string;
    text: string;
    rating: number;
    project?: string;
  }>;
  title?: string;
  subtitle?: string;
  sectionClass?: string;
}

const {
  testimonials,
  title = "What Our Clients Say",
  subtitle = "Real results from real boring professionals across India",
  sectionClass = "py-16 bg-gray-50",
} = Astro.props;
---

<section class={sectionClass}>
  <div class="container mx-auto px-4 md:px-8 max-w-6xl">
    <SectionHeading title={title} subtitle={subtitle} />

    <div class="grid md:grid-cols-3 gap-8">
      {
        testimonials.map((testimonial) => (
          <article class="surface-card relative overflow-hidden border border-slate-200 bg-white p-8 transition duration-300 hover:-translate-y-1 hover:shadow-[0_30px_70px_rgba(15,23,42,0.12)]">
            <div class="absolute inset-x-0 top-0 h-1.5 bg-[linear-gradient(90deg,#0f766e,#84cc16)]"></div>
            <div class="flex items-center gap-4 mb-4">
              <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-brand-teal/12">
                <span class="text-brand-teal font-bold text-lg">
                  {testimonial.name.charAt(0)}
                </span>
              </div>
              <div>
                <p class="font-bold text-gray-900">{testimonial.name}</p>
                <p class="text-sm text-gray-600">{testimonial.location}</p>
                <p class="text-xs text-gray-500 italic">{testimonial.role}</p>
              </div>
            </div>

            <p class="mb-4 leading-relaxed text-slate-700">
              "{testimonial.text}"
            </p>

            {testimonial.project && (
              <p class="mb-4 inline-flex rounded-full bg-emerald-50 px-3 py-1 text-sm font-semibold text-emerald-700">
                + {testimonial.project}
              </p>
            )}

            <p class="font-semibold text-amber-500">
              {"★".repeat(testimonial.rating)}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
