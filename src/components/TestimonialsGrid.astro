---
interface Props {
  testimonials: Array<{
    name: string;
    location: string;
    role: string;
    text: string;
    rating: number;
    project?: string;
  }>;
  title?: string;
}

const { testimonials, title = "What Our Clients Say" } = Astro.props;
---

<section class="py-16 bg-gray-50">
  <div class="container mx-auto px-4 md:px-8 max-w-6xl">
    <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center text-gray-900">
      {title}
    </h2>
    <p class="text-center text-gray-600 mb-12 text-lg max-w-3xl mx-auto">
      Real results from real boring professionals across India
    </p>

    <div class="grid md:grid-cols-3 gap-8">
      {
        testimonials.map((testimonial) => (
          <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition border-t-4 border-brand-teal">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 bg-brand-teal bg-opacity-20 rounded-full flex items-center justify-center">
                <span class="text-brand-teal font-bold text-lg">
                  {testimonial.name.charAt(0)}
                </span>
              </div>
              <div>
                <p class="font-bold text-gray-900">{testimonial.name}</p>
                <p class="text-sm text-gray-600">{testimonial.location}</p>
                <p class="text-xs text-gray-500 italic">{testimonial.role}</p>
              </div>
            </div>

            <p class="text-gray-700 mb-4 leading-relaxed">
              "{testimonial.text}"
            </p>

            {testimonial.project && (
              <p class="text-sm text-brand-teal font-semibold mb-3">
                ✓ {testimonial.project}
              </p>
            )}

            <p class="text-yellow-500 font-semibold">
              {"★".repeat(testimonial.rating)}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
