---
import { siteConfig, getWhatsAppNumber } from "../config/site";
import {
  footerBottomLinks,
  footerCompanyLinks,
  footerLocationLinks,
} from "../data/navigation";
import { getLocaleFromPath, withLocalePrefix } from "../lib/i18n";

const currentPath = Astro.url?.pathname || "/";
const locale = getLocaleFromPath(currentPath);
const isHindi = locale === "hi";
const whatsappNumber = getWhatsAppNumber();
---

<footer class="bg-[linear-gradient(180deg,#0f172a_0%,#081117_100%)] text-slate-100">
  <div class="container mx-auto px-4 md:px-6 max-w-7xl">
    <!-- Main Footer Grid -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 py-12 md:py-16 border-b-2 border-slate-800"
    >
      <!-- Company Info -->
      <div class="space-y-4">
        <div class="flex items-center gap-3 mb-6">
          <img
            src={siteConfig.logoPath}
            alt="ASR Drillers"
            class="h-12 w-12 rounded-2xl border border-white/10 bg-white p-1.5 shadow-[0_16px_35px_rgba(15,118,110,0.15)]"
          />
          <div>
            <h3 class="text-xl font-bold text-white">ASR Drillers</h3>
            <p
              class="text-xs font-semibold text-brand-teal uppercase tracking-widest"
            >
              {isHindi ? "भरोसेमंद ड्रिलिंग" : "Boring Excellence"}
            </p>
          </div>
        </div>
        <p class="text-sm leading-relaxed text-slate-300">
          {
            isHindi
              ? "भारत में बोरिंग मशीनों के अग्रणी निर्माता। 14+ वर्षों का अनुभव, 500+ संतुष्ट ग्राहक।"
              : "Leading boring machine manufacturer in India. 14+ years of excellence, 500+ happy customers."
          }
        </p>
        <div class="flex gap-3 pt-2">
          <a
            href={`tel:${siteConfig.phone}`}
            class="inline-flex items-center gap-2 text-sm font-semibold text-brand-teal hover:text-brand-green transition-colors"
          >
            <span>📞</span>
            {siteConfig.phone}
          </a>
        </div>
      </div>

      <!-- Quick Links - Locations -->
      <div class="space-y-4">
        <h4 class="text-lg font-bold text-white">
          {isHindi ? "स्थान" : "Locations"}
        </h4>
        <nav class="flex flex-col gap-2.5">
          {
            footerLocationLinks.map((link) => (
              <a
                href={withLocalePrefix(link.path, locale)}
                class="text-sm text-slate-300 hover:text-brand-teal hover:translate-x-1 transition-all font-semibold"
              >
                ➜ {link.label[locale]}
              </a>
            ))
          }
        </nav>
      </div>

      <!-- Quick Links - Company -->
      <div class="space-y-4">
        <h4 class="text-lg font-bold text-white">
          {isHindi ? "कंपनी" : "Company"}
        </h4>
        <nav class="flex flex-col gap-2.5">
          {
            footerCompanyLinks.map((link) => (
              <a
                href={withLocalePrefix(link.path, locale)}
                class="text-sm text-slate-300 hover:text-brand-teal hover:translate-x-1 transition-all font-semibold"
              >
                ➜ {link.label[locale]}
              </a>
            ))
          }
        </nav>
      </div>

      <!-- Quick Links - Support -->
      <div class="space-y-4">
        <h4 class="text-lg font-bold text-white">
          {isHindi ? "सहायता" : "Support"}
        </h4>
        <div class="space-y-3">
          <a
            href={`tel:${siteConfig.phone}`}
            class="flex items-center gap-3 rounded-2xl border border-white/5 bg-white/5 p-3 transition-colors group hover:bg-brand-teal/20"
          >
            <span class="text-2xl">📞</span>
            <div>
              <p class="text-xs font-semibold text-slate-400">
                {isHindi ? "कॉल करें" : "Call Now"}
              </p>
              <p
                class="text-sm font-bold text-brand-teal group-hover:text-brand-green"
              >
                {siteConfig.phone}
              </p>
            </div>
          </a>
          <a
            href={`https://wa.me/${whatsappNumber}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 rounded-2xl bg-brand-green p-3 font-bold text-white transition-colors hover:bg-brand-green/90"
          >
            <span class="text-2xl">💬</span>
            <span>{isHindi ? "व्हाट्सऐप पर बात करें" : "Chat on WhatsApp"}</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Footer -->
    <div class="py-8 md:py-10 border-t-2 border-slate-800">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-3">
          <p class="text-sm text-slate-400">
            {
              isHindi
                ? `© ${siteConfig.foundingYear}-${new Date().getFullYear()} ASR Drillers. सर्वाधिकार सुरक्षित।`
                : `© ${siteConfig.foundingYear}-${new Date().getFullYear()} ASR Drillers. All rights reserved.`
            }
          </p>
          <p class="text-xs text-slate-500">
            {
              isHindi
                ? "भारत में निर्मित, विश्व-स्तरीय गुणवत्ता के साथ"
                : "Made in India, with world-class quality"
            }
          </p>
        </div>
        <div class="flex gap-4 md:justify-end">
          {
            footerBottomLinks.map((link) => (
              <a
                href={withLocalePrefix(link.path, locale)}
                class="text-sm text-slate-400 hover:text-brand-teal transition-colors font-semibold"
              >
                {link.label[locale]}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</footer>
