---
import { commonData } from "../data/locations-i18n.js";
const { phone, whatsapp } = commonData;
---

<footer class="bg-gray-900 text-gray-400 py-12">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="grid md:grid-cols-4 gap-8">
      <div>
        <h3 class="text-white text-xl font-bold mb-4">ASR Drillers</h3>
        <p class="text-sm">
          Premium Tubewell Boring Machines<br />Kanpur, Uttar Pradesh
        </p>
        <p class="mt-4 text-xs">GST: 09XXXXXXXXXXXXXX</p>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4">Quick Links</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/kanpur" class="hover:text-white">Kanpur</a></li>
          <li><a href="/lucknow" class="hover:text-white">Lucknow</a></li>
          <li><a href="/bihar" class="hover:text-white">Bihar</a></li>
          <li><a href="/kolkata" class="hover:text-white">Kolkata</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4">Support</h4>
        <p class="text-sm">
          24/7 WhatsApp: <a
            href={`https://wa.me/${whatsapp}`}
            class="text-teal-400 hover:text-teal-300">{phone}</a
          >
        </p>
        <p class="text-sm mt-2">Factory Address: Pukhrayan, Kanpur, UP</p>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4">Get In Touch</h4>
        <a
          href={`https://wa.me/${whatsapp}`}
          class="block bg-green-600 hover:bg-green-700 text-white text-center py-4 rounded-lg font-semibold"
        >
          💬 Message on WhatsApp Now
        </a>
      </div>
    </div>

    <div class="text-center text-xs mt-12 pt-8 border-t border-gray-800">
      © 2026 ASR Drillers • Best Boring Machine Manufacturer in India
    </div>
  </div>
</footer>
