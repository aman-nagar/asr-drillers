---
import CommonCTA from "../CommonCTA.astro";
import PageHero from "../sections/PageHero.astro";
import SectionHeading from "../sections/SectionHeading.astro";
import SignalStrip from "../sections/SignalStrip.astro";
import Layout from "../../layouts/Layout.astro";
import { getWhatsAppNumber, siteConfig } from "../../config/site";

interface SignalItem {
  value: string;
  label: string;
  note?: string;
}

interface HeroSignal {
  value: string;
  label: string;
}

interface ShowcaseItem {
  title: string;
  category: string;
  summary: string;
  imageUrl: string;
  featured?: boolean;
}

interface ChipItem {
  title: string;
  value: string;
  description: string;
}

interface ModelItem {
  name: string;
  price: string;
  depth: string;
  bestFor: string;
  highlights: string[];
  imageUrl: string;
}

interface StoryItem {
  title: string;
  quote: string;
  author: string;
  tag: string;
}

interface GalleryContent {
  pageTitle: string;
  pageDescription: string;
  hero: {
    eyebrow: string;
    title: string;
    description: string;
    primaryActionLabel: string;
    secondaryActionLabel: string;
    whatsappMessage?: string;
    signals: HeroSignal[];
    visualTitle: string;
    visualLines: string[];
  };
  stripItems: SignalItem[];
  categorySection: {
    title: string;
    subtitle: string;
    chips: ChipItem[];
  };
  showcaseSection: {
    title: string;
    subtitle: string;
    items: ShowcaseItem[];
  };
  modelsSection: {
    title: string;
    subtitle: string;
    quoteLabel: string;
    items: ModelItem[];
  };
  storiesSection: {
    title: string;
    subtitle: string;
    items: StoryItem[];
  };
  cta: {
    headline: string;
    subheadline: string;
  };
}

interface Props {
  content: GalleryContent;
}

const { content } = Astro.props;
const whatsappNumber = getWhatsAppNumber();
const heroMessage =
  content.hero.whatsappMessage ??
  "Hi! I want to review machine photos and field examples.";
---

<Layout title={content.pageTitle} description={content.pageDescription}>
  <PageHero
    eyebrow={content.hero.eyebrow}
    title={content.hero.title}
    description={content.hero.description}
    signals={content.hero.signals}
    visualTitle={content.hero.visualTitle}
    visualLines={content.hero.visualLines}
    actions={[
      {
        href: `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(heroMessage)}`,
        label: content.hero.primaryActionLabel,
        variant: "primary",
        external: true,
      },
      {
        href: `tel:${siteConfig.phone}`,
        label: content.hero.secondaryActionLabel,
        variant: "secondary",
      },
    ]}
  />

  <SignalStrip items={content.stripItems} sectionClass="bg-slate-950 py-8 md:py-10" />

  <section class="section-shell section-tint">
    <div class="container mx-auto max-w-6xl px-4 md:px-8">
      <div class="surface-panel border border-slate-200/80 bg-white/90 p-6 shadow-[0_30px_90px_rgba(15,23,42,0.08)] md:p-8">
        <SectionHeading
          title={content.categorySection.title}
          subtitle={content.categorySection.subtitle}
        />

        <div class="grid gap-6 md:grid-cols-3">
          {content.categorySection.chips.map((chip, index) => (
            <article
              class:list={[
                "surface-card border p-7",
                index === 0
                  ? "border-slate-900 bg-[linear-gradient(135deg,#0f172a_0%,#0f766e_100%)] text-white md:col-span-2"
                  : "border-slate-200 bg-white",
              ]}
            >
              <p class:list={[
                "text-xs font-semibold uppercase tracking-[0.22em]",
                index === 0 ? "text-emerald-100/80" : "text-brand-teal",
              ]}>
                {chip.title}
              </p>
              <h3 class:list={[
                "mt-4 text-3xl font-bold",
                index === 0 ? "text-white md:text-4xl" : "text-slate-950",
              ]}>{chip.value}</h3>
              <p class:list={[
                "mt-4 leading-relaxed",
                index === 0 ? "max-w-2xl text-slate-100" : "text-slate-700",
              ]}>{chip.description}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell bg-white">
    <div class="container mx-auto max-w-6xl px-4 md:px-8">
      <SectionHeading
        title={content.showcaseSection.title}
        subtitle={content.showcaseSection.subtitle}
      />

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {content.showcaseSection.items.map((item, index) => (
          <article
            class:list={[
              "surface-card group relative overflow-hidden border border-slate-200 bg-slate-950 text-white",
              item.featured ? "xl:col-span-2" : "",
              index === 0 ? "min-h-[24rem]" : "",
            ]}
          >
            <div
              class:list={[
                "bg-cover bg-center transition duration-500 group-hover:scale-[1.02]",
                index === 0 ? "min-h-[24rem]" : "min-h-[20rem]",
              ]}
              style={`background-image:url('${item.imageUrl}')`}
            >
              <div
                class:list={[
                  "flex flex-col justify-between bg-[linear-gradient(180deg,rgba(2,6,23,0.1)_0%,rgba(2,6,23,0.9)_100%)] p-6",
                  index === 0 ? "min-h-[24rem]" : "min-h-[20rem]",
                ]}
              >
                <div class="flex items-start justify-between gap-3">
                  <span class="inline-flex rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-white/90">
                    {item.category}
                  </span>
                  <span class="rounded-full bg-white/10 px-3 py-1 text-xs text-white/80">
                    Photo slot
                  </span>
                </div>
                <div>
                  <h3 class:list={["font-bold", index === 0 ? "text-3xl md:text-4xl" : "text-2xl"]}>
                    {item.title}
                  </h3>
                  <p class="mt-3 max-w-2xl text-sm leading-relaxed text-slate-100">
                    {item.summary}
                  </p>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell bg-white">
    <div class="container mx-auto max-w-6xl px-4 md:px-8">
      <div class="surface-panel overflow-hidden border border-slate-200 bg-slate-950 text-white">
        <div class="border-b border-white/10 bg-[radial-gradient(circle_at_top_left,rgba(45,212,191,0.18),transparent_46%)] px-6 py-8 md:px-8">
          <SectionHeading
            title={content.modelsSection.title}
            subtitle={content.modelsSection.subtitle}
            titleClass="text-white"
            subtitleClass="text-slate-300"
          />
        </div>

        <div class="grid gap-6 p-6 md:p-8 lg:grid-cols-3">
          {content.modelsSection.items.map((item, index) => (
            <article
              class:list={[
                "surface-card overflow-hidden border bg-[linear-gradient(180deg,#ffffff_0%,#f8fafc_100%)] text-slate-900",
                index === 1 ? "border-emerald-300" : "border-slate-200",
              ]}
            >
              <div
                class="h-52 bg-cover bg-center"
                style={`background-image:url('${item.imageUrl}')`}
              ></div>
              <div class="p-6">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">
                    {item.price}
                  </span>
                  <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
                    {item.depth}
                  </span>
                </div>
                <h3 class="mt-4 text-2xl font-bold text-slate-950">{item.name}</h3>
                <p class="mt-3 text-sm leading-relaxed text-slate-700">{item.bestFor}</p>
                <ul class="mt-5 space-y-2 text-sm text-slate-700">
                  {item.highlights.map((highlight) => (
                    <li class="flex items-start gap-2">
                      <span class="mt-0.5 text-emerald-600">+</span>
                      <span>{highlight}</span>
                    </li>
                  ))}
                </ul>
                <a
                  href={`https://wa.me/${whatsappNumber}?text=${encodeURIComponent(`${heroMessage} ${item.name}`)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-6 inline-flex w-full items-center justify-center rounded-2xl bg-slate-950 px-5 py-3 text-sm font-bold text-white transition hover:bg-brand-teal"
                >
                  {content.modelsSection.quoteLabel}
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell bg-[linear-gradient(180deg,#0f172a_0%,#111827_100%)] text-white">
    <div class="container mx-auto max-w-6xl px-4 md:px-8">
      <SectionHeading
        title={content.storiesSection.title}
        subtitle={content.storiesSection.subtitle}
        titleClass="text-white"
        subtitleClass="text-slate-300"
      />

      <div class="grid gap-6 md:grid-cols-3">
        {content.storiesSection.items.map((item, index) => (
          <article
            class:list={[
              "surface-card border p-7",
              index === 0
                ? "border-white/10 bg-white/10 backdrop-blur"
                : "border-white/10 bg-white/[0.04]",
            ]}
          >
            <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-white">
              {item.tag}
            </span>
            <h3 class="mt-5 text-2xl font-bold text-white">{item.title}</h3>
            <p class="mt-4 leading-relaxed text-slate-200">{item.quote}</p>
            <p class="mt-5 text-sm font-semibold text-emerald-200">{item.author}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CommonCTA
    headline={content.cta.headline}
    subheadline={content.cta.subheadline}
  />
</Layout>
