---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../Breadcrumbs.astro";
import CommonCTA from "../CommonCTA.astro";
import FAQSection from "../FAQSection.astro";
import LocalProblemsSolutions from "../LocalProblemsSolutions.astro";
import ModelsTable from "../ModelsTable.astro";
import TestimonialsGrid from "../TestimonialsGrid.astro";
import TrustBadges from "../TrustBadges.astro";
import PageHero from "../sections/PageHero.astro";
import SectionHeading from "../sections/SectionHeading.astro";
import SignalStrip from "../sections/SignalStrip.astro";
import { getAbsoluteUrl, getWhatsAppNumber, siteConfig } from "../../config/site";
import type { Locale } from "../../lib/i18n";

interface FAQItem {
  question: string;
  answer: string;
}

interface LocationContentBlock {
  title: string;
  description: string;
  heroHeadline: string;
  localProblems?: Array<{ title: string; desc: string }>;
  localSolutions?: Array<{ title: string; desc: string }>;
  localTestimonials?: Array<{
    name: string;
    location: string;
    role: string;
    text: string;
    rating: number;
    project?: string;
  }>;
  shippingInfo?: string;
  areaServed?: string[];
}

interface Props {
  locale: Locale;
  location: string;
  pageData: LocationContentBlock;
  faqItems: FAQItem[];
}

const { locale, location, pageData, faqItems } = Astro.props;
const isHindi = locale === "hi";
const locationPath = isHindi ? `/hi/${location}` : `/${location}`;
const pageTitle = isHindi
  ? `${pageData.title} | ASR Drillers - बोरिंग मशीनें`
  : `${pageData.title} | ASR Drillers - Boring Machines`;
const pageDescription = pageData.description;
const breadcrumbs = [{ label: pageData.title, href: locationPath }];
const whatsappNumber = getWhatsAppNumber();
const heroMessage = isHindi
  ? `नमस्ते! मुझे ${pageData.title} में बोरिंग मशीनों के बारे में जानना है। कृपया विवरण साझा करें।`
  : `Hi! I'm interested in boring machines in ${pageData.title}. Please share details.`;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${getAbsoluteUrl(locationPath)}/#localbusiness`,
  name: `${siteConfig.name} - ${pageData.title}`,
  image: getAbsoluteUrl(siteConfig.logoPath),
  description: pageData.description,
  url: getAbsoluteUrl(locationPath),
  address: {
    "@type": "PostalAddress",
    addressLocality: pageData.title,
    addressRegion: "Uttar Pradesh",
    addressCountry: "IN",
  },
  telephone: siteConfig.phone,
  areaServed: pageData.areaServed,
  priceRange: "₹450000-₹750000",
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
    opens: "08:00",
    closes: "20:00",
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

const copy = {
  eyebrow: isHindi ? `${pageData.title} के लिए सेवा कवरेज` : `Service coverage for ${pageData.title}`,
  heroPrimary: isHindi ? "व्हाट्सऐप पर संपर्क करें" : "WhatsApp Now",
  heroSecondary: isHindi ? "कॉल करें" : "Get Quote",
  problemsTitle: isHindi ? "आपकी ड्रिलिंग चुनौतियां" : "Your Drilling Challenges",
  solutionsTitle: isHindi ? "ASR Drillers समाधान" : "ASR Drillers Solution",
  productsTitle: isHindi ? "हमारी सर्वश्रेष्ठ बोरिंग मशीनें" : "Our Best-Selling Boring Machines",
  productsSubtitle: isHindi
    ? "भारतीय इलाके के लिए डिज़ाइन की गई पेशेवर-ग्रेड मशीनें"
    : "Professional-grade machines designed for Indian terrain",
  testimonialsTitle: isHindi
    ? `${pageData.title} में सफलता की कहानियाँ`
    : `Success Stories from ${pageData.title}`,
  testimonialsSubtitle: isHindi
    ? `${pageData.title} के ठेकेदारों और किसानों से असली प्रतिक्रिया`
    : `Real feedback from contractors and farmers in ${pageData.title}`,
  shippingTitle: isHindi
    ? `${pageData.title} में डिलीवरी और समर्थन`
    : `Delivery & Support in ${pageData.title}`,
  faqTitle: isHindi
    ? "हमारी बोरिंग मशीनों के बारे में आम प्रश्न"
    : "Common Questions About Our Boring Machines",
  ctaHeadline: isHindi
    ? `${pageData.title} में शुरुआत करने के लिए तैयार?`
    : `Ready to Get Started in ${pageData.title}?`,
  ctaSubheadline: isHindi
    ? "कानपुर के विश्वस्त निर्माता से कस्टम उद्धरण प्राप्त करें। हम आपके क्षेत्र में तेज़ डिलीवरी और स्थल पर समर्थन के साथ सेवा देते हैं।"
    : "Get a custom quote from Kanpur's trusted manufacturer. We serve your area with quick delivery and on-site support.",
};

const heroSignals = [
  {
    value: isHindi ? "2-5 दिन" : "2-5 Days",
    label: isHindi ? "डिलीवरी विंडो" : "Delivery Window",
  },
  {
    value: "22-38 HP",
    label: isHindi ? "उपलब्ध मॉडल" : "Machine Range",
  },
  {
    value: isHindi ? "24/7" : "24/7",
    label: isHindi ? "व्हाट्सऐप सहायता" : "WhatsApp Support",
  },
];

const stripItems = [
  {
    value: isHindi ? "उत्तर भारत" : "North India",
    label: isHindi ? "सर्विस रीच" : "Service Reach",
    note: isHindi ? "फैक्टरी से फील्ड समर्थन" : "Factory-backed field support",
  },
  {
    value: "₹4.8-7.2L",
    label: isHindi ? "मूल्य सीमा" : "Price Band",
    note: isHindi ? "मॉडल के अनुसार" : "Based on machine model",
  },
  {
    value: isHindi ? "स्थल पर" : "On-Site",
    label: isHindi ? "स्थापन" : "Installation",
    note: isHindi ? "ऑपरेटर प्रशिक्षण के साथ" : "Operator training included",
  },
  {
    value: isHindi ? "1-2 वर्ष" : "1-2 Years",
    label: isHindi ? "वारंटी" : "Warranty",
    note: isHindi ? "निर्माण दोषों पर" : "Manufacturing-defect cover",
  },
];

const supportChecks = isHindi
  ? [
      "मॉडल चयन के लिए फैक्टरी मार्गदर्शन",
      "व्हाट्सऐप पर तेज़ जवाब",
      "डिलीवरी और इंस्टॉलेशन समन्वय",
      "हिंदी और अंग्रेजी दोनों में सहायता",
    ]
  : [
      "Factory guidance for machine selection",
      "Fast responses on WhatsApp",
      "Delivery and installation coordination",
      "Support in both Hindi and English",
    ];

const localRouteSteps = isHindi
  ? [
      {
        title: "1. आवश्यकता साझा करें",
        body: `${pageData.title} या आसपास के क्षेत्र, गहराई और उपयोग की जानकारी भेजें।`,
      },
      {
        title: "2. मॉडल सुझाव",
        body: "हम workload और terrain के हिसाब से उपयुक्त मशीन लेवल शॉर्टलिस्ट करते हैं।",
      },
      {
        title: "3. डिलीवरी और सपोर्ट",
        body: "डिस्पैच, इंस्टॉलेशन और शुरुआती गाइडेंस में सीधे सहायता मिलती है।",
      },
    ]
  : [
      {
        title: "1. Share your requirement",
        body: `Send your location around ${pageData.title}, depth target, and use case.`,
      },
      {
        title: "2. Get model guidance",
        body: "We shortlist the right machine level based on workload and terrain.",
      },
      {
        title: "3. Plan delivery and support",
        body: "You get direct help with dispatch, installation, and early guidance.",
      },
    ];
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <Breadcrumbs breadcrumbs={breadcrumbs} />

  <PageHero
    eyebrow={copy.eyebrow}
    title={pageData.heroHeadline}
    description={pageData.description}
    signals={heroSignals}
    visualTitle={isHindi ? "फैक्टरी से फील्ड रेडी सपोर्ट" : "Factory-to-field support"}
    visualLines={[
      isHindi
        ? `${pageData.title} के लिए तेज़ सपोर्ट और स्पेयर उपलब्धता`
        : `Fast support and spare-part access for ${pageData.title}`,
      isHindi
        ? "ठेकेदारों और किसानों के लिए उपयुक्त मॉडल गाइडेंस"
        : "Model guidance for both contractors and farmers",
      isHindi
        ? "हिंदी और अंग्रेजी में सीधे संपर्क"
        : "Direct contact in both Hindi and English",
    ]}
    actions={[
      {
        href: `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(heroMessage)}`,
        label: copy.heroPrimary,
        variant: "primary",
        external: true,
      },
      {
        href: `tel:${siteConfig.phone}`,
        label: copy.heroSecondary,
        variant: "secondary",
      },
    ]}
  />

  <SignalStrip items={stripItems} sectionClass="bg-slate-950 py-10" />

  <TrustBadges />

  <section class="section-shell section-tint">
    <div class="container mx-auto max-w-6xl px-4 md:px-8">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(300px,0.9fr)]">
        <div class="surface-panel border border-slate-200 bg-white/90 p-6 md:p-8">
          <SectionHeading
            title={copy.shippingTitle}
            subtitle={isHindi ? "स्थानीय खरीदारों के लिए तेज़, स्पष्ट और भरोसेमंद समर्थन" : "Fast, clear, and dependable support for local buyers"}
            align="left"
          />

          <div class="grid gap-4 sm:grid-cols-2">
            {stripItems.map((item) => (
              <div class="surface-card border border-slate-200 bg-white px-4 py-4">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
                  {item.label}
                </p>
                <p class="mt-3 text-2xl font-bold text-slate-950">{item.value}</p>
                {item.note && <p class="mt-2 text-sm text-slate-600">{item.note}</p>}
              </div>
            ))}
          </div>
        </div>

        <aside class="surface-panel border border-slate-200 bg-slate-950 p-6 text-white md:p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-emerald-200/80">
            {isHindi ? "स्थानीय सेवा वादा" : "Local Service Promise"}
          </p>
          <h3 class="mt-4 text-3xl font-bold">
            {isHindi ? `${pageData.title} के लिए फील्ड-रेडी सहायता` : `Field-ready help for ${pageData.title}`}
          </h3>
          <div class="mt-6 space-y-3">
            {supportChecks.map((item) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-100">
                {item}
              </div>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-shell bg-white">
    <div class="container mx-auto max-w-6xl px-4 md:px-8">
      <div class="surface-panel overflow-hidden border border-slate-200 bg-[linear-gradient(135deg,#ffffff_0%,#f8fafc_100%)]">
        <div class="grid gap-6 p-6 md:p-8 lg:grid-cols-[minmax(0,1fr)_minmax(320px,0.92fr)]">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-teal">
              {isHindi ? "लोकल खरीद मार्ग" : "Local Buying Route"}
            </p>
            <h2 class="mt-4 text-3xl font-bold text-slate-950">
              {isHindi
                ? `${pageData.title} के खरीदारों के लिए एक सरल, स्पष्ट प्रक्रिया`
                : `A simpler buying process for buyers in ${pageData.title}`}
            </h2>
            <div class="mt-6 grid gap-4">
              {localRouteSteps.map((step) => (
                <div class="rounded-2xl border border-slate-200 bg-white px-5 py-4">
                  <p class="font-bold text-slate-950">{step.title}</p>
                  <p class="mt-2 text-sm leading-relaxed text-slate-700">{step.body}</p>
                </div>
              ))}
            </div>
          </div>

          <aside class="surface-card border border-slate-200 bg-slate-950 p-6 text-white">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-emerald-200/80">
              {isHindi ? "एरिया कवर" : "Area Covered"}
            </p>
            <div class="mt-4 flex flex-wrap gap-3">
              {(pageData.areaServed ?? [pageData.title]).map((area) => (
                <span class="inline-flex rounded-full border border-white/10 bg-white/10 px-4 py-2 text-sm font-semibold text-white">
                  {area}
                </span>
              ))}
            </div>
            <div class="mt-6 space-y-3">
              {supportChecks.map((item) => (
                <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-100">
                  {item}
                </div>
              ))}
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>

  {pageData.localProblems && pageData.localSolutions && (
    <LocalProblemsSolutions
      problems={pageData.localProblems}
      solutions={pageData.localSolutions}
      problemsTitle={copy.problemsTitle}
      solutionsTitle={copy.solutionsTitle}
    />
  )}

  <ModelsTable title={copy.productsTitle} subtitle={copy.productsSubtitle} />

  {pageData.localTestimonials && pageData.localTestimonials.length > 0 && (
    <TestimonialsGrid
      testimonials={pageData.localTestimonials}
      title={copy.testimonialsTitle}
      subtitle={copy.testimonialsSubtitle}
      sectionClass="section-shell bg-white"
    />
  )}

  {pageData.shippingInfo && (
    <section class="section-shell bg-white">
      <div class="container mx-auto max-w-6xl px-4 md:px-8">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(280px,0.95fr)]">
          <div class="surface-panel border border-slate-200 bg-[linear-gradient(180deg,#ffffff_0%,#f8fafc_100%)] p-6 md:p-8">
            <SectionHeading title={copy.shippingTitle} align="left" />
            <p class="text-base leading-relaxed text-slate-700 md:text-lg">
              {pageData.shippingInfo}
            </p>
          </div>

          <div class="surface-panel border border-slate-200 bg-white p-6 md:p-8">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">
              {isHindi ? "एरिया कवरेज" : "Area Coverage"}
            </p>
            <div class="mt-4 flex flex-wrap gap-3">
              {(pageData.areaServed ?? [pageData.title]).map((area) => (
                <span class="inline-flex rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-700">
                  {area}
                </span>
              ))}
            </div>
            <div class="mt-6 rounded-2xl bg-slate-950 px-5 py-4 text-sm leading-relaxed text-slate-200">
              {isHindi
                ? "ऑर्डर से डिस्पैच तक हम मॉडल सुझाव, कीमत मार्गदर्शन और डिलीवरी समन्वय में सीधे सहायता करते हैं।"
                : "From model selection to dispatch, we help directly with pricing guidance, support coordination, and delivery planning."}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <FAQSection faqs={faqItems} title={copy.faqTitle} />

  <CommonCTA headline={copy.ctaHeadline} subheadline={copy.ctaSubheadline} />
</Layout>
