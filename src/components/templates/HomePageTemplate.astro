---
import ModelsTable from "../ModelsTable.astro";
import TestimonialsGrid from "../TestimonialsGrid.astro";
import FAQSection from "../FAQSection.astro";
import CommonCTA from "../CommonCTA.astro";
import InsightCard from "../cards/InsightCard.astro";
import PageHero from "../sections/PageHero.astro";
import SectionHeading from "../sections/SectionHeading.astro";
import SignalStrip from "../sections/SignalStrip.astro";
import Layout from "../../layouts/Layout.astro";
import { getWhatsAppNumber } from "../../config/site";
import { commonData } from "../../data/locations-i18n.js";

interface HeroSignal {
  value: string;
  label: string;
}

interface SignalStripItem {
  value: string;
  label: string;
  note?: string;
}

interface InsightItem {
  title: string;
  body: string;
}

interface DecisionStat {
  label: string;
  value: string;
}

interface FAQItem {
  question: string;
  answer: string;
}

interface TestimonialItem {
  name: string;
  location: string;
  role: string;
  text: string;
  rating: number;
  project?: string;
}

interface HomePageContent {
  pageTitle: string;
  pageDescription: string;
  schema: Record<string, unknown>;
  hero: {
    eyebrow: string;
    title: string;
    description: string;
    signals: HeroSignal[];
    visualTitle: string;
    visualLines: string[];
    primaryActionLabel: string;
    secondaryActionLabel: string;
    whatsappMessage?: string;
  };
  stripItems: SignalStripItem[];
  problems: {
    title: string;
    subtitle: string;
    cards: InsightItem[];
  };
  advantages: {
    title: string;
    subtitle: string;
    cards: InsightItem[];
  };
  decisionPanel: {
    eyebrow: string;
    title: string;
    stats: DecisionStat[];
    ctaLabel: string;
    whatsappMessage?: string;
  };
  models: {
    title: string;
    subtitle: string;
  };
  testimonials: {
    title: string;
    subtitle: string;
    items: TestimonialItem[];
  };
  faq: {
    title: string;
    items: FAQItem[];
  };
  cta: {
    headline: string;
    subheadline: string;
  };
}

interface Props {
  content: HomePageContent;
}

const { content } = Astro.props;
const whatsappNumber = getWhatsAppNumber();
const heroMessage =
  content.hero.whatsappMessage ??
  "Hi! I want help choosing the right boring machine.";
const decisionMessage = content.decisionPanel.whatsappMessage ?? heroMessage;
---

<Layout title={content.pageTitle} description={content.pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(content.schema)} />

  <PageHero
    eyebrow={content.hero.eyebrow}
    title={content.hero.title}
    description={content.hero.description}
    signals={content.hero.signals}
    visualTitle={content.hero.visualTitle}
    visualLines={content.hero.visualLines}
    actions={[
      {
        href: `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(heroMessage)}`,
        label: content.hero.primaryActionLabel,
        variant: "primary",
        external: true,
      },
      {
        href: `tel:${commonData.phone}`,
        label: content.hero.secondaryActionLabel,
        variant: "secondary",
      },
    ]}
  />

  <SignalStrip items={content.stripItems} sectionClass="bg-slate-950 py-10" />

  <section class="section-shell section-tint">
    <div class="container mx-auto max-w-6xl px-4 md:px-8">
      <div class="surface-panel border border-slate-200/80 bg-white/90 p-6 shadow-[0_30px_90px_rgba(15,23,42,0.08)] md:p-8">
        <SectionHeading
          title={content.problems.title}
          subtitle={content.problems.subtitle}
        />

        <div class="grid gap-6 md:grid-cols-3">
          {content.problems.cards.map((card) => (
            <InsightCard title={card.title} body={card.body} tone="danger" icon="X" />
          ))}
        </div>

        <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
          {content.stripItems.map((item) => (
            <div class="surface-card border border-slate-200 bg-slate-950 px-5 py-4 text-white">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-emerald-200/80">
                {item.label}
              </p>
              <p class="mt-3 text-2xl font-bold">{item.value}</p>
              {item.note && <p class="mt-2 text-sm text-slate-300">{item.note}</p>}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell bg-white">
    <div class="container mx-auto max-w-6xl px-4 md:px-8">
      <SectionHeading
        title={content.advantages.title}
        subtitle={content.advantages.subtitle}
      />

      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(320px,0.9fr)]">
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {content.advantages.cards.map((card, index) => (
            <InsightCard
              title={card.title}
              body={card.body}
              tone="success"
              icon={index === 0 ? "A" : index === 1 ? "B" : "+"}
            />
          ))}
        </div>

        <aside class="surface-panel overflow-hidden border border-slate-200 bg-slate-950 text-white">
          <div class="border-b border-white/10 bg-[radial-gradient(circle_at_top_left,rgba(45,212,191,0.22),transparent_48%)] p-8">
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-emerald-200/80">
              {content.decisionPanel.eyebrow}
            </p>
            <h3 class="mt-4 text-3xl font-bold">{content.decisionPanel.title}</h3>
          </div>

          <div class="space-y-4 p-8">
            {content.decisionPanel.stats.map((stat) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 px-5 py-4">
                <p class="text-xs uppercase tracking-[0.2em] text-emerald-200/70">
                  {stat.label}
                </p>
                <p class="mt-2 text-2xl font-bold">{stat.value}</p>
              </div>
            ))}

            <a
              href={`https://wa.me/${whatsappNumber}?text=${encodeURIComponent(decisionMessage)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex w-full items-center justify-center rounded-2xl bg-white px-6 py-4 font-bold text-brand-teal transition hover:bg-slate-100"
            >
              {content.decisionPanel.ctaLabel}
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-shell section-tint">
    <div class="container mx-auto max-w-6xl px-4 md:px-8">
      <div class="surface-panel overflow-hidden border border-slate-200 bg-slate-950 text-white">
        <div class="grid gap-6 p-6 md:p-8 lg:grid-cols-[minmax(0,1fr)_minmax(320px,0.95fr)]">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-emerald-200/80">
              {content.decisionPanel.eyebrow}
            </p>
            <h2 class="mt-4 text-3xl font-bold md:text-4xl">
              {content.hero.title}
            </h2>
            <p class="mt-4 max-w-2xl text-sm leading-relaxed text-slate-300 md:text-base">
              {content.hero.description}
            </p>
            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
              <a
                href={`https://wa.me/${whatsappNumber}?text=${encodeURIComponent(heroMessage)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex min-h-[3.75rem] flex-1 items-center justify-center rounded-2xl bg-white px-6 py-4 font-bold text-slate-950 transition hover:bg-slate-100"
              >
                {content.hero.primaryActionLabel}
              </a>
              <a
                href={`tel:${commonData.phone}`}
                class="inline-flex min-h-[3.75rem] flex-1 items-center justify-center rounded-2xl border border-white/20 bg-white/10 px-6 py-4 font-bold text-white transition hover:bg-white/15"
              >
                {content.hero.secondaryActionLabel}
              </a>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            {content.decisionPanel.stats.map((stat) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 px-5 py-5">
                <p class="text-xs uppercase tracking-[0.2em] text-emerald-200/70">
                  {stat.label}
                </p>
                <p class="mt-3 text-3xl font-bold text-white">{stat.value}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <ModelsTable title={content.models.title} subtitle={content.models.subtitle} />

  <TestimonialsGrid
    testimonials={content.testimonials.items}
    title={content.testimonials.title}
    subtitle={content.testimonials.subtitle}
    sectionClass="section-shell bg-slate-50"
  />

  <FAQSection
    faqs={content.faq.items}
    title={content.faq.title}
    sectionId="faq"
  />

  <CommonCTA
    headline={content.cta.headline}
    subheadline={content.cta.subheadline}
  />
</Layout>
